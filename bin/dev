#!/usr/bin/env sh

if ! gem list foreman -i --silent; then
  echo "Installing foreman..."
  gem install foreman
fi

# Default local server ports if not specified
export PORT="${PORT:-3000}"
export DOCS_PORT="${DOCS_PORT:-3001}"

# Keep local docs preview compatible with installed Wrangler versions that
# cannot run a Workers runtime dated newer than their bundled binary.
export DOCS_COMPATIBILITY_DATE="${DOCS_COMPATIBILITY_DATE:-2026-04-27}"

# Let the debug gem allow remote connections,
# but avoid loading until `debugger` is called
export RUBY_DEBUG_OPEN="true"
export RUBY_DEBUG_LAZY="true"

exec foreman start -f Procfile.dev "$@"
