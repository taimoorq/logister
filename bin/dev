#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

REDIS_URL="${REDIS_URL:-redis://127.0.0.1:6379/0}"

start_local_redis_if_needed() {
  if command -v redis-cli >/dev/null 2>&1 && redis-cli -u "$REDIS_URL" ping >/dev/null 2>&1; then
    return
  end

  if command -v docker >/dev/null 2>&1; then
    echo "Starting local Redis via docker compose..."
    docker compose up -d redis >/dev/null 2>&1 || true
    sleep 1
  fi

  if command -v redis-cli >/dev/null 2>&1 && redis-cli -u "$REDIS_URL" ping >/dev/null 2>&1; then
    return
  end

  echo "Warning: Redis is not reachable at $REDIS_URL. Continuing with degraded caching."
}

start_local_redis_if_needed
exec ./bin/rails server "$@"
