# Rails
RAILS_ENV=development
RAILS_MAX_THREADS=5
REDIS_URL=redis://127.0.0.1:6379/0

# PostgreSQL
# For local Docker Compose, these defaults work with the postgres service.
DATABASE_URL=postgresql://logister:logister@127.0.0.1:5432/logister_development

# Production database password (used by config/database.yml in production)
LOGISTER_DATABASE_PASSWORD=

# ClickHouse (optional, recommended for scale)
LOGISTER_CLICKHOUSE_ENABLED=false
LOGISTER_CLICKHOUSE_URL=http://127.0.0.1:8123
LOGISTER_CLICKHOUSE_DATABASE=logister
LOGISTER_CLICKHOUSE_EVENTS_TABLE=events_raw
LOGISTER_CLICKHOUSE_USERNAME=default
LOGISTER_CLICKHOUSE_PASSWORD=
