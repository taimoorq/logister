# Rails
RAILS_ENV=development
RAILS_MAX_THREADS=5
REDIS_URL=redis://127.0.0.1:6379/0
# For Redis Cloud / redis.io in production, use TLS URL format:
# REDIS_URL=rediss://default:<password>@<host>:<port>/0
LOGISTER_EMAIL_FROM=support@logister.org

# PostgreSQL
# For Postgres.app local default:
DATABASE_URL=postgresql://127.0.0.1:5432/logister_development
# For Docker Compose postgres service instead:
# DATABASE_URL=postgresql://logister:logister@127.0.0.1:5432/logister_development

LOGISTER_ADMIN_EMAILS=you@example.com

# Production database password (used by config/database.yml in production)
LOGISTER_DATABASE_PASSWORD=

# ClickHouse (optional, recommended for scale)
LOGISTER_CLICKHOUSE_ENABLED=false
LOGISTER_CLICKHOUSE_URL=http://127.0.0.1:8123
LOGISTER_CLICKHOUSE_DATABASE=logister
LOGISTER_CLICKHOUSE_EVENTS_TABLE=events_raw
LOGISTER_CLICKHOUSE_USERNAME=default
LOGISTER_CLICKHOUSE_PASSWORD=

# Cloudflare Turnstile for Devise sign-in/sign-up forms
LOGISTER_TURNSTILE_ENABLED=false
LOGISTER_TURNSTILE_SITE_KEY=
LOGISTER_TURNSTILE_SECRET_KEY=

# Outbound email (SendGrid API)
SENDGRID_API_KEY=

# Cookie Consent (TermsFeed)
# Set to false to disable the banner entirely.
LOGISTER_COOKIE_CONSENT_ENABLED=true
# Analytics tags render by default in production only.
# Set true to render analytics tags in development/staging for verification.
LOGISTER_ANALYTICS_ENABLED=false
# Optional override for script URL/version.
# COOKIECONSENT_SCRIPT_URL=https://www.termsfeed.com/public/cookie-consent/4.2.0/cookie-consent.js
# Optional site-specific text/link values in the consent banner config.
COOKIECONSENT_WEBSITE_NAME=Logister
COOKIECONSENT_PRIVACY_POLICY_URL=https://logister.org/privacy

# Google Analytics (gtag) measurement ID, e.g. G-XXXXXXXXXX.
# In open source forks, use your own property ID.
# Analytics scripts are consent-gated and only run when both
# LOGISTER_COOKIE_CONSENT_ENABLED=true and GOOGLE_TAG_ID is set.
# GOOGLE_TAG_ID=

# Cloudflare Web Analytics token (optional).
# In open source forks, use your own Cloudflare token.
# Analytics scripts are consent-gated and only run when both
# LOGISTER_COOKIE_CONSENT_ENABLED=true and CLOUDFLARE_WEB_ANALYTICS_TOKEN is set.
# CLOUDFLARE_WEB_ANALYTICS_TOKEN=
