# Logister environment template.
#
# This file is safe to commit because every sensitive value is blank or a
# placeholder. Do not put production secrets in this file. Store real values in
# Fly secrets, your container orchestrator, Rails credentials, or another secret
# manager.

# Rails runtime
RAILS_ENV=development
RAILS_MAX_THREADS=5
RAILS_LOG_LEVEL=info
# Set PORT when your platform does not inject one for the web process.
# PORT=3000
# Set WEB_CONCURRENCY only when you want multiple Puma workers per web process.
# WEB_CONCURRENCY=1
# Required in production. Store this in your deploy provider, not in the repo.
# RAILS_MASTER_KEY=

# App URLs and access
LOGISTER_ADMIN_EMAILS=you@example.com
# Public URL used for links in emails and generated metadata.
# In production, set this to the canonical HTTPS URL for your self-hosted app.
LOGISTER_PUBLIC_URL=https://your-logister-host.example
# Public docs host used by in-app documentation links.
LOGISTER_DOCS_URL=https://docs.logister.org
# Prefix for newly generated project API tokens.
LOGISTER_API_KEY_PREFIX=logister

# Redis / background jobs
REDIS_URL=redis://127.0.0.1:6379/0
# For a production Compose stack with a redis service:
# REDIS_URL=redis://redis:6379/0
# For Redis Cloud / redis.io in production, use TLS URL format:
# REDIS_URL=rediss://default:<password>@<host>:<port>/0
SIDEKIQ_CONCURRENCY=5

# PostgreSQL
# For Postgres.app local default:
DATABASE_URL=postgresql://127.0.0.1:5432/logister_development
# For Docker Compose postgres service instead:
# DATABASE_URL=postgresql://logister:logister@127.0.0.1:5432/logister_development
# For a production Compose stack, use the service name and your real password:
# DATABASE_URL=postgresql://logister:<password>@postgres:5432/logister_production
# For managed providers with separate migration/admin URLs, such as Prisma Postgres:
# DATABASE_URL=<provider-pooled-postgres-url>
# DATABASE_MIGRATION_URL=<provider-direct-postgres-url>

# Optional self-observability
# Set these if you want the Logister app itself to send events to a Logister project.
# LOGISTER_API_KEY=
# LOGISTER_ENDPOINT=https://your-logister-host.example/api/v1/ingest_events
# LOGISTER_RELEASE=
# These knobs control which app-health events are captured when self-observability is configured.
# Keep them enabled for production diagnosis unless event volume becomes noisy.
LOGISTER_CAPTURE_REQUEST_SPANS=true
LOGISTER_CAPTURE_DB_METRICS=true
LOGISTER_DB_METRIC_MIN_DURATION_MS=25
LOGISTER_DB_METRIC_SAMPLE_RATE=1.0
LOGISTER_CAPTURE_SQL_BREADCRUMBS=true
LOGISTER_SQL_BREADCRUMB_MIN_DURATION_MS=25
LOGISTER_CAPTURE_WEB_REQUEST_TRANSACTIONS=true
LOGISTER_WEB_REQUEST_MIN_DURATION_MS=250
LOGISTER_WEB_REQUEST_LOG_MIN_DURATION_MS=1000

# ClickHouse (optional, recommended for scale)
LOGISTER_CLICKHOUSE_ENABLED=false
LOGISTER_CLICKHOUSE_URL=http://127.0.0.1:8123
# For a production Compose stack with a clickhouse service:
# LOGISTER_CLICKHOUSE_URL=http://clickhouse:8123
LOGISTER_CLICKHOUSE_DATABASE=logister
LOGISTER_CLICKHOUSE_EVENTS_TABLE=events_raw
LOGISTER_CLICKHOUSE_SPANS_TABLE=spans_raw
LOGISTER_CLICKHOUSE_USERNAME=default
LOGISTER_CLICKHOUSE_PASSWORD=
# Prevent a single ClickHouse outage from creating a self-monitoring event storm.
LOGISTER_CLICKHOUSE_FAILURE_THROTTLE_SECONDS=60

# S3 / telemetry archive storage
# Set ACTIVE_STORAGE_SERVICE=amazon in production when you want telemetry
# archives or uploaded files to use S3 instead of local disk.
ACTIVE_STORAGE_SERVICE=local
# For hosted deployments, prefer a least-privilege IAM user or role scoped to
# the telemetry archive bucket/prefix. Self-hosters can swap these for their own
# AWS account, bucket, or S3-compatible provider.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
# Optional for S3-compatible storage providers.
# AWS_S3_ENDPOINT=
# AWS_S3_FORCE_PATH_STYLE=false
LOGISTER_ARCHIVE_PREFIX=telemetry
# Optional: send telemetry archives to a named storage.yml service without
# changing the default Active Storage service used by app uploads.
# LOGISTER_ARCHIVE_STORAGE_SERVICE=amazon

# Cloudflare Turnstile for Devise sign-in/sign-up forms
LOGISTER_TURNSTILE_ENABLED=false
LOGISTER_TURNSTILE_SITE_KEY=
LOGISTER_TURNSTILE_SECRET_KEY=

# Outbound email (Amazon SES SMTP)
LOGISTER_EMAIL_FROM=support@logister.org
SES_REGION=us-east-1
SES_SMTP_USERNAME=
SES_SMTP_PASSWORD=
# SES_SMTP_ADDRESS=email-smtp.us-east-1.amazonaws.com
# SES_SMTP_PORT=587
# SES_SMTP_DOMAIN=logister.org
# SES_SMTP_ENABLE_STARTTLS_AUTO=true
# SES_SMTP_OPEN_TIMEOUT=5
# SES_SMTP_READ_TIMEOUT=5
# Optional SES configuration set for bounce/complaint/open delivery metrics.
# SES_CONFIGURATION_SET=logister-production

# Cookie Consent (Probo)
# Set to false to disable the banner entirely.
LOGISTER_COOKIE_CONSENT_ENABLED=true
# Analytics tags render by default in production only.
# Set true to render analytics tags in development/staging for verification.
LOGISTER_ANALYTICS_ENABLED=false
# Probo banner configuration. Set these in your deploy environment.
# PROBO_COOKIE_BANNER_SCRIPT_URL=https://cdn.jsdelivr.net/npm/@probo/cookie-banner/dist/cookie-banner.iife.js
PROBO_COOKIE_BANNER_ID=
PROBO_COOKIE_BANNER_BASE_URL=
PROBO_COOKIE_BANNER_POSITION=bottom-left
# Must match the Probo category slug used for analytics cookies.
LOGISTER_ANALYTICS_COOKIE_CATEGORY=analytics

# Google Analytics (gtag) measurement ID, e.g. G-XXXXXXXXXX.
# In open source forks, use your own property ID.
# Analytics scripts are consent-gated and only run when both
# LOGISTER_COOKIE_CONSENT_ENABLED=true and GOOGLE_TAG_ID is set.
# GOOGLE_TAG_ID=

# Cloudflare Web Analytics token (optional).
# In open source forks, use your own Cloudflare token.
# Analytics scripts are consent-gated and only run when both
# LOGISTER_COOKIE_CONSENT_ENABLED=true and CLOUDFLARE_WEB_ANALYTICS_TOKEN is set.
# CLOUDFLARE_WEB_ANALYTICS_TOKEN=

# Cloudflare Pages docs deployment
# These are GitHub Actions / Cloudflare Pages settings, not Rails runtime values.
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_PAGES_PROJECT=
# DOCS_PROBO_COOKIE_BANNER_ID=
# DOCS_PROBO_COOKIE_BANNER_BASE_URL=
# DOCS_PROBO_COOKIE_BANNER_POSITION=
# DOCS_ANALYTICS_COOKIE_CATEGORY=analytics
# DOCS_GOOGLE_TAG_ID=
# DOCS_CLOUDFLARE_WEB_ANALYTICS_TOKEN=
