<% content_for :title, "Self-Hosted Error Monitoring" %>
<% content_for :meta_description, "Logister is an open source, self-hosted error monitoring and bug triage app with grouped errors, assignment, runtime integrations, and Docker deployment docs." %>
<% content_for :canonical_path, root_path %>
<% content_for :og_type, "website" %>
<% content_for :json_ld, json_ld({
  "@context" => "https://schema.org",
  "@graph" => [
    {
      "@type" => "SoftwareApplication",
      "name" => "Logister",
      "applicationCategory" => "DeveloperApplication",
      "applicationSubCategory" => "Error monitoring and bug triage",
      "operatingSystem" => "Web",
      "description" => "Open source, self-hosted error monitoring and bug triage with grouped errors, assignment, runtime integrations, and Docker deployment docs.",
      "url" => absolute_url_for(root_path),
      "image" => absolute_url_for("/icon.png"),
      "license" => "https://github.com/taimoorq/logister/blob/main/LICENSE",
      "codeRepository" => "https://github.com/taimoorq/logister",
      "downloadUrl" => [
        "https://github.com/taimoorq/logister/pkgs/container/logister",
        "https://hub.docker.com/r/taimoorq/logister"
      ],
      "softwareVersion" => "2.9",
      "keywords" => "open source error monitoring, self-hosted bug tracking, Bugsnag alternative, Bugzilla alternative, Sentry alternative, application observability, Rails error tracking, Docker self hosting",
      "sameAs" => [
        "https://github.com/taimoorq/logister",
        "https://github.com/taimoorq/logister-ruby",
        "https://github.com/taimoorq/logister-dotnet",
        "https://github.com/taimoorq/logister-python",
        "https://github.com/taimoorq/logister-js",
        "https://github.com/taimoorq/logister-android",
        "https://github.com/taimoorq/logister-ios"
      ],
      "featureList" => [
        "Open source and forkable application source",
        "Self-hosted Rails app with PostgreSQL, Redis, and Sidekiq",
        "Versioned GHCR and Docker Hub images with optional Quay mirrors",
        "Grouped error inbox with assignment, status, and occurrence history",
        "Ruby instrumentation via the published gem",
        ".NET instrumentation for ASP.NET Core and C# services",
        "Python instrumentation for FastAPI, Django, Flask, Celery, and logging",
        "JavaScript and TypeScript instrumentation",
        "Android and iOS mobile integrations",
        "CFML and direct HTTP ingestion",
        "Error, log, metric, transaction, span, and check-in capture"
      ],
      "offers" => {
        "@type" => "Offer",
        "price" => "0",
        "priceCurrency" => "USD"
      }
    },
    {
      "@type" => "FAQPage",
      "mainEntity" => [
        {
          "@type" => "Question",
          "name" => "Can Logister be self-hosted?",
          "acceptedAnswer" => {
            "@type" => "Answer",
            "text" => "Yes. Logister is an open source Rails app designed to run with PostgreSQL, Redis, and a Sidekiq worker, with optional ClickHouse and S3-compatible archive storage."
          }
        },
        {
          "@type" => "Question",
          "name" => "Which runtimes can send events to Logister?",
          "acceptedAnswer" => {
            "@type" => "Answer",
            "text" => "Logister supports Ruby, .NET, Python, JavaScript and TypeScript, Android, iOS, CFML, Cloudflare Pages, and custom HTTP clients."
          }
        }
      ]
    }
  ]
}) %>
<%
  screenshot_exists = ->(path) { Rails.root.join("app/assets/images", path).exist? }
  dashboard_path = "screenshots/public/dashboard-overview.webp"
  project_home_path = "screenshots/public/project-home.webp"
  inbox_path = "screenshots/public/project-error-inbox.webp"
  insights_path = "screenshots/public/project-insights.webp"
  notifications_path = "screenshots/public/project-notifications.webp"
  retention_path = "screenshots/public/project-data-retention.webp"
  full_size_screenshot_label = ->(label) { "Open full-size #{label} screenshot" }
  screenshots = [
    {
      path: dashboard_path,
      alt: "Logister overview dashboard showing cross-app event flow, assignments, and errors that need attention",
      width: 3600,
      height: 2213,
      label: "overview"
    },
    {
      path: project_home_path,
      alt: "Logister project home showing a telemetry timeline and project health summaries",
      width: 3586,
      height: 1454,
      label: "project home"
    },
    {
      path: inbox_path,
      alt: "Logister project inbox with search, assignee filters, and stacktrace detail",
      width: 3600,
      height: 1660,
      label: "inbox"
    },
    {
      path: insights_path,
      alt: "Logister project insights timeline and recent event stream",
      width: 3600,
      height: 2795,
      label: "insights"
    },
    {
      path: notifications_path,
      alt: "Logister notification settings organized by alert purpose",
      width: 3600,
      height: 1754,
      label: "notifications"
    },
    {
      path: retention_path,
      alt: "Logister Data settings showing a saved retention summary and Archive Center overview",
      width: 3600,
      height: 2093,
      label: "retention"
    }
  ]
%>

<div class="marketing-home">
  <section class="marketing-hero" style="view-transition-name: public-hero; view-transition-class: public-panel;">
    <div class="hero-grid">
      <div>
        <p class="hero-kicker" data-controller="reveal" data-reveal-animation-class-value="reveal-up">Self-hosted error monitoring</p>
        <h1 class="hero-title" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="80">
          Self-host error monitoring and bug triage with Logister.
        </h1>
        <p class="hero-copy" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="140">
          Logister gives teams a forkable Rails app for grouped production errors, ownership, and runtime telemetry. Run it with PostgreSQL, Redis, and Sidekiq, then connect Ruby, .NET, Python, JavaScript, Android, iOS, CFML, Cloudflare Pages, or direct HTTP clients.
        </p>
        <div class="hero-actions" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="200">
          <%= link_to "Read self-hosting docs", docs_site_url(:self_hosting), target: "_blank", rel: "noopener noreferrer", class: "hero-btn hero-btn-primary" %>
          <%= link_to "Create hosted account", new_user_registration_path, class: "hero-btn hero-btn-secondary", data: { turbo: false } %>
        </div>
        <div class="hero-proof" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="250">
          <span>Open source</span>
          <span>Forkable</span>
          <span>Versioned registry images</span>
          <span>Self-host first</span>
          <span>Ruby, .NET, Python, JS, Android, iOS, and CFML</span>
        </div>
      </div>

      <div class="hero-surface" data-controller="reveal" data-reveal-animation-class-value="reveal-scale" data-reveal-delay-value="120">
        <div class="shot-frame shot-main">
          <% if screenshot_exists.call(dashboard_path) %>
            <%= link_to asset_path(dashboard_path),
                        target: "_blank",
                        rel: "noopener noreferrer",
                        class: "screenshot-fullsize-link",
                        aria: { label: full_size_screenshot_label.call("overview dashboard") } do %>
              <%= image_tag dashboard_path,
                            alt: "Logister overview dashboard showing cross-app event flow",
                            class: "hero-shot",
                            width: 3600,
                            height: 2213,
                            loading: "eager",
                            fetchpriority: "high",
                            decoding: "async" %>
            <% end %>
          <% else %>
            <div class="shot-placeholder">Add <code>app/assets/images/<%= dashboard_path %></code></div>
          <% end %>
        </div>
        <div class="hero-mobile-shots" aria-hidden="true">
          <div class="shot-frame">
            <% if screenshot_exists.call(project_home_path) %>
              <%= image_tag project_home_path,
                            alt: "",
                            class: "hero-shot",
                            width: 3586,
                            height: 1454,
                            loading: "lazy",
                            fetchpriority: "low",
                            decoding: "async" %>
            <% else %>
              <div class="shot-placeholder">project home</div>
            <% end %>
          </div>
          <div class="shot-frame">
            <% if screenshot_exists.call(insights_path) %>
              <%= image_tag insights_path,
                            alt: "",
                            class: "hero-shot",
                            width: 3600,
                            height: 2795,
                            loading: "lazy",
                            fetchpriority: "low",
                            decoding: "async" %>
            <% else %>
              <div class="shot-placeholder">insights</div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="logo-band" data-controller="reveal screenshots-slider" data-reveal-animation-class-value="reveal-up" style="view-transition-name: public-showcase; view-transition-class: public-panel;">
    <div class="logo-band-head">
      <p class="logo-band-title">Real product screenshots</p>
      <div class="screenshots-slider-controls" aria-label="Screenshot slider controls">
        <button type="button" class="screenshots-slider-arrow" data-action="click->screenshots-slider#prev" aria-label="Previous screenshot">
          <%= app_icon(:arrow_left, css: "w-4 h-4") %>
        </button>
        <button type="button" class="screenshots-slider-arrow" data-action="click->screenshots-slider#next" aria-label="Next screenshot">
          <%= app_icon(:arrow_left, css: "w-4 h-4 rotate-180") %>
        </button>
      </div>
    </div>

    <div class="shot-frame shot-wide screenshots-slider" aria-label="Logister product screenshots" role="region">
      <div class="screenshots-slider-track" data-screenshots-slider-target="track">
        <% screenshots.each do |screenshot| %>
          <div class="screenshots-slide" data-screenshots-slider-target="slide">
            <% if screenshot_exists.call(screenshot[:path]) %>
              <%= link_to asset_path(screenshot[:path]),
                          target: "_blank",
                          rel: "noopener noreferrer",
                          class: "screenshot-fullsize-link",
                          aria: { label: full_size_screenshot_label.call(screenshot[:label]) } do %>
                <%= image_tag screenshot[:path],
                              alt: screenshot[:alt],
                              class: "hero-shot",
                              width: screenshot[:width],
                              height: screenshot[:height],
                              loading: "lazy",
                              fetchpriority: "low",
                              decoding: "async" %>
              <% end %>
            <% else %>
              <div class="shot-placeholder">Add <code>app/assets/images/<%= screenshot[:path] %></code></div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="screenshots-slider-dots" role="tablist" aria-label="Select screenshot">
      <% screenshots.each_with_index do |screenshot, index| %>
        <button type="button" class="screenshots-slider-dot" data-screenshots-slider-target="dot" data-slide-index="<%= index %>" data-action="click->screenshots-slider#go" aria-label="Show <%= screenshot[:label] %> screenshot"></button>
      <% end %>
    </div>
  </section>

  <section class="stats-grid" style="view-transition-name: public-stats; view-transition-class: public-panel;">
    <article class="stat-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up">
      <p class="stat-label">Signal families</p>
      <p class="stat-value" data-controller="countup" data-countup-number-value="6">6</p>
      <p class="stat-meta">errors, logs, metrics, transactions, spans, check-ins</p>
    </article>
    <article class="stat-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="90">
      <p class="stat-label">Integration paths</p>
      <p class="stat-value" data-controller="countup" data-countup-number-value="9">9</p>
      <p class="stat-meta">SDK, mobile, Cloudflare Pages, CFML, and HTTP options</p>
    </article>
    <article class="stat-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="150">
      <p class="stat-label">Required app processes</p>
      <p class="stat-value" data-controller="countup" data-countup-number-value="2">2</p>
      <p class="stat-meta">Rails web plus Sidekiq worker</p>
    </article>
  </section>

  <section class="feature-grid" style="view-transition-name: public-features; view-transition-class: public-panel;">
    <article class="feature-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up">
      <p class="feature-kicker">Inbox</p>
      <h2>Bug tracking and error grouping in one queue</h2>
      <p>Use one inbox for unresolved, resolved, ignored, and archived issues, with owner assignment and occurrence history built around engineering triage.</p>
    </article>
    <article class="feature-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="60">
      <p class="feature-kicker">Context</p>
      <h2>Trace-linked detail with stacktrace and related logs</h2>
      <p>Pivot from an exception to nearby logs and transaction traces without switching tools or tabs.</p>
    </article>
    <article class="feature-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="120">
      <p class="feature-kicker">Self-hosting</p>
      <h2>Docs, releases, and Docker images for operators</h2>
      <p>Use public docs, explicit environment references, Docker self-hosting paths, versioned GHCR and Docker Hub images, and optional Quay mirrors instead of piecing together a private deployment recipe.</p>
    </article>
  </section>

  <section class="workflow-wrap" style="view-transition-name: public-positioning; view-transition-class: public-panel;">
    <div class="workflow-head" data-controller="reveal" data-reveal-animation-class-value="reveal-up">
      <p class="workflow-kicker">Why teams choose Logister</p>
      <h2>Built for teams that want ownership, not another closed SaaS dependency.</h2>
    </div>
    <div class="workflow-grid">
      <article class="workflow-step" data-controller="reveal" data-reveal-animation-class-value="reveal-up">
        <span class="workflow-index">01</span>
        <h3>Forkable source</h3>
        <p>Run the public Rails app as-is, inspect the implementation, or fork it when your team needs different operational defaults.</p>
      </article>
      <article class="workflow-step" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="80">
        <span class="workflow-index">02</span>
        <h3>Versioned releases</h3>
        <p>Self-hosters can track GitHub Releases and pull matching Docker images from GitHub Container Registry or Docker Hub.</p>
      </article>
      <article class="workflow-step" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="140">
        <span class="workflow-index">03</span>
        <h3>Documented operations</h3>
        <p>Deployment, environment variables, SES email, Redis jobs, PostgreSQL, optional ClickHouse, and SDK setup are documented for repeatable installs.</p>
      </article>
    </div>
  </section>

  <section class="workflow-wrap" style="view-transition-name: public-workflow; view-transition-class: public-panel;">
    <div class="workflow-head" data-controller="reveal" data-reveal-animation-class-value="reveal-up">
      <p class="workflow-kicker">How it works</p>
        <h2>Three steps from setup to owned triage</h2>
    </div>
    <div class="workflow-grid">
      <article class="workflow-step" data-controller="reveal" data-reveal-animation-class-value="reveal-up">
        <span class="workflow-index">01</span>
        <h3>Create project + key</h3>
        <p>Create a project, mint a key, and send your first event from production or staging.</p>
      </article>
      <article class="workflow-step" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="80">
        <span class="workflow-index">02</span>
        <h3>Choose your integration</h3>
        <p>Use <code>logister-ruby</code>, <code>logister-dotnet</code>, <code>logister-python</code>, <code>logister-js</code>, or direct CFML HTTP ingestion to capture errors, logs, metrics, spans, and check-ins with minimal setup.</p>
      </article>
      <article class="workflow-step" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="140">
        <span class="workflow-index">03</span>
        <h3>Triage with confidence</h3>
        <p>Group duplicates, confirm regressions per release, and drive fixes from a single inbox.</p>
      </article>
    </div>
  </section>

  <section class="code-and-proof" style="view-transition-name: public-proof; view-transition-class: public-panel;">
    <article class="code-block-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up">
      <p class="feature-kicker">Connect your stack</p>
      <pre><code>bundle add logister-ruby
dotnet add package Logister.AspNetCore
pip install logister-python
npm install logister-js
LOGISTER_API_KEY=your_key_here
</code></pre>
    </article>
    <article class="proof-card" data-controller="reveal" data-reveal-animation-class-value="reveal-scale" data-reveal-delay-value="120">
      <p class="proof-quote">MIT-licensed source, versioned Docker images, public SDK packages, and practical self-hosting docs keep the operating model inspectable.</p>
      <p class="proof-person">Proof links</p>
      <div class="proof-links">
        <a href="https://github.com/taimoorq/logister" target="_blank" rel="noopener">Self-host source</a>
        <a href="<%= docs_site_url(:self_hosting) %>" target="_blank" rel="noopener">Self-hosting docs</a>
        <a href="<%= docs_site_url(:product) %>" target="_blank" rel="noopener">Product guide</a>
        <a href="https://rubygems.org/gems/logister-ruby" target="_blank" rel="noopener">Ruby gem</a>
        <a href="https://www.nuget.org/packages/Logister.AspNetCore" target="_blank" rel="noopener">.NET package</a>
        <a href="https://pypi.org/project/logister-python/" target="_blank" rel="noopener">Python package</a>
        <a href="https://www.npmjs.com/package/logister-js" target="_blank" rel="noopener">JavaScript package</a>
        <a href="<%= docs_site_url(:cfml_integration) %>" target="_blank" rel="noopener">CFML guide</a>
        <a href="/llms.txt">AI docs</a>
      </div>
    </article>
  </section>

  <section class="feature-grid" style="view-transition-name: public-faq; view-transition-class: public-panel;">
    <article class="feature-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up">
      <p class="feature-kicker">FAQ</p>
      <h2>Can Logister be self-hosted?</h2>
      <p>Yes. The documented baseline is a Rails web process, a Sidekiq worker, PostgreSQL, and Redis. SMTP, ClickHouse, S3-compatible archives, Turnstile, and analytics are optional.</p>
    </article>
    <article class="feature-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="80">
      <p class="feature-kicker">FAQ</p>
      <h2>What does Logister collect?</h2>
      <p>Logister stores application errors, logs, metrics, transactions, spans, and check-ins, then turns repeated failures into grouped issues that can be assigned and reviewed.</p>
    </article>
    <article class="feature-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="140">
      <p class="feature-kicker">FAQ</p>
      <h2>Is the hosted app required?</h2>
      <p>No. The hosted app is optional. The primary product path is open source and self-hosted, with public source, Docker images, and deployment documentation.</p>
    </article>
  </section>

  <section class="marketing-cta" data-controller="reveal" data-reveal-animation-class-value="reveal-up" style="view-transition-name: public-cta; view-transition-class: public-panel;">
    <div>
      <p class="workflow-kicker">Run it yourself</p>
      <h2>Self-host Logister and keep clearer error ownership close to your team.</h2>
    </div>
    <div class="hero-actions">
      <%= link_to "Read self-hosting docs", docs_site_url(:self_hosting), target: "_blank", rel: "noopener noreferrer", class: "hero-btn hero-btn-primary" %>
      <%= link_to "Use hosted app", new_user_registration_path, class: "hero-btn hero-btn-secondary", data: { turbo: false } %>
    </div>
  </section>
</div>
