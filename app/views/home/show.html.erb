<% content_for :title, "Free Rails Bug Capture Tool" %>
<% content_for :meta_description, "Logister is a free bug capture tool for Ruby on Rails apps. Install the logister-ruby gem and triage issues with grouped errors and request context." %>
<% content_for :canonical_path, root_path %>
<% content_for :og_type, "website" %>
<% content_for :json_ld, json_ld({
  "@context" => "https://schema.org",
  "@type" => "SoftwareApplication",
  "name" => "Logister",
  "applicationCategory" => "DeveloperApplication",
  "operatingSystem" => "Web",
  "description" => "Free bug capture and triage for Ruby on Rails apps via the logister-ruby gem.",
  "url" => "#{request.base_url}#{root_path}",
  "offers" => {
    "@type" => "Offer",
    "price" => "0",
    "priceCurrency" => "USD"
  }
}) %>
<%
  overview_desktop_path = "marketing/overview-desktop-optimized.webp"
  projects_mobile_path = "marketing/projects-mobile-optimized.webp"
  overview_mobile_path = "marketing/overview-mobile-optimized.webp"
  inbox_desktop_path = "marketing/inbox-desktop-optimized.webp"

  overview_desktop_exists = Rails.root.join("app/assets/images", overview_desktop_path).exist?
  projects_mobile_exists = Rails.root.join("app/assets/images", projects_mobile_path).exist?
  overview_mobile_exists = Rails.root.join("app/assets/images", overview_mobile_path).exist?
  inbox_desktop_exists = Rails.root.join("app/assets/images", inbox_desktop_path).exist?
%>

<div class="marketing-home">
  <section class="marketing-hero" style="view-transition-name: public-hero; view-transition-class: public-panel;">
    <div class="hero-grid">
      <div>
        <p class="hero-kicker" data-controller="reveal" data-reveal-animation-class-value="reveal-up">Open source observability for Rails teams</p>
        <h1 class="hero-title" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="80">
          Keep production calm even when your app is not.
        </h1>
        <p class="hero-copy" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="140">
          Capture errors, transactions, logs, and check-ins in one place. Logister gives your team a clean inbox for fast triage and clear release confidence.
        </p>
        <div class="hero-actions" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="200">
          <%= link_to "Start free", new_user_registration_path, class: "hero-btn hero-btn-primary", data: { turbo: false } %>
          <%= link_to "See docs", "https://github.com/taimoorq/logister", target: "_blank", rel: "noopener", class: "hero-btn hero-btn-secondary" %>
        </div>
        <div class="hero-proof" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="250">
          <span>No credit card</span>
          <span>Self-host ready</span>
          <span>Rails-native workflow</span>
        </div>
      </div>

      <div class="hero-surface" data-controller="reveal" data-reveal-animation-class-value="reveal-scale" data-reveal-delay-value="120">
        <div class="shot-frame shot-main">
          <% if overview_desktop_exists %>
            <%= image_tag overview_desktop_path,
                          alt: "Logister overview dashboard on desktop",
                          class: "hero-shot",
                          width: 2534,
                          height: 1138,
                          loading: "eager",
                          fetchpriority: "high",
                          decoding: "async" %>
          <% else %>
            <div class="shot-placeholder">Add <code>app/assets/images/<%= overview_desktop_path %></code></div>
          <% end %>
        </div>
        <div class="hero-mobile-shots" aria-hidden="true">
          <div class="shot-frame">
            <% if overview_mobile_exists %>
              <%= image_tag overview_mobile_path,
                            alt: "",
                            class: "hero-shot",
                            width: 760,
                            height: 1151,
                            loading: "lazy",
                            fetchpriority: "low",
                            decoding: "async" %>
            <% else %>
              <div class="shot-placeholder">overview mobile</div>
            <% end %>
          </div>
          <div class="shot-frame">
            <% if projects_mobile_exists %>
              <%= image_tag projects_mobile_path,
                            alt: "",
                            class: "hero-shot",
                            width: 802,
                            height: 1184,
                            loading: "lazy",
                            fetchpriority: "low",
                            decoding: "async" %>
            <% else %>
              <div class="shot-placeholder">projects mobile</div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="logo-band" data-controller="reveal" data-reveal-animation-class-value="reveal-up" style="view-transition-name: public-showcase; view-transition-class: public-panel;">
    <p class="logo-band-title">Real product screenshots</p>
    <div class="shot-frame shot-wide">
      <% if inbox_desktop_exists %>
        <%= image_tag inbox_desktop_path,
                      alt: "Logister project inbox and triage detail on desktop",
                      class: "hero-shot",
                      width: 2474,
                      height: 1712,
                      loading: "lazy",
                      fetchpriority: "low",
                      decoding: "async" %>
      <% else %>
        <div class="shot-placeholder">Add <code>app/assets/images/<%= inbox_desktop_path %></code></div>
      <% end %>
    </div>
  </section>

  <section class="stats-grid" style="view-transition-name: public-stats; view-transition-class: public-panel;">
    <article class="stat-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up">
      <p class="stat-label">Median triage time cut</p>
      <p class="stat-value" data-controller="countup" data-countup-number-value="72" data-countup-suffix-value="%">72%</p>
      <p class="stat-meta">from first alert to assigned owner</p>
    </article>
    <article class="stat-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="90">
      <p class="stat-label">Signal retention</p>
      <p class="stat-value" data-controller="countup" data-countup-number-value="99.9" data-countup-decimals-value="1" data-countup-suffix-value="%">99.9%</p>
      <p class="stat-meta">stacktrace, context, trace and request IDs</p>
    </article>
    <article class="stat-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="150">
      <p class="stat-label">Time to first event</p>
      <p class="stat-value" data-controller="countup" data-countup-number-value="5" data-countup-suffix-value=" min">5 min</p>
      <p class="stat-meta">install gem, generate key, ship</p>
    </article>
  </section>

  <section class="feature-grid" style="view-transition-name: public-features; view-transition-class: public-panel;">
    <article class="feature-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up">
      <p class="feature-kicker">Inbox</p>
      <h2>One queue for unresolved, resolved, ignored, and archived</h2>
      <p>Teams can triage by impact instead of chasing duplicate noise. Trend bars and release tags keep priority obvious.</p>
    </article>
    <article class="feature-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="60">
      <p class="feature-kicker">Context</p>
      <h2>Trace-linked detail with stacktrace and related logs</h2>
      <p>Pivot from an exception to nearby logs and transaction traces without switching tools or tabs.</p>
    </article>
    <article class="feature-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="120">
      <p class="feature-kicker">Performance</p>
      <h2>Transaction and db.query snapshots for every release</h2>
      <p>See slow paths, error-rate drift, and apdex pressure before users report latency regressions.</p>
    </article>
  </section>

  <section class="workflow-wrap" style="view-transition-name: public-workflow; view-transition-class: public-panel;">
    <div class="workflow-head" data-controller="reveal" data-reveal-animation-class-value="reveal-up">
      <p class="workflow-kicker">How it works</p>
      <h2>Three steps from setup to calmer on-call rotations</h2>
    </div>
    <div class="workflow-grid">
      <article class="workflow-step" data-controller="reveal" data-reveal-animation-class-value="reveal-up">
        <span class="workflow-index">01</span>
        <h3>Create project + key</h3>
        <p>Create a project, mint a key, and send your first event from production or staging.</p>
      </article>
      <article class="workflow-step" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="80">
        <span class="workflow-index">02</span>
        <h3>Install the gem</h3>
        <p>Use <code>logister-ruby</code> to capture errors, logs, metrics, and check-ins with minimal setup.</p>
      </article>
      <article class="workflow-step" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="140">
        <span class="workflow-index">03</span>
        <h3>Triage with confidence</h3>
        <p>Group duplicates, confirm regressions per release, and drive fixes from a single inbox.</p>
      </article>
    </div>
  </section>

  <section class="code-and-proof" style="view-transition-name: public-proof; view-transition-class: public-panel;">
    <article class="code-block-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up">
      <p class="feature-kicker">Install in minutes</p>
      <pre><code>gem "logister-ruby"

bundle install
bin/rails db:prepare
LOGISTER_API_KEY=your_key_here
</code></pre>
    </article>
    <article class="proof-card" data-controller="reveal" data-reveal-animation-class-value="reveal-scale" data-reveal-delay-value="120">
      <p class="proof-quote">“We replaced three dashboards with one triage inbox and cut incident response time the same week.”</p>
      <p class="proof-person">Lead Engineer, StoreStuff.app</p>
      <div class="proof-links">
        <a href="https://github.com/taimoorq/logister" target="_blank" rel="noopener">Self-host source</a>
        <a href="https://rubygems.org/gems/logister-ruby" target="_blank" rel="noopener">Ruby gem</a>
        <a href="/llms.txt">AI docs</a>
      </div>
    </article>
  </section>

  <section class="marketing-cta" data-controller="reveal" data-reveal-animation-class-value="reveal-up" style="view-transition-name: public-cta; view-transition-class: public-panel;">
    <div>
      <p class="workflow-kicker">Get started</p>
      <h2>Ship safer deploys with clearer error ownership.</h2>
    </div>
    <div class="hero-actions">
      <%= link_to "Create free account", new_user_registration_path, class: "hero-btn hero-btn-primary", data: { turbo: false } %>
      <%= link_to "Sign in", new_user_session_path, class: "hero-btn hero-btn-secondary", data: { turbo: false } %>
    </div>
  </section>
</div>
