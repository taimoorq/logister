<% content_for :title, "About" %>
<% content_for :meta_description, "About Logister, an open source error tracking and observability app for Ruby, Python, JavaScript/TypeScript, and ColdFusion/CFML teams." %>
<% content_for :canonical_path, about_path %>
<% content_for :og_type, "article" %>
<% content_for :json_ld, json_ld({
  "@context" => "https://schema.org",
  "@type" => "AboutPage",
  "name" => "About Logister",
  "url" => absolute_url_for(about_path),
  "description" => "About Logister and its open source observability workflow for Ruby, Python, JavaScript, TypeScript, and CFML apps."
}) %>
<%
  overview_desktop_path = "marketing/overview-desktop-optimized.webp"
  projects_mobile_path = "marketing/projects-mobile-optimized.webp"
  overview_mobile_path = "marketing/overview-mobile-optimized.webp"
  inbox_desktop_path = "marketing/inbox-desktop-optimized.webp"

  overview_desktop_exists = Rails.root.join("app/assets/images", overview_desktop_path).exist?
  projects_mobile_exists = Rails.root.join("app/assets/images", projects_mobile_path).exist?
  overview_mobile_exists = Rails.root.join("app/assets/images", overview_mobile_path).exist?
  inbox_desktop_exists = Rails.root.join("app/assets/images", inbox_desktop_path).exist?
%>

<div class="marketing-home about-page">
  <section class="about-hero" style="view-transition-name: public-hero; view-transition-class: public-panel;">
    <div class="hero-grid">
      <div>
        <p class="hero-kicker" data-controller="reveal" data-reveal-animation-class-value="reveal-up">About Logister</p>
        <h1 class="hero-title" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="70">
          Built for backend teams that need faster triage, not another noisy dashboard.
        </h1>
        <p class="hero-copy" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="130">
          Logister is an open source reporting shell and incident triage workflow for Ruby, Python, JavaScript/TypeScript,
          and ColdFusion/CFML apps. We focus on grouping repeated failures, preserving request context,
          and keeping the fix loop short from alert to ownership.
        </p>
        <div class="hero-actions" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="190">
          <%= link_to "Create account", new_user_registration_path, class: "hero-btn hero-btn-primary", data: { turbo: false } %>
          <%= link_to "View source", "https://github.com/taimoorq/logister", target: "_blank", rel: "noopener", class: "hero-btn hero-btn-secondary" %>
        </div>
      </div>
      <div class="shot-frame" data-controller="reveal" data-reveal-animation-class-value="reveal-scale" data-reveal-delay-value="120">
        <% if overview_desktop_exists %>
          <%= image_tag overview_desktop_path, alt: "Logister overview dashboard screenshot", class: "hero-shot" %>
        <% else %>
          <div class="shot-placeholder">Add <code>app/assets/images/<%= overview_desktop_path %></code></div>
        <% end %>
      </div>
    </div>
  </section>

  <section class="about-strip" data-controller="reveal" data-reveal-animation-class-value="reveal-up" style="view-transition-name: public-stats; view-transition-class: public-panel;">
    <article class="about-pill-card">
      <p class="stat-label">Focus</p>
      <p class="about-pill-value">Error ownership + release confidence</p>
    </article>
    <article class="about-pill-card">
      <p class="stat-label">Approach</p>
      <p class="about-pill-value">Open source, self-hosted shell, multi-runtime</p>
    </article>
    <article class="about-pill-card">
      <p class="stat-label">Deploy</p>
      <p class="about-pill-value">Cloud hosted or fully self-hosted</p>
    </article>
  </section>

  <section class="about-showcase" style="view-transition-name: public-showcase; view-transition-class: public-panel;">
    <div class="about-showcase-head" data-controller="reveal" data-reveal-animation-class-value="reveal-up">
      <p class="workflow-kicker">Product in action</p>
      <h2>Designed for day-to-day triage flow on desktop and mobile.</h2>
    </div>
    <div class="about-showcase-grid">
      <article class="about-shot-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up">
        <p class="feature-kicker">Project inbox</p>
        <div class="shot-frame">
          <% if inbox_desktop_exists %>
            <%= image_tag inbox_desktop_path, alt: "Logister inbox detail view screenshot", class: "hero-shot" %>
          <% else %>
            <div class="shot-placeholder">Add <code>app/assets/images/<%= inbox_desktop_path %></code></div>
          <% end %>
        </div>
      </article>
      <article class="about-shot-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="90">
        <p class="feature-kicker">Mobile overview</p>
        <div class="shot-frame">
          <% if overview_mobile_exists %>
            <%= image_tag overview_mobile_path, alt: "Logister overview mobile screenshot", class: "hero-shot" %>
          <% else %>
            <div class="shot-placeholder">Add <code>app/assets/images/<%= overview_mobile_path %></code></div>
          <% end %>
        </div>
      </article>
      <article class="about-shot-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="150">
        <p class="feature-kicker">Mobile projects</p>
        <div class="shot-frame">
          <% if projects_mobile_exists %>
            <%= image_tag projects_mobile_path, alt: "Logister projects mobile screenshot", class: "hero-shot" %>
          <% else %>
            <div class="shot-placeholder">Add <code>app/assets/images/<%= projects_mobile_path %></code></div>
          <% end %>
        </div>
      </article>
    </div>
  </section>

  <section class="feature-grid" style="view-transition-name: public-features; view-transition-class: public-panel;">
    <article class="feature-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up">
      <p class="feature-kicker">Capture</p>
      <h2>Ingest errors, transactions, logs, metrics, and check-ins</h2>
      <p>One API shape, first-party Ruby, Python, and JavaScript packages, and one place to inspect reliability signals per project and release.</p>
    </article>
    <article class="feature-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="80">
      <p class="feature-kicker">Triage</p>
      <h2>Group duplicate failures into an actionable inbox</h2>
      <p>Move issues through unresolved, resolved, ignored, and archived states with context preserved.</p>
    </article>
    <article class="feature-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="140">
      <p class="feature-kicker">Operate</p>
      <h2>Run hosted or self-host with infrastructure you control</h2>
      <p>Most teams only need the product and the language packages. Runtime stack details matter when you want to operate Logister yourself.</p>
    </article>
  </section>

  <section class="workflow-wrap" style="view-transition-name: public-workflow; view-transition-class: public-panel;">
    <div class="workflow-head" data-controller="reveal" data-reveal-animation-class-value="reveal-up">
      <p class="workflow-kicker">Operator details</p>
      <h2>Runtime and deployment details for teams self-hosting the app.</h2>
    </div>
    <div class="about-config-grid">
      <article class="workflow-step" data-controller="reveal" data-reveal-animation-class-value="reveal-up">
        <h3>Runtime stack</h3>
        <ul class="about-list">
          <li>Ruby on Rails + Puma</li>
          <li>PostgreSQL (control plane and event store)</li>
          <li>Redis + Sidekiq for background processing</li>
          <li>Optional ClickHouse for analytics acceleration</li>
        </ul>
      </article>
      <article class="workflow-step" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="45">
        <h3>Supported app integrations</h3>
        <ul class="about-list">
          <li><code>logister-ruby</code> for Rails and Ruby apps</li>
          <li><code>logister-python</code> for FastAPI, Django, Flask, Celery, and Python services</li>
          <li><code>logister-js</code> for JavaScript and TypeScript apps, with optional Express middleware</li>
          <li>Direct HTTP ingestion for Lucee and Adobe ColdFusion</li>
        </ul>
      </article>
      <article class="workflow-step" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="90">
        <h3>Required production env</h3>
        <ul class="about-list">
          <li><code>RAILS_MASTER_KEY</code></li>
          <li><code>DATABASE_URL</code></li>
          <li><code>REDIS_URL</code></li>
          <li><code>LOGISTER_ADMIN_EMAILS</code></li>
        </ul>
      </article>
      <article class="workflow-step" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="150">
        <h3>Optional integrations</h3>
        <ul class="about-list">
          <li>SendGrid for transactional email</li>
          <li>Cloudflare Turnstile for auth protection</li>
          <li>ClickHouse dual-write analytics path</li>
          <li>Docker/Kamal deployment flows</li>
        </ul>
      </article>
    </div>
  </section>

  <section class="marketing-cta" data-controller="reveal" data-reveal-animation-class-value="reveal-up" style="view-transition-name: public-cta; view-transition-class: public-panel;">
    <div>
      <p class="workflow-kicker">Next step</p>
      <h2>Start capturing real production issues in minutes.</h2>
    </div>
    <div class="hero-actions">
      <%= link_to "Sign up free", new_user_registration_path, class: "hero-btn hero-btn-primary", data: { turbo: false } %>
      <%= link_to "Read docs", docs_site_url, target: "_blank", rel: "noopener noreferrer", class: "hero-btn hero-btn-secondary" %>
    </div>
  </section>
</div>
