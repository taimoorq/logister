<% content_for :title, "Terms of Use" %>
<% content_for :meta_description, "Read Logister's terms of use for service access, account responsibilities, and data submission rules." %>
<% content_for :canonical_path, terms_path %>
<% content_for :og_type, "article" %>
<% content_for :json_ld, json_ld({
  "@context" => "https://schema.org",
  "@type" => "WebPage",
  "name" => "Logister Terms of Use",
  "url" => "#{request.base_url}#{terms_path}",
  "description" => "Terms of use for Logister."
}) %>

<div class="marketing-home legal-page">
  <section class="legal-hero" data-controller="reveal" data-reveal-animation-class-value="reveal-up">
    <p class="hero-kicker">Legal</p>
    <h1 class="hero-title">Terms of Use</h1>
    <p class="hero-copy max-w-3xl">
      These terms govern access to and use of Logister, including account security,
      acceptable service usage, and responsibilities for submitted application data.
    </p>
    <p class="legal-updated"><strong>Last updated:</strong> February 28, 2026</p>
  </section>

  <section class="legal-summary-grid">
    <article class="about-pill-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up">
      <p class="stat-label">Use of service</p>
      <p class="about-pill-value">Use lawfully and avoid platform abuse</p>
    </article>
    <article class="about-pill-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="80">
      <p class="stat-label">Accounts and keys</p>
      <p class="about-pill-value">You secure credentials and API tokens</p>
    </article>
    <article class="about-pill-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="140">
      <p class="stat-label">Availability</p>
      <p class="about-pill-value">Service may evolve with reasonable notice</p>
    </article>
  </section>

  <section class="legal-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up">
    <article class="legal-section">
      <h2>Use of service</h2>
      <p>
        You may use Logister to monitor and troubleshoot your applications in accordance
        with applicable law. You must not misuse the service, attempt unauthorized access,
        or disrupt platform operations.
      </p>
    </article>

    <article class="legal-section">
      <h2>Account responsibilities</h2>
      <p>
        You are responsible for safeguarding your account credentials and API keys, and for
        all activity that occurs under your account.
      </p>
    </article>

    <article class="legal-section">
      <h2>Data submission</h2>
      <p>
        You are responsible for the data your applications send to Logister, including any
        personal or sensitive data included in error payloads.
      </p>
    </article>

    <article class="legal-section">
      <h2>Service availability</h2>
      <p>
        Logister is provided on an "as is" basis. We may change or discontinue features,
        including free usage terms, with reasonable notice.
      </p>
    </article>

    <article class="legal-section">
      <h2>Contact</h2>
      <p>
        For legal questions, contact
        <code>support@logister.org</code>.
      </p>
    </article>
  </section>

  <section class="marketing-cta" data-controller="reveal" data-reveal-animation-class-value="reveal-up">
    <div>
      <p class="workflow-kicker">Related pages</p>
      <h2>Need policy or product context?</h2>
    </div>
    <div class="hero-actions">
      <%= link_to "Privacy policy", privacy_path, class: "hero-btn hero-btn-primary" %>
      <%= link_to "About Logister", about_path, class: "hero-btn hero-btn-secondary" %>
    </div>
  </section>
</div>
