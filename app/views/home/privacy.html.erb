<% content_for :title, "Privacy Policy" %>
<% content_for :meta_description, "Read Logister's privacy policy for how account and application telemetry data is handled." %>
<% content_for :canonical_path, privacy_path %>
<% content_for :og_type, "article" %>
<% content_for :json_ld, json_ld({
  "@context" => "https://schema.org",
  "@type" => "WebPage",
  "name" => "Logister Privacy Policy",
  "url" => "#{request.base_url}#{privacy_path}",
  "description" => "Privacy policy for Logister."
}) %>

<section class="card legal-page">
  <h1>Privacy Policy</h1>
  <p class="muted"><strong>Last updated:</strong> February 28, 2026</p>

  <h2>Information we collect</h2>
  <p class="muted">
    We collect account information you provide (such as email and profile name),
    plus error and telemetry data sent by your applications through our ingest API.
  </p>

  <h2>How we use information</h2>
  <p class="muted">
    We use collected data to operate Logister, provide error monitoring features,
    improve product reliability, and communicate service-related updates.
  </p>

  <h2>Data controls</h2>
  <p class="muted">
    You are responsible for configuring what your applications send. Avoid sending
    secrets or sensitive personal data in event payloads unless required and properly protected.
  </p>

  <h2>Security</h2>
  <p class="muted">
    We use reasonable administrative and technical measures to protect data, but no
    internet transmission or storage system is guaranteed to be fully secure.
  </p>

  <h2>Contact</h2>
  <p class="muted">
    For privacy questions, contact <code>support@logister.org</code>.
  </p>
</section>
