<% content_for :title, "Privacy Policy" %>
<% content_for :meta_description, "Read Logister's privacy policy for how account and application telemetry data is handled." %>
<% content_for :canonical_path, privacy_path %>
<% content_for :og_type, "article" %>
<% content_for :json_ld, json_ld({
  "@context" => "https://schema.org",
  "@type" => "WebPage",
  "name" => "Logister Privacy Policy",
  "url" => "#{request.base_url}#{privacy_path}",
  "description" => "Privacy policy for Logister."
}) %>

<div class="marketing-home legal-page">
  <section class="legal-hero" data-controller="reveal" data-reveal-animation-class-value="reveal-up" style="view-transition-name: public-hero; view-transition-class: public-panel;">
    <p class="hero-kicker">Legal</p>
    <h1 class="hero-title">Privacy Policy</h1>
    <p class="hero-copy max-w-3xl">
      This policy explains what information Logister collects, how it is used,
      and what controls you have when using the hosted service and related APIs.
    </p>
    <p class="legal-updated"><strong>Last updated:</strong> February 28, 2026</p>
  </section>

  <section class="legal-summary-grid" style="view-transition-name: public-stats; view-transition-class: public-panel;">
    <article class="about-pill-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up">
      <p class="stat-label">What we collect</p>
      <p class="about-pill-value">Account details + telemetry payloads</p>
    </article>
    <article class="about-pill-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="80">
      <p class="stat-label">What we do with it</p>
      <p class="about-pill-value">Operate, improve, and secure the service</p>
    </article>
    <article class="about-pill-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up" data-reveal-delay-value="140">
      <p class="stat-label">Your responsibility</p>
      <p class="about-pill-value">Control what event data your apps send</p>
    </article>
  </section>

  <section class="legal-card" data-controller="reveal" data-reveal-animation-class-value="reveal-up" style="view-transition-name: public-workflow; view-transition-class: public-panel;">
    <article class="legal-section">
      <h2>Information we collect</h2>
      <p>
        We collect account information you provide (such as email and profile name),
        plus error and telemetry data sent by your applications through our ingest API.
      </p>
    </article>

    <article class="legal-section">
      <h2>How we use information</h2>
      <p>
        We use collected data to operate Logister, provide error monitoring features,
        improve product reliability, and communicate service-related updates.
      </p>
    </article>

    <article class="legal-section">
      <h2>Data controls</h2>
      <p>
        You are responsible for configuring what your applications send. Avoid sending
        secrets or sensitive personal data in event payloads unless required and properly protected.
      </p>
    </article>

    <article class="legal-section">
      <h2>Security</h2>
      <p>
        We use reasonable administrative and technical measures to protect data, but no
        internet transmission or storage system is guaranteed to be fully secure.
      </p>
    </article>

    <article class="legal-section">
      <h2>Contact</h2>
      <p>
        For privacy questions, contact
        <code>support@logister.org</code>.
      </p>
    </article>
  </section>

  <section class="marketing-cta" data-controller="reveal" data-reveal-animation-class-value="reveal-up" style="view-transition-name: public-cta; view-transition-class: public-panel;">
    <div>
      <p class="workflow-kicker">Related pages</p>
      <h2>Need legal or product details?</h2>
    </div>
    <div class="hero-actions">
      <%= link_to "Terms of use", terms_path, class: "hero-btn hero-btn-primary" %>
      <%= link_to "About Logister", about_path, class: "hero-btn hero-btn-secondary" %>
    </div>
  </section>
</div>
