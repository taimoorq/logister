<section class="max-w-xl mx-auto">
  <div class="rounded-xl bg-white border border-slate-200 shadow-sm p-6 sm:p-8">
    <h1 class="text-2xl font-bold text-slate-900 mb-2 inline-flex items-center gap-2"><%= app_icon(:pencil, css: "w-6 h-6") %><span>Edit profile</span></h1>
    <p class="text-slate-600 text-sm mb-6">Update your public account details.</p>

    <%= form_with model: @user, url: profile_path, method: :patch, data: { turbo: false } do |f| %>
      <div class="space-y-4">
        <div>
          <%= f.label :name, class: "form-label" %>
          <%= f.text_field :name, maxlength: 100, placeholder: "Your name", class: "form-input" %>
        </div>

        <% if @user.errors.any? %>
          <div class="rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">
            <%= @user.errors.full_messages.to_sentence %>
          </div>
        <% end %>

        <div class="flex flex-wrap gap-3 pt-2">
          <%= f.button class: "btn-primary inline-flex items-center gap-2" do %>
            <%= app_icon(:check) %><span>Save profile</span>
          <% end %>
          <%= link_to profile_path, class: "inline-flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-medium border border-slate-300 bg-white text-slate-700 hover:bg-slate-50 no-underline" do %>
            <%= app_icon(:x) %><span>Cancel</span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>
