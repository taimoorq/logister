<div class="space-y-5">
  <section class="rounded-xl border border-slate-200 bg-white px-5 py-4 shadow-sm">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-3">
      <div>
        <h1 class="text-2xl font-semibold text-slate-900">Overview</h1>
        <p class="text-sm text-slate-500 mt-1">Cross-project error health and triage queues.</p>
      </div>
      <%= link_to "New project", new_project_path, class: "inline-flex items-center justify-center rounded-md bg-blue-600 px-4 py-2 text-sm font-semibold text-white no-underline hover:bg-blue-700" %>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mt-4">
      <article class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3">
        <p class="text-[11px] uppercase tracking-[0.14em] font-semibold text-slate-500">Projects</p>
        <p class="text-2xl font-semibold text-slate-900 mt-1"><%= @projects_count %></p>
      </article>
      <article class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3">
        <p class="text-[11px] uppercase tracking-[0.14em] font-semibold text-slate-500">Active API keys</p>
        <p class="text-2xl font-semibold text-slate-900 mt-1"><%= @api_keys_count %></p>
      </article>
      <article class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3">
        <p class="text-[11px] uppercase tracking-[0.14em] font-semibold text-slate-500">Events (24h)</p>
        <p class="text-2xl font-semibold text-slate-900 mt-1"><%= @events_last_24h %></p>
      </article>
    </div>
  </section>

  <section class="grid grid-cols-1 xl:grid-cols-[1.65fr_1fr] gap-5">
    <div class="space-y-4">
      <div class="flex items-center justify-between gap-3">
        <h2 class="text-lg font-semibold text-slate-900">Error views</h2>
        <%= link_to "Open all projects", projects_path, class: "text-sm font-medium text-blue-600 hover:text-blue-700 no-underline" %>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <% if @error_views.any? %>
          <% @error_views.each_with_index do |project_view, idx| %>
            <article class="rounded-xl bg-white border border-slate-200 shadow-sm p-4 overflow-hidden" style="view-transition-name: dashboard-error-view-<%= project_view[:project].id %>-<%= idx %>; view-transition-class: dashboard-error-card;">
              <div class="flex items-start justify-between gap-3 mb-4">
                <div>
                  <h3 class="text-base font-semibold text-slate-900 truncate"><%= project_view[:project].name %></h3>
                  <p class="text-xs text-slate-500 mt-1">
                    <%= project_view[:events_count] %> events across <%= pluralize(project_view[:error_views].size, "error") %> in the last 7 days
                  </p>
                </div>
                <p class="text-xs text-slate-500 whitespace-nowrap"><%= time_ago_in_words(project_view[:latest_event].occurred_at) %> ago</p>
              </div>

              <div class="space-y-4">
                <% project_view[:error_views].each do |view| %>
                  <section class="rounded-lg border border-slate-200 bg-slate-50/70 p-3">
                    <div class="flex items-center justify-between gap-2 mb-2">
                      <h4 class="text-sm font-semibold text-slate-900 truncate"><%= view[:title] %></h4>
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold bg-white text-slate-700 border border-slate-200"><%= view[:stage].presence || "production" %></span>
                    </div>
                    <%= render "shared/widgets/sparkline", points: view[:trend] %>
                    <div class="mt-3 flex items-center justify-between gap-3 text-sm">
                      <strong class="text-slate-900"><%= view[:events_count] %> events</strong>
                      <span class="text-slate-500"><%= time_ago_in_words(view[:latest_event].occurred_at) %> ago</span>
                    </div>
                  </section>
                <% end %>
              </div>

              <div class="mt-4 pt-3 border-t border-slate-200 flex items-center justify-end">
                <%= link_to "View in inbox", project_path(project_view[:project]), class: "text-sm font-medium text-blue-600 hover:text-blue-700 no-underline" %>
              </div>
            </article>
          <% end %>
        <% else %>
          <article class="rounded-xl bg-white border border-slate-200 shadow-sm p-5 lg:col-span-2">
            <p class="text-slate-600">No errors captured in the last 7 days.</p>
          </article>
        <% end %>
      </div>
    </div>

    <aside class="space-y-4">
      <section class="rounded-xl border border-slate-200 bg-white shadow-sm overflow-hidden">
        <header class="px-4 py-3 border-b border-slate-200">
          <h2 class="text-lg font-semibold text-slate-900">Recent events</h2>
        </header>
        <% if @recent_events.any? %>
          <div class="max-h-[32rem] overflow-y-auto">
            <% @recent_events.each do |event| %>
              <div class="px-4 py-3 border-b border-slate-100 last:border-b-0">
                <%= link_to truncate(event.message.to_s.lines.first, length: 88), project_event_path(event.project, event), class: "block text-sm font-medium text-blue-700 hover:underline" %>
                <p class="text-xs text-slate-500 mt-1"><%= event.project.name %> · <%= time_ago_in_words(event.occurred_at) %> ago</p>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="p-4 text-sm text-slate-600">No events yet.</p>
        <% end %>
      </section>
    </aside>
  </section>
</div>
