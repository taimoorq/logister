<% tour_group = "dashboard" %>
<% dashboard_tab = params[:tab].presence_in(%w[overview projects]) || "overview" %>

<%= render layout: "shared/product_tour_frame", locals: { tour_group: tour_group, html_options: { class: "dashboard-page" } } do %>
  <section class="dashboard-title-row"
           <%= tag.attributes(data: product_tour_step_data(tour_group, :overview)) %>>
    <div class="dashboard-title-copy">
      <p class="dashboard-kicker">Overview</p>
      <h1>All apps</h1>
      <p>Monitor cross-app stability, open issues, and project health.</p>
    </div>

    <div class="dashboard-action-row">
      <%= tour_help_button %>
      <%= link_to projects_path, class: "projects-secondary-button" do %>
        <%= app_icon(:projects, css: "w-4 h-4") %>
        <span>All projects</span>
      <% end %>
      <%= link_to new_project_path, class: "projects-new-button" do %>
        <%= app_icon(:plus, css: "w-4 h-4") %>
        <span>New project</span>
      <% end %>
    </div>
  </section>

  <nav class="dashboard-tabs" role="tablist" aria-label="Dashboard sections">
    <%= link_to dashboard_path,
                class: "dashboard-tab #{"is-active" if dashboard_tab == "overview"}",
                role: "tab",
                aria: { selected: (dashboard_tab == "overview").to_s, controls: "dashboard-tab-overview", current: ("page" if dashboard_tab == "overview") },
                tabindex: (dashboard_tab == "overview" ? 0 : -1) do %>
      Overview
    <% end %>
    <%= link_to dashboard_path(tab: "projects"),
                class: "dashboard-tab #{"is-active" if dashboard_tab == "projects"}",
                role: "tab",
                aria: { selected: (dashboard_tab == "projects").to_s, controls: "dashboard-tab-projects", current: ("page" if dashboard_tab == "projects") },
                tabindex: (dashboard_tab == "projects" ? 0 : -1) do %>
      Projects
    <% end %>
  </nav>

  <% if dashboard_tab == "overview" %>
  <div id="dashboard-tab-overview" class="dashboard-overview-layout" role="tabpanel" aria-label="Overview">
  <section class="dashboard-priority-grid"
           data-controller="dashboard-attention"
           data-dashboard-attention-active-value="error"
           <%= tag.attributes(data: product_tour_step_data(tour_group, :attention_queue)) %>>
    <aside class="dashboard-assignment-panel" aria-label="Your assigned issues">
      <div class="dashboard-assignment-header">
        <div>
          <h3>My assignments</h3>
          <p>Open bugs across active apps</p>
        </div>
        <% if @assigned_error_groups.first %>
          <%= link_to "Open", inbox_project_path(@assigned_error_groups.first.project, group_uuid: @assigned_error_groups.first.uuid, assignee: "me"), class: "dashboard-panel-link" %>
        <% else %>
          <%= link_to "Projects", projects_path, class: "dashboard-panel-link" %>
        <% end %>
      </div>

      <div class="dashboard-assignment-summary">
        <span>
          <strong><%= number_with_delimiter(@assigned_error_groups_count) %></strong>
          <span>Assigned to me</span>
        </span>
        <span>
          <strong><%= number_with_delimiter(@unassigned_error_groups_count) %></strong>
          <span>Unassigned</span>
        </span>
      </div>

      <% if @assigned_error_groups.any? %>
        <div class="dashboard-assignment-list">
          <% @assigned_error_groups.each do |group| %>
            <%= link_to inbox_project_path(group.project, group_uuid: group.uuid, assignee: "me"), class: "dashboard-assignment-row" do %>
              <span class="dashboard-assignment-title"><%= group.title %></span>
              <span class="dashboard-assignment-meta">
                <%= group.project.name %> · <%= group.last_seen_at.present? ? "#{time_ago_in_words(group.last_seen_at)} ago" : "No events yet" %>
              </span>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="dashboard-assignment-empty">
          <strong>Nothing assigned to you</strong>
          <span><%= pluralize(@unassigned_error_groups_count, "open issue") %> still <%= @unassigned_error_groups_count == 1 ? "needs" : "need" %> an owner.</span>
        </div>
      <% end %>
    </aside>

    <article class="dashboard-panel dashboard-attention-panel">
      <div class="dashboard-panel-header">
        <div>
          <h2 data-dashboard-attention-target="title">Needs attention</h2>
          <p data-dashboard-attention-target="subtitle"><%= pluralize(@new_error_groups_last_24h, "new error group") %> first seen in the last 24 hours</p>
        </div>
        <%= link_to "Projects", projects_path, class: "dashboard-panel-link" %>
      </div>

      <div class="dashboard-attention-list">
        <% @recent_error_groups.each do |group| %>
          <% latest_event = @recent_error_group_latest_events[group.latest_event_id] %>
          <article class="dashboard-attention-row"
                   data-dashboard-attention-target="item"
                   data-event-type="error"
                   style="view-transition-name: <%= dom_id(group, :dashboard) %>; view-transition-class: dashboard-error-card;">
            <div class="dashboard-attention-main">
              <div class="dashboard-attention-title-row">
                <%= link_to group.title, inbox_project_path(group.project, group_uuid: group.uuid), class: "dashboard-attention-title" %>
                <span class="dashboard-attention-chip"><%= group.severity.presence || "error" %></span>
              </div>
              <span class="dashboard-attention-meta"><%= group.project.name %> · <%= group.subtitle.presence || group.stage %> · <%= group.stage %></span>
              <p class="dashboard-attention-latest">
                <span>Latest</span>
                <%= latest_event&.message.to_s.lines.first.to_s.strip.presence || "No event detail captured yet" %>
              </p>
            </div>

            <div class="dashboard-attention-side">
              <div class="dashboard-attention-stats">
                <span>
                  <strong><%= number_with_delimiter(group.occurrence_count) %></strong>
                  <span>Events</span>
                </span>
                <span>
                  <strong><%= group.last_seen_at.present? ? "#{time_ago_in_words(group.last_seen_at)} ago" : "--" %></strong>
                  <span>Last seen</span>
                </span>
                <span>
                  <strong><%= group.first_seen_at.present? ? "#{time_ago_in_words(group.first_seen_at)} ago" : "--" %></strong>
                  <span>First seen</span>
                </span>
              </div>
              <div class="dashboard-attention-actions">
                <%= link_to "Open issue", inbox_project_path(group.project, group_uuid: group.uuid), class: "dashboard-attention-action" %>
                <% if latest_event.present? %>
                  <%= link_to "Latest event", partitioned_project_event_path(group.project, latest_event), class: "dashboard-attention-action" %>
                <% end %>
                <%= link_to "Events", activity_project_path(group.project), class: "dashboard-attention-action" %>
              </div>
            </div>
          </article>
        <% end %>

        <% @recent_context_events.each do |event| %>
          <article class="dashboard-attention-row dashboard-attention-row-context"
                   data-dashboard-attention-target="item"
                   data-event-type="<%= event.event_type %>"
                   style="view-transition-name: <%= dom_id(event, :dashboard) %>; view-transition-class: dashboard-error-card;">
            <div class="dashboard-attention-main">
              <div class="dashboard-attention-title-row">
                <%= link_to event.message.to_s.lines.first.to_s.strip.presence || "(untitled event)", partitioned_project_event_path(event.project, event), class: "dashboard-attention-title" %>
                <span class="<%= dashboard_event_badge_class(event.event_type) %>"><%= dashboard_event_type_label(event.event_type) %></span>
              </div>
              <span class="dashboard-attention-meta"><%= event.project.name %> · <%= event.level.presence || event.event_type %></span>
              <p class="dashboard-attention-latest">
                <span>Context</span>
                <%= event.context.is_a?(Hash) && event.context["name"].present? ? event.context["name"] : event.fingerprint.presence || "Recent #{dashboard_event_type_label(event.event_type).downcase.singularize}" %>
              </p>
            </div>

            <div class="dashboard-attention-side">
              <div class="dashboard-attention-stats dashboard-attention-stats-compact">
                <span>
                  <strong><%= event.occurred_at.present? ? "#{time_ago_in_words(event.occurred_at)} ago" : "--" %></strong>
                  <span>Occurred</span>
                </span>
                <span>
                  <strong><%= event.project.integration_label %></strong>
                  <span>App type</span>
                </span>
              </div>
              <div class="dashboard-attention-actions">
                <%= link_to "Open event", partitioned_project_event_path(event.project, event), class: "dashboard-attention-action" %>
                <%= link_to "Project", project_path(event.project), class: "dashboard-attention-action" %>
              </div>
            </div>
          </article>
        <% end %>

        <div class="dashboard-empty-state dashboard-attention-empty" data-dashboard-attention-target="empty" <%= "hidden" if @recent_error_groups.any? %>>
          <strong>No matching items</strong>
          <span>This event type has no recent rows in the dashboard window.</span>
        </div>
      </div>
    </article>

  </section>

  <section class="dashboard-explorer"
           data-controller="dashboard-explorer"
           data-dashboard-explorer-payload-value="<%= @dashboard_explorer.to_json %>"
           <%= tag.attributes(data: product_tour_step_data(tour_group, :explorer)) %>
           aria-label="Cross-app event explorer">
    <div class="dashboard-explorer-header">
      <div>
        <p class="dashboard-kicker">Explorer</p>
        <h2>Overall Event flow</h2>
        <p>Last <%= @dashboard_explorer[:window_days] %> days across accessible apps</p>
      </div>
    </div>

    <div class="dashboard-explorer-workbench">
      <aside class="dashboard-explorer-slice" aria-label="Current explorer slice">
        <div class="dashboard-explorer-slice-header">
          <div>
            <p class="dashboard-kicker">Current slice</p>
            <h3>Selection totals</h3>
          </div>
          <button type="button" class="dashboard-explorer-reset" data-dashboard-explorer-target="resetButton" data-action="dashboard-explorer#resetFilters">Reset</button>
        </div>

        <div class="dashboard-explorer-summary" data-dashboard-explorer-target="summary"></div>

        <div class="dashboard-explorer-actions">
          <%= link_to dashboard_events_path,
                      class: "dashboard-explorer-open",
                      data: { dashboard_explorer_target: "openEventsLink" } do %>
            Open matching events
          <% end %>
          <%= link_to "#",
                      class: "dashboard-explorer-project",
                      hidden: true,
                      data: { dashboard_explorer_target: "openProjectLink" } do %>
            Open project
          <% end %>
        </div>

        <div class="dashboard-explorer-filter-panel">
          <div class="dashboard-explorer-filter-heading">
            <span>Filters</span>
          </div>
          <div class="dashboard-explorer-filters" data-dashboard-explorer-target="filters"></div>
        </div>
      </aside>

      <div class="dashboard-explorer-main">
        <div class="dashboard-explorer-layout">
          <article class="dashboard-explorer-card dashboard-explorer-card-wide">
            <div class="dashboard-explorer-card-header">
              <h3>Daily volume</h3>
              <span>By event type</span>
            </div>
            <div class="dashboard-explorer-chart dashboard-explorer-chart-tall" data-dashboard-explorer-target="timelineChart" role="img" aria-label="Daily event volume by type"></div>
          </article>

          <article class="dashboard-explorer-card">
            <div class="dashboard-explorer-card-header">
              <h3>Event types</h3>
              <span>Current slice</span>
            </div>
            <div class="dashboard-explorer-chart" data-dashboard-explorer-target="eventTypeChart" role="img" aria-label="Events grouped by type"></div>
          </article>

          <article class="dashboard-explorer-card">
            <div class="dashboard-explorer-card-header">
              <h3>Apps by volume</h3>
              <span>Top active apps</span>
            </div>
            <div class="dashboard-explorer-chart" data-dashboard-explorer-target="projectChart" role="img" aria-label="Top apps by event volume"></div>
          </article>

        </div>
      </div>
    </div>
  </section>

  </div>
  <% else %>
  <div id="dashboard-tab-projects" class="dashboard-tab-panel" role="tabpanel" aria-label="Projects">

  <section class="dashboard-project-overview-grid"
           aria-label="Project overview"
           <%= tag.attributes(data: product_tour_step_data(tour_group, :project_signals)) %>>
    <article class="dashboard-panel dashboard-project-overview-main">
      <div class="dashboard-panel-header">
        <div>
          <h2>Projects at a glance</h2>
          <p>Compact shortcuts into the apps that need the next look</p>
        </div>
        <%= link_to "View all", projects_path, class: "dashboard-panel-link" %>
      </div>

      <% if @project_summaries.any? %>
        <div class="dashboard-project-list">
          <% @project_summaries.each do |project| %>
            <% stats = @project_stats[project.id] || { open_groups: 0, activity_events: 0, latest_event_at: nil } %>
            <div class="dashboard-project-row" data-project-name="<%= project.name.downcase %>" data-project-slug="<%= project.slug.downcase %>">
              <%= link_to project_path(project), class: "dashboard-project-main" do %>
                <%= project_integration_icon(project) %>
                <span>
                  <strong><%= project.name %></strong>
                  <span><%= project.integration_label %> · <%= project.owned_by?(current_user) ? "Owner" : "Shared" %></span>
                </span>
              <% end %>
              <div class="dashboard-project-stats">
                <%= link_to inbox_project_path(project, filter: "unresolved") do %>
                  <strong><%= stats.fetch(:open_groups, 0).to_i %></strong>
                  <span>Open errors</span>
                <% end %>
                <%= link_to activity_project_path(project) do %>
                  <strong><%= stats.fetch(:activity_events, 0).to_i %></strong>
                  <span>Events</span>
                <% end %>
                <span>
                  <strong><%= stats[:latest_event_at].present? ? "#{time_ago_in_words(stats[:latest_event_at])} ago" : "--" %></strong>
                  <span>Latest event</span>
                </span>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="dashboard-empty-state">
          <strong>No projects yet</strong>
          <span>Create a project to start ingesting app events.</span>
          <div class="project-card-empty-actions mt-4">
            <%= link_to "Create project", new_project_path, class: "btn-primary" %>
            <%= link_to "Browse docs", docs_site_url, target: "_blank", rel: "noopener noreferrer", class: "btn-ghost" %>
          </div>
        </div>
      <% end %>
    </article>

    <aside class="dashboard-panel dashboard-project-summary-panel" aria-label="Project status counts">
      <div class="dashboard-panel-header">
        <div>
          <h2>Project signals</h2>
          <p>Counts tied to the project list</p>
        </div>
      </div>

      <div class="dashboard-title-metrics" aria-label="Overview signals">
        <span>
          <strong><%= @active_projects_count %></strong>
          <span>Active apps</span>
        </span>
        <span>
          <strong><%= @new_error_groups_last_24h %></strong>
          <span>New issues</span>
        </span>
        <span>
          <strong><%= @monitor_status_counts.fetch(:ok, 0) %></strong>
          <span>Healthy monitors</span>
        </span>
        <span>
          <strong><%= @api_keys_count %></strong>
          <span>API keys</span>
        </span>
      </div>

      <div class="dashboard-metric-grid" aria-label="Account-wide project status">
        <%= link_to projects_path, class: "dashboard-metric-card dashboard-metric-link" do %>
          <span class="dashboard-metric-icon"><%= app_icon(:projects, css: "w-5 h-5") %></span>
          <span class="dashboard-metric-label">Apps watched</span>
          <strong><%= @projects_count %></strong>
          <span><%= pluralize(@quiet_projects_count, "quiet app") %></span>
        <% end %>

        <article class="dashboard-metric-card">
          <span class="dashboard-metric-icon"><%= app_icon(:chart, css: "w-5 h-5") %></span>
          <span class="dashboard-metric-label">Events today</span>
          <strong><%= number_with_delimiter(@events_last_24h) %></strong>
          <span><%= pluralize(@events_by_type_last_24h.fetch("error", 0), "error event") %></span>
        </article>

        <%= link_to(@recent_error_groups.first ? inbox_project_path(@recent_error_groups.first.project, group_uuid: @recent_error_groups.first.uuid) : projects_path,
                    class: "dashboard-metric-card dashboard-metric-link #{dashboard_metric_state_class(@open_error_groups_count)}") do %>
          <span class="dashboard-metric-icon"><%= app_icon(:warning, css: "w-5 h-5") %></span>
          <span class="dashboard-metric-label">Errors for review</span>
          <strong><%= @open_error_groups_count %></strong>
          <span><%= pluralize(@projects_with_open_errors_count, "affected app") %></span>
        <% end %>

        <article class="dashboard-metric-card <%= dashboard_metric_state_class(@unhealthy_monitors_count) %>">
          <span class="dashboard-metric-icon"><%= app_icon(:check, css: "w-5 h-5") %></span>
          <span class="dashboard-metric-label">Monitor issues</span>
          <strong><%= @unhealthy_monitors_count %></strong>
          <span><%= pluralize(@monitors_count, "monitor") %> tracked</span>
        </article>
      </div>
    </aside>
  </section>
  </div>
  <% end %>
<% end %>
