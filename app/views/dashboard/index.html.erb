<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-bold text-slate-900">Overview</h1>
    <p class="text-slate-600 text-sm mt-1">Track cross-project reliability, triage trends, and newly introduced issues.</p>
  </div>
  <%= link_to "Create project", new_project_path, class: "inline-flex items-center px-4 py-2.5 rounded-lg text-sm font-medium bg-blue-600 text-white hover:bg-blue-700 no-underline shrink-0" %>
</div>

<section class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
  <article class="rounded-xl bg-white border border-slate-200 shadow-sm p-5">
    <p class="text-xs font-semibold uppercase tracking-wider text-slate-500 mb-1">Projects</p>
    <p class="text-2xl sm:text-3xl font-bold text-slate-900"><%= @projects_count %></p>
  </article>
  <article class="rounded-xl bg-white border border-slate-200 shadow-sm p-5">
    <p class="text-xs font-semibold uppercase tracking-wider text-slate-500 mb-1">Active API keys</p>
    <p class="text-2xl sm:text-3xl font-bold text-slate-900"><%= @api_keys_count %></p>
  </article>
  <article class="rounded-xl bg-white border border-slate-200 shadow-sm p-5">
    <p class="text-xs font-semibold uppercase tracking-wider text-slate-500 mb-1">Events (24h)</p>
    <p class="text-2xl sm:text-3xl font-bold text-slate-900"><%= @events_last_24h %></p>
  </article>
</section>

<div class="flex items-center justify-between gap-4 mb-4">
  <h2 class="text-lg font-bold text-slate-900">Error views</h2>
  <%= link_to "Open all projects", projects_path, class: "text-sm font-medium text-blue-600 hover:text-blue-700 no-underline" %>
</div>

<section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
  <% if @error_views.any? %>
    <% @error_views.each_with_index do |view, idx| %>
      <article class="rounded-xl bg-white border border-slate-200 shadow-sm p-5 overflow-hidden" style="view-transition-name: dashboard-error-view-<%= view[:project].id %>-<%= idx %>; view-transition-class: dashboard-error-card;">
        <div class="min-w-0 mb-2">
          <h3 class="text-base font-bold text-slate-900 truncate"><%= view[:title] %></h3>
        </div>
        <div class="flex items-start justify-between gap-2 mb-3">
          <p class="text-sm text-slate-500 shrink-0"><%= view[:project].name %> · last 7 days</p>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-slate-100 text-slate-700 border border-slate-200"><%= view[:stage].presence || "production" %></span>
        </div>

        <%= render "shared/widgets/sparkline", points: view[:trend] %>

        <div class="flex items-center justify-between gap-2 mt-4 pt-3 border-t border-slate-200">
          <strong class="text-sm text-slate-900"><%= view[:events_count] %> events</strong>
          <%= link_to "View in inbox", project_path(view[:project]), class: "text-sm font-medium text-blue-600 hover:text-blue-700 no-underline" %>
        </div>
      </article>
    <% end %>
  <% else %>
    <article class="rounded-xl bg-white border border-slate-200 shadow-sm p-5 sm:col-span-2 lg:col-span-3">
      <p class="text-slate-600">No errors captured in the last 7 days.</p>
    </article>
  <% end %>
</section>

<section class="rounded-xl bg-white border border-slate-200 shadow-sm overflow-hidden">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 p-5 border-b border-slate-200">
    <h2 class="text-lg font-bold text-slate-900">Recent events</h2>
    <%= link_to "View projects", projects_path, class: "text-sm font-medium text-blue-600 hover:text-blue-700 no-underline" %>
  </div>

  <% if @recent_events.any? %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Error</th>
            <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Project</th>
            <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">When</th>
            <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Severity</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200 bg-white">
          <% @recent_events.each do |event| %>
            <tr class="hover:bg-slate-50">
              <td class="px-4 py-3 text-sm text-slate-900">
                <%= link_to truncate(event.message.to_s.lines.first, length: 96), project_event_path(event.project, event), class: "text-blue-600 hover:underline" %>
              </td>
              <td class="px-4 py-3 text-sm text-slate-600"><%= event.project.name %></td>
              <td class="px-4 py-3 text-sm text-slate-600"><%= local_time_tag(event.occurred_at) %></td>
              <td class="px-4 py-3"><%= render "shared/widgets/severity_badge", level: event.level.presence || "error" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="p-5 text-slate-600 text-sm">No events yet. Create a project, then an API key, and start sending data from your gem.</p>
  <% end %>
</section>
