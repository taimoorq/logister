<section class="max-w-md mx-auto">
  <div class="rounded-xl bg-white border border-slate-200 shadow-sm p-6 sm:p-8">
    <h1 class="text-2xl font-bold text-slate-900 mb-2">Forgot your password?</h1>
    <p class="text-slate-600 text-sm mb-6">Enter your email and we’ll send you reset instructions.</p>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <div class="space-y-4">
        <div>
          <%= f.label :email, class: "form-label" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", required: true, class: "form-input" %>
        </div>

        <div>
          <%= render "devise/shared/turnstile" %>
        </div>

        <div class="pt-2">
          <%= f.submit "Send reset instructions", class: "btn-primary w-full sm:w-auto" %>
        </div>
      </div>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</section>
