<% content_for :title, "Choose New Password" %>
<% content_for :meta_description, "Choose a new Logister password after using a secure reset link." %>
<% content_for :canonical_path, new_user_password_path %>
<% content_for :meta_robots, "noindex, follow" %>

<%= render "devise/shared/auth_shell",
           title: "Choose a new password",
           subtitle: "Set a fresh password and return to your Logister workspace." do %>
  <h2 class="auth-form-title">Reset password</h2>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, data: { turbo: false } }) do |f| %>
    <%= f.hidden_field :reset_password_token %>

    <div class="space-y-4">
      <div>
        <%= f.label :password, "New password", class: "form-label" %>
        <% if resource_class.respond_to?(:password_length) && resource_class.password_length.min.present? %>
          <span class="text-slate-500 text-sm">(<%= resource_class.password_length.min %> characters minimum)</span>
        <% end %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password", required: true, class: "form-input mt-1" %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirm new password", class: "form-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", required: true, class: "form-input" %>
      </div>

      <% if resource.errors.any? %>
        <div class="rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">
          <%= resource.errors.full_messages.to_sentence %>
        </div>
      <% end %>

      <div class="pt-2">
        <%= f.submit "Update password", class: "btn-primary w-full" %>
      </div>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
<% end %>
