<%= render "devise/shared/auth_shell",
           title: "Confirm your account",
           subtitle: "Need a fresh confirmation email? We can resend it instantly." do %>
  <h2 class="auth-form-title">Resend confirmation</h2>

  <%= form_for(resource, as: resource_name, url: confirmation_path(resource_name), html: { method: :post, data: { turbo: false } }) do |f| %>
    <div class="space-y-4">
      <div>
        <%= f.label :email, class: "form-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", required: true, class: "form-input" %>
      </div>

      <div>
        <%= render "devise/shared/turnstile" %>
      </div>

      <div class="pt-2">
        <%= f.submit "Resend confirmation", class: "btn-primary w-full" %>
      </div>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
<% end %>
