<% assignment_summary ||= ProjectAssignmentSummary.new(project) %>
<% member = membership.user %>

<tr id="<%= dom_id(membership) %>">
  <td class="px-3 py-2 text-sm text-slate-900"><%= member.email %></td>
  <td class="px-3 py-2 text-sm text-slate-600">
    <%= form_with model: [ project, membership ], class: "min-w-32" do |f| %>
      <%= f.select :role,
                   options_for_select(ProjectMembership.role_options, membership.role),
                   {},
                   class: "form-input text-sm",
                   onchange: "this.form.requestSubmit()" %>
    <% end %>
  </td>
  <td class="px-3 py-2 text-sm text-slate-600">
    <%= link_to inbox_project_path(project, filter: "unresolved", assignee: member.uuid), class: "font-semibold text-blue-600 no-underline hover:text-blue-700" do %>
      <%= number_with_delimiter(assignment_summary.open_count_for(member)) %>
    <% end %>
  </td>
  <td class="px-3 py-2">
    <%= button_to "Remove",
                  project_project_membership_path(project, membership),
                  method: :delete,
                  class: "text-sm font-medium text-red-600 hover:text-red-700",
                  form: { data: { turbo_confirm: "Remove this member's access?", turbo_stream: true } } %>
  </td>
</tr>
