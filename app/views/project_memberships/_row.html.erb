<tr id="<%= dom_id(membership) %>">
  <td class="px-3 py-2 text-sm text-slate-900"><%= membership.user.email %></td>
  <td class="px-3 py-2 text-sm text-slate-600"><%= membership.role %></td>
  <td class="px-3 py-2">
    <%= button_to "Remove",
                  project_project_membership_path(project, membership),
                  method: :delete,
                  class: "text-sm font-medium text-red-600 hover:text-red-700",
                  form: { data: { turbo_confirm: "Remove this member's access?", turbo_stream: true } } %>
  </td>
</tr>
