<h1 style="margin:0 0 12px; font-size:24px; line-height:1.25; color:#0f172a;"><%= @notification_label %> for <%= @project.name %></h1>

<p style="margin:0 0 18px; color:#475569; font-size:15px; line-height:1.6;">
  Logister noticed a project-level condition that matches your email notification settings.
</p>

<div style="border:1px solid #e2e8f0; border-radius:8px; padding:16px; margin:0 0 18px; background:#f8fafc;">
  <p style="margin:0 0 8px; font-size:12px; letter-spacing:.04em; text-transform:uppercase; color:#64748b; font-weight:700;">Details</p>
  <% if @metadata.any? %>
    <table role="presentation" style="width:100%; border-collapse:collapse;">
      <% @metadata.each do |key, value| %>
        <tr>
          <td style="padding:6px 0; color:#64748b; font-size:13px;"><%= key.to_s.humanize %></td>
          <td style="padding:6px 0; color:#0f172a; font-size:13px; text-align:right;"><%= value %></td>
        </tr>
      <% end %>
    </table>
  <% else %>
    <p style="margin:0; color:#475569; font-size:14px;">Open the project to review details.</p>
  <% end %>
</div>

<p style="margin:0 0 22px;">
  <a href="<%= @project_url %>" style="display:inline-block; background:#2563eb; color:#ffffff; text-decoration:none; border-radius:8px; padding:11px 16px; font-weight:700; font-size:14px;">Open project in Logister</a>
</p>

<p style="margin:0; color:#64748b; font-size:12px; line-height:1.5;">
  You received this because <%= @notification_label.downcase %> emails are enabled for <%= @project.name %>.
  <a href="<%= @settings_url %>" style="color:#2563eb;">Manage project email settings</a>.
</p>
