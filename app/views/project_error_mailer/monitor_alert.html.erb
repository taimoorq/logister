<h1 style="margin:0 0 12px; font-size:24px; line-height:1.25; color:#0f172a;"><%= @notification_label %> in <%= @project.name %></h1>

<p style="margin:0 0 18px; color:#475569; font-size:15px; line-height:1.6;">
  Logister detected a check-in monitor status change.
</p>

<div style="border:1px solid #e2e8f0; border-radius:8px; padding:16px; margin:0 0 18px; background:#f8fafc;">
  <p style="margin:0 0 8px; font-size:12px; letter-spacing:.04em; text-transform:uppercase; color:#64748b; font-weight:700;">Monitor</p>
  <p style="margin:0 0 6px; font-size:18px; line-height:1.35; color:#0f172a; font-weight:700;"><%= @metadata["monitor_slug"].presence || @monitor&.slug || "Monitor" %></p>
  <p style="margin:0; color:#475569; font-size:14px;"><%= @metadata["environment"].presence || @monitor&.environment || "production" %></p>
</div>

<table role="presentation" style="width:100%; border-collapse:collapse; margin:0 0 20px;">
  <tr>
    <td style="padding:8px 0; color:#64748b; font-size:13px;">Status</td>
    <td style="padding:8px 0; color:#0f172a; font-size:13px; text-align:right;"><%= @metadata["status"] || @monitor&.status %></td>
  </tr>
  <% if @monitor&.last_check_in_at.present? %>
    <tr>
      <td style="padding:8px 0; color:#64748b; font-size:13px;">Last check-in</td>
      <td style="padding:8px 0; color:#0f172a; font-size:13px; text-align:right;"><%= l(@monitor.last_check_in_at, format: :long) %></td>
    </tr>
  <% end %>
  <% if @monitor&.expected_interval_seconds.present? %>
    <tr>
      <td style="padding:8px 0; color:#64748b; font-size:13px;">Expected interval</td>
      <td style="padding:8px 0; color:#0f172a; font-size:13px; text-align:right;"><%= distance_of_time_in_words(Time.current, Time.current + @monitor.expected_interval_seconds.seconds) %></td>
    </tr>
  <% end %>
</table>

<p style="margin:0 0 22px;">
  <a href="<%= @monitor_url %>" style="display:inline-block; background:#2563eb; color:#ffffff; text-decoration:none; border-radius:8px; padding:11px 16px; font-weight:700; font-size:14px;">Open monitors in Logister</a>
</p>

<p style="margin:0; color:#64748b; font-size:12px; line-height:1.5;">
  You received this because monitor emails are enabled for <%= @project.name %>.
  <a href="<%= @settings_url %>" style="color:#2563eb;">Manage project email settings</a>.
</p>
