<% if cookie_consent_enabled? %>
  <script
    src="<%= probo_cookie_banner_script_url %>"
    data-banner-id="<%= probo_cookie_banner_id %>"
    data-base-url="<%= probo_cookie_banner_base_url %>"
    data-position="<%= probo_cookie_banner_position %>"
  ></script>

  <% if analytics_enabled? && google_tag_id.present? %>
    <!-- Google Analytics -->
    <!-- Google tag (gtag.js) -->
    <script type="text/plain" data-cookie-consent="<%= analytics_cookie_consent_category %>" async src="https://www.googletagmanager.com/gtag/js?id=<%= google_tag_id %>"></script>
    <script type="text/plain" data-cookie-consent="<%= analytics_cookie_consent_category %>">
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', '<%= google_tag_id %>');
    </script>
    <!-- end of Google Analytics-->
  <% end %>

  <% if analytics_enabled? && cloudflare_web_analytics_token.present? %>
    <!-- Cloudflare Web Analytics -->
    <script type="text/plain" data-cookie-consent="<%= analytics_cookie_consent_category %>" defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='<%= { token: cloudflare_web_analytics_token }.to_json %>'></script>
    <!-- End Cloudflare Web Analytics -->
  <% end %>
<% end %>
