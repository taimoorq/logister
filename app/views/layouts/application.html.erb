<!DOCTYPE html>
<html>
  <head>
    <title><%= seo_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Logister">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="<%= seo_description %>">
    <meta name="robots" content="<%= seo_robots %>">
    <link rel="canonical" href="<%= seo_canonical_url %>">
    <meta property="og:site_name" content="Logister">
    <meta property="og:title" content="<%= seo_title %>">
    <meta property="og:description" content="<%= seo_description %>">
    <meta property="og:type" content="<%= seo_og_type %>">
    <meta property="og:url" content="<%= seo_canonical_url %>">
    <meta property="og:image" content="<%= seo_og_image %>">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= seo_title %>">
    <meta name="twitter:description" content="<%= seo_description %>">
    <meta name="twitter:image" content="<%= seo_og_image %>">
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <script type="text/javascript" charset="UTF-8" src="//cdn.cookie-script.com/s/508b202c755ae8c25a504f130bcbfc3f.js"></script>

    <%= yield :head %>
    <% if seo_json_ld.present? %>
      <script type="application/ld+json"><%= raw seo_json_ld %></script>
    <% end %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="global-nav">
      <div class="global-nav-inner">
        <%= link_to root_path, class: "brand" do %>
          <%= image_tag "logister-logo.svg", alt: "logister.org", class: "brand-logo" %>
          <span class="brand-text">Logister</span>
        <% end %>

        <nav class="global-links">
          <% if user_signed_in? %>
            <%= link_to "Overview", dashboard_path, class: "global-link #{"is-active" if current_page?(dashboard_path)}" %>
            <%= link_to "Projects", projects_path, class: "global-link #{"is-active" if current_page?(projects_path)}" %>
            <%= link_to "Account", profile_path, class: "global-link #{"is-active" if current_page?(profile_path)}" %>
            <% if admin_user? %>
              <%= link_to "Admin", admin_users_path, class: "global-link #{"is-active" if request.path.start_with?("/admin")}" %>
            <% end %>
          <% else %>
            <%= link_to "Home", root_path, class: "global-link #{"is-active" if current_page?(root_path)}" %>
            <%= link_to "About", about_path, class: "global-link #{"is-active" if current_page?(about_path)}" %>
            <%= link_to "Privacy", privacy_path, class: "global-link #{"is-active" if current_page?(privacy_path)}" %>
            <%= link_to "Terms", terms_path, class: "global-link #{"is-active" if current_page?(terms_path)}" %>
            <%= link_to "Sign in", new_user_session_path, class: "global-link", data: { turbo: false } %>
            <%= link_to "Sign up", new_user_registration_path, class: "global-link", data: { turbo: false } %>
          <% end %>
        </nav>

        <div class="global-actions">
          <% if user_signed_in? %>
            <p class="global-user"><%= current_user.email %></p>
            <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "ghost-button" %>
          <% end %>
        </div>
      </div>
    </header>

    <main class="workspace">
      <div class="content-shell">
        <% if notice %>
          <p class="flash notice"><%= notice %></p>
        <% end %>
        <% if alert %>
          <p class="flash alert"><%= alert %></p>
        <% end %>

        <%= yield %>
      </div>
    </main>
  </body>
</html>
