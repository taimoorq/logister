<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= seo_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Logister">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="<%= seo_description %>">
    <meta name="robots" content="<%= seo_robots %>">
    <link rel="canonical" href="<%= seo_canonical_url %>">
    <meta property="og:site_name" content="Logister">
    <meta property="og:title" content="<%= seo_title %>">
    <meta property="og:description" content="<%= seo_description %>">
    <meta property="og:type" content="<%= seo_og_type %>">
    <meta property="og:url" content="<%= seo_canonical_url %>">
    <meta property="og:image" content="<%= seo_og_image %>">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= seo_title %>">
    <meta name="twitter:description" content="<%= seo_description %>">
    <meta name="twitter:image" content="<%= seo_og_image %>">
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <% cookie_consent_enabled = ActiveModel::Type::Boolean.new.cast(ENV.fetch("LOGISTER_COOKIE_CONSENT_ENABLED", "true")) %>
    <% analytics_enabled = Rails.env.production? || ActiveModel::Type::Boolean.new.cast(ENV.fetch("LOGISTER_ANALYTICS_ENABLED", "false")) %>
    <% cookie_consent_script_url = ENV.fetch("COOKIECONSENT_SCRIPT_URL", "https://www.termsfeed.com/public/cookie-consent/4.2.0/cookie-consent.js") %>
    <% cookie_consent_website_name = ENV["COOKIECONSENT_WEBSITE_NAME"].to_s.strip.presence || "Logister" %>
    <% cookie_consent_privacy_url = ENV["COOKIECONSENT_PRIVACY_POLICY_URL"].to_s.strip.presence || absolute_url_for(privacy_path) %>
    <% google_tag_id = ENV["GOOGLE_TAG_ID"].to_s.strip.presence %>
    <% cloudflare_web_analytics_token = ENV["CLOUDFLARE_WEB_ANALYTICS_TOKEN"].to_s.strip.presence %>
    <% if google_tag_id.present? %>
      <meta name="logister-google-tag-id" content="<%= google_tag_id %>">
    <% end %>
    <%# Turbo 8: view transitions (crossfade/slide on navigation and morph). Ignored on Turbo 7. %>
    <meta name="turbo-view-transition" content="true">
    <%# Turbo 8: morphing refresh + preserve scroll when redirecting back to same page. Ignored on Turbo 7. %>
    <meta name="turbo-refresh-method" content="morph">
    <meta name="turbo-refresh-scroll" content="preserve">

    <%= yield :head %>
    <%= content_tag(:script, seo_json_ld, type: "application/ld+json") if seo_json_ld.present? %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">

    <%= app_stylesheet_tags %>
    <%= app_javascript_tags %>
  </head>

  <body class="<%= user_signed_in? ? 'min-h-screen flex flex-col bg-slate-100 text-slate-900 antialiased' : 'min-h-screen flex flex-col bg-slate-50 text-slate-800 antialiased' %>" data-controller="local-time">
    <nav class="<%= user_signed_in? ? 'bg-[#09195d] border-b border-[#31458f] sticky top-0 z-20' : 'bg-white border-b border-slate-200 shadow-sm sticky top-0 z-10' %>" data-controller="nav">
      <div class="<%= user_signed_in? ? 'w-full px-4 sm:px-6 lg:px-8' : 'max-w-7xl mx-auto px-4 sm:px-6 lg:px-8' %>">
        <div class="flex justify-between items-center h-14 min-h-[3.5rem]">
          <div class="flex items-center gap-3 min-w-0">
            <%= link_to(user_signed_in? ? dashboard_path : root_path, class: "flex items-center gap-2 no-underline font-semibold shrink-0 #{user_signed_in? ? 'text-white hover:text-blue-100' : 'text-slate-800 hover:text-slate-600'}") do %>
              <%= image_tag "logister-logo.svg", alt: "Logister", class: "h-6 w-auto #{'brightness-0 invert' if user_signed_in?}", width: 232, height: 48 %>
            <% end %>
            <% if user_signed_in? %>
              <div class="hidden md:block h-5 w-px bg-blue-300/40"></div>
              <p class="hidden md:block text-sm text-blue-100 truncate max-w-[16rem]"><%= defined?(@project) && @project.present? ? @project.name : "Stability center" %></p>
            <% end %>
          </div>

          <button type="button"
                  class="<%= user_signed_in? ? 'md:hidden flex items-center justify-center w-11 h-11 -mr-2 rounded-lg text-blue-100 hover:bg-blue-900/60 hover:text-white focus:outline-none focus:ring-2 focus:ring-blue-300 focus:ring-offset-2 focus:ring-offset-[#09195d]' : 'md:hidden flex items-center justify-center w-11 h-11 -mr-2 rounded-lg text-slate-600 hover:bg-slate-100 hover:text-slate-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2' %>"
                  data-nav-target="toggle"
                  data-action="click->nav#toggle"
                  aria-expanded="false"
                  aria-controls="nav-menu-panel"
                  aria-label="Toggle menu">
            <svg class="w-6 h-6" data-nav-target="iconOpen" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
            <svg class="w-6 h-6 hidden" data-nav-target="iconClose" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>

          <div id="nav-menu-panel"
               class="<%= user_signed_in? ? 'hidden md:flex flex-col md:flex-row md:items-center gap-0 md:gap-1 absolute md:relative top-full left-0 right-0 md:top-0 bg-[#09195d] md:bg-transparent border-b border-[#31458f] md:border-0 shadow-lg md:shadow-none py-3 md:py-0 px-4 md:px-0' : 'hidden md:flex flex-col md:flex-row md:items-center gap-0 md:gap-1 lg:gap-2 absolute md:relative top-full left-0 right-0 md:top-0 bg-white md:bg-transparent border-b md:border-b-0 border-slate-200 md:border-0 shadow-lg md:shadow-none py-3 md:py-0 px-4 md:px-0' %>"
               data-nav-target="panel">
            <% if user_signed_in? %>
              <%= link_to dashboard_path, class: "nav-link inline-flex items-center gap-2 py-2 px-3 rounded-md text-sm font-medium #{current_page?(dashboard_path) ? 'bg-blue-800/70 text-white' : 'text-blue-100 hover:bg-blue-900/60 hover:text-white'}" do %>
                <%= app_icon(:dashboard, css: "w-4 h-4") %>
                <span>Overview</span>
              <% end %>
              <%= link_to projects_path, class: "nav-link inline-flex items-center gap-2 py-2 px-3 rounded-md text-sm font-medium #{current_page?(projects_path) ? 'bg-blue-800/70 text-white' : 'text-blue-100 hover:bg-blue-900/60 hover:text-white'}" do %>
                <%= app_icon(:projects, css: "w-4 h-4") %>
                <span>Projects</span>
              <% end %>
              <%= link_to docs_site_url, target: "_blank", rel: "noopener noreferrer", class: "nav-link inline-flex items-center gap-2 py-2 px-3 rounded-md text-sm font-medium text-blue-100 hover:bg-blue-900/60 hover:text-white" do %>
                <%= app_icon(:all, css: "w-4 h-4") %>
                <span>Docs</span>
              <% end %>

              <div class="mt-2 md:mt-0 pt-3 md:pt-0 border-t md:border-t-0 border-[#31458f] md:border-l md:border-[#31458f] md:pl-3">
                <details class="relative">
                  <summary class="list-none flex items-center justify-between gap-2 py-2 px-3 rounded-md text-sm font-medium text-blue-100 hover:bg-blue-900/60 hover:text-white cursor-pointer select-none min-h-[44px] md:min-h-0">
                    <span class="truncate max-w-[220px] text-left"><%= current_user.email %></span>
                    <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                    </svg>
                  </summary>
                  <div class="md:absolute md:right-0 mt-1 md:mt-2 w-full md:w-56 rounded-lg border border-slate-200 bg-white shadow-sm overflow-hidden z-10">
                    <%= link_to profile_path, class: "nav-link block px-3 py-2.5 text-sm font-medium #{current_page?(profile_path) ? 'bg-blue-50 text-blue-700' : 'text-slate-700 hover:bg-slate-50'}" do %>
                      <span class="inline-flex items-center gap-2"><%= app_icon(:account, css: "w-4 h-4") %><span>Account</span></span>
                    <% end %>
                    <% if admin_user? %>
                      <%= link_to admin_users_path, class: "nav-link block px-3 py-2.5 text-sm font-medium #{request.path.start_with?('/admin') ? 'bg-blue-50 text-blue-700' : 'text-slate-700 hover:bg-slate-50'}" do %>
                        <span class="inline-flex items-center gap-2"><%= app_icon(:shield, css: "w-4 h-4") %><span>Admin</span></span>
                      <% end %>
                    <% end %>
                    <div class="border-t border-slate-200 p-2">
                      <%= button_to destroy_user_session_path, method: :delete, class: "nav-link w-full text-left px-3 py-2 rounded-lg text-sm font-medium border border-slate-300 bg-white text-slate-700 hover:bg-slate-50 min-h-[44px] md:min-h-0" do %>
                        <span class="inline-flex items-center gap-2"><%= app_icon(:x, css: "w-4 h-4") %><span>Sign out</span></span>
                      <% end %>
                    </div>
                  </div>
                </details>
              </div>
            <% else %>
              <%= link_to root_path, class: "nav-link inline-flex items-center gap-2 py-3 md:py-2 px-3 rounded-lg text-sm font-medium #{current_page?(root_path) ? 'bg-blue-50 text-blue-700' : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900'}" do %>
                <%= app_icon(:dashboard, css: "w-4 h-4") %>
                <span>Home</span>
              <% end %>
              <%= link_to about_path, class: "nav-link inline-flex items-center gap-2 py-3 md:py-2 px-3 rounded-lg text-sm font-medium #{current_page?(about_path) ? 'bg-blue-50 text-blue-700' : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900'}" do %>
                <%= app_icon(:info, css: "w-4 h-4") %>
                <span>About</span>
              <% end %>
              <%= link_to docs_site_url, target: "_blank", rel: "noopener noreferrer", class: "nav-link inline-flex items-center gap-2 py-3 md:py-2 px-3 rounded-lg text-sm font-medium text-slate-600 hover:bg-slate-100 hover:text-slate-900" do %>
                <%= app_icon(:all, css: "w-4 h-4") %>
                <span>Docs</span>
              <% end %>
              <div class="flex flex-col sm:flex-row gap-2 mt-2 md:mt-0 pt-3 md:pt-0 border-t md:border-t-0 border-slate-200">
                <%= link_to new_user_session_path, class: "nav-link py-3 md:py-2 px-4 rounded-lg text-sm font-medium text-slate-600 hover:bg-slate-100 text-center min-h-[44px] md:min-h-0 inline-flex items-center justify-center gap-2", data: { turbo: false } do %>
                  <%= app_icon(:account, css: "w-4 h-4") %>
                  <span>Sign in</span>
                <% end %>
                <%= link_to new_user_registration_path, class: "nav-link py-3 md:py-2 px-4 rounded-lg text-sm font-medium bg-blue-600 text-white hover:bg-blue-700 text-center min-h-[44px] md:min-h-0 inline-flex items-center justify-center gap-2", data: { turbo: false } do %>
                  <%= app_icon(:plus, css: "w-4 h-4") %>
                  <span>Sign up</span>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <main class="<%= user_signed_in? ? 'flex-1 w-full px-3 sm:px-4 lg:px-6 py-4 sm:py-5' : 'flex-1 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8' %>">
      <% if notice %>
        <div class="mb-4 rounded-lg bg-blue-50 border border-blue-200 px-4 py-3 text-sm text-blue-800"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>

    <% unless user_signed_in? %>
      <footer class="border-t border-slate-200 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
          <p class="text-sm text-slate-500">© <%= Time.current.year %> Logister</p>
          <div class="flex items-center gap-4 text-sm">
            <%= link_to "Docs", docs_site_url, target: "_blank", rel: "noopener noreferrer", class: "text-slate-600 hover:text-slate-900 no-underline" %>
            <%= link_to "Privacy", privacy_path, class: "text-slate-600 hover:text-slate-900 no-underline #{current_page?(privacy_path) ? 'font-semibold text-slate-900' : ''}" %>
            <%= link_to "Terms", terms_path, class: "text-slate-600 hover:text-slate-900 no-underline #{current_page?(terms_path) ? 'font-semibold text-slate-900' : ''}" %>
            <% if cookie_consent_enabled %>
              <a href="#" id="open_preferences_center" class="text-slate-600 hover:text-slate-900 no-underline">Cookie preferences</a>
            <% end %>
          </div>
        </div>
      </footer>
    <% end %>

    <script>
      (function() {
        function initNavFallback() {
          var nav = document.querySelector("nav[data-controller~='nav']")
          if (!nav || nav.dataset.navFallbackBound === "1") return

          var toggle = nav.querySelector("[data-nav-target='toggle']")
          var panel = nav.querySelector("[data-nav-target='panel']")
          if (!toggle || !panel) return

          var iconOpen = nav.querySelector("[data-nav-target='iconOpen']")
          var iconClose = nav.querySelector("[data-nav-target='iconClose']")

          function isStimulusConnected() {
            return nav.dataset.navConnected === "1"
          }

          function isOpen() {
            return !panel.classList.contains("hidden")
          }

          function openMenu() {
            panel.classList.remove("hidden")
            toggle.setAttribute("aria-expanded", "true")
            if (iconOpen) iconOpen.classList.add("hidden")
            if (iconClose) iconClose.classList.remove("hidden")
          }

          function closeMenu() {
            panel.classList.add("hidden")
            toggle.setAttribute("aria-expanded", "false")
            if (iconOpen) iconOpen.classList.remove("hidden")
            if (iconClose) iconClose.classList.add("hidden")
          }

          function onToggleClick(event) {
            if (isStimulusConnected()) return
            event.preventDefault()
            event.stopPropagation()
            if (isOpen()) closeMenu()
            else openMenu()
          }

          function onDocClick(event) {
            if (isStimulusConnected() || !isOpen()) return
            if (panel.contains(event.target) || toggle.contains(event.target)) return
            closeMenu()
          }

          function onKeyDown(event) {
            if (isStimulusConnected() || !isOpen()) return
            if (event.key === "Escape") closeMenu()
          }

          function onPanelClick(event) {
            if (isStimulusConnected()) return
            var target = event && event.target
            if (target && typeof target.closest === "function" && target.closest(".nav-link")) closeMenu()
          }

          toggle.addEventListener("click", onToggleClick)
          document.addEventListener("click", onDocClick)
          document.addEventListener("keydown", onKeyDown)
          panel.addEventListener("click", onPanelClick)

          nav.dataset.navFallbackBound = "1"
        }

        document.addEventListener("turbo:load", initNavFallback)
        document.addEventListener("DOMContentLoaded", initNavFallback)
      })()
    </script>

    <%# Cookie Consent by TermsFeed %>
    <% if cookie_consent_enabled %>
      <!-- Cookie Consent by TermsFeed https://www.TermsFeed.com -->
      <script type="text/javascript" src="<%= cookie_consent_script_url %>" charset="UTF-8"></script>
      <script type="text/javascript" charset="UTF-8">
      document.addEventListener('DOMContentLoaded', function () {
      cookieconsent.run({"notice_banner_type":"headline","consent_type":"express","palette":"dark","language":"en","page_load_consent_levels":["strictly-necessary"],"notice_banner_reject_button_hide":false,"preferences_center_close_button_hide":false,"page_refresh_confirmation_buttons":false});
      });
      </script>

      <% if analytics_enabled && google_tag_id.present? %>
        <!-- Google Analytics -->
        <!-- Google tag (gtag.js) -->
        <script type="text/plain" data-cookie-consent="tracking" async src="https://www.googletagmanager.com/gtag/js?id=<%= google_tag_id %>"></script>
        <script type="text/plain" data-cookie-consent="tracking">
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());

          gtag('config', '<%= google_tag_id %>');
        </script>
        <!-- end of Google Analytics-->
      <% end %>

      <% if analytics_enabled && cloudflare_web_analytics_token.present? %>
        <!-- Cloudflare Web Analytics -->
        <script type="text/plain" data-cookie-consent="tracking" defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='<%= { token: cloudflare_web_analytics_token }.to_json %>'></script>
        <!-- End Cloudflare Web Analytics -->
      <% end %>

      <noscript>Free cookie consent management tool by <a href="https://www.termsfeed.com/">TermsFeed</a></noscript>
      <!-- End Cookie Consent by TermsFeed https://www.TermsFeed.com -->
    <% end %>
  </body>
</html>
