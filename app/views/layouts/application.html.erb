<!DOCTYPE html>
<html>
  <head>
    <title><%= seo_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Logister">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="<%= seo_description %>">
    <meta name="robots" content="<%= seo_robots %>">
    <link rel="canonical" href="<%= seo_canonical_url %>">
    <meta property="og:site_name" content="Logister">
    <meta property="og:title" content="<%= seo_title %>">
    <meta property="og:description" content="<%= seo_description %>">
    <meta property="og:type" content="<%= seo_og_type %>">
    <meta property="og:url" content="<%= seo_canonical_url %>">
    <meta property="og:image" content="<%= seo_og_image %>">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= seo_title %>">
    <meta name="twitter:description" content="<%= seo_description %>">
    <meta name="twitter:image" content="<%= seo_og_image %>">
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <% if Rails.application.config.x.logister.cookie_script_id.present? %>
      <script type="text/javascript" charset="UTF-8" src="https://cdn.cookie-script.com/s/<%= Rails.application.config.x.logister.cookie_script_id %>.js" crossorigin="anonymous"></script>
    <% end %>

    <%= yield :head %>
    <% if seo_json_ld.present? %>
      <script type="application/ld+json"><%= raw seo_json_ld %></script>
    <% end %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: { sans: ['Inter', 'ui-sans-serif', 'system-ui', 'sans-serif'] }
          }
        }
      }
    </script>
    <style type="text/tailwindcss">
      @layer components {
        .card { @apply rounded-xl bg-white border border-slate-200 shadow-sm p-5; }
        .btn-ghost { @apply inline-flex items-center px-4 py-2 rounded-lg text-sm font-medium border border-slate-300 bg-white text-slate-700 hover:bg-slate-50 no-underline; }
        .btn-primary { @apply inline-flex items-center justify-center rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 border border-transparent cursor-pointer; }
        .action-link { @apply inline-flex items-center px-4 py-2.5 rounded-lg text-sm font-medium bg-blue-600 text-white hover:bg-blue-700 no-underline; }
        .inline-link { @apply text-sm font-medium text-blue-600 hover:text-blue-700 no-underline; }
        .muted { @apply text-slate-600; }
        .kicker { @apply text-xs font-semibold uppercase tracking-wider text-slate-500; }
        .form-label { @apply block text-sm font-medium text-slate-700 mb-1; }
        .form-input { @apply block w-full rounded-lg border border-slate-300 px-3 py-2 text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500; }
        .sidebar-action-link { @apply block py-1.5 text-sm font-medium text-blue-600 hover:text-blue-700 no-underline; }
        .inbox-filters { @apply flex flex-col gap-0.5; }
        .inbox-filter-link { @apply flex justify-between items-center gap-2 px-3 py-2 rounded-lg text-sm no-underline text-slate-600 hover:bg-slate-100; }
        .inbox-filter-link.is-active { @apply bg-blue-50 text-blue-700 font-medium; }
        .filter-count { @apply text-xs font-bold text-slate-500 bg-slate-100 border border-slate-200 rounded-full px-2 min-w-[1.5rem] text-center; }
        .inbox-filter-link.is-active .filter-count { @apply bg-blue-100 border-blue-200 text-blue-700; }
        .inbox-table-wrap { @apply rounded-xl bg-white border border-slate-200 shadow-sm overflow-hidden; }
        .inbox-table { @apply min-w-full divide-y divide-slate-200; }
        .inbox-table thead { @apply bg-slate-50; }
        .inbox-table th { @apply px-4 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider; }
        .inbox-table .inbox-row { @apply border-b border-slate-200 transition-colors; }
        .inbox-table .inbox-row:hover { @apply bg-slate-50; }
        .inbox-table .inbox-row.is-selected { @apply bg-blue-50 border-l-4 border-l-blue-600; }
        .inbox-table td { @apply px-4 py-3 text-sm; }
        .col-error { @apply max-w-0 w-2/5; }
        .error-row-link { @apply block no-underline text-slate-900; }
        .error-row-link:hover { @apply text-blue-600; }
        .error-title { @apply font-semibold block; }
        .error-subtitle { @apply block text-slate-500 text-sm mt-0.5; }
        .error-meta { @apply block text-slate-400 text-xs mt-1; }
        .stage-tag { @apply inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold bg-slate-100 text-slate-700 border border-slate-200; }
        .inbox-empty { @apply p-6 text-center text-slate-600; }
        .empty-detail { @apply flex items-center justify-center min-h-[200px] rounded-xl bg-white border border-slate-200 shadow-sm p-6; }
        .pill { @apply inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-slate-100 text-slate-700 border border-slate-200; }
        .detail-actionbar { @apply flex flex-wrap justify-between items-start gap-4 rounded-xl bg-white border border-slate-200 shadow-sm p-5; }
        .detail-actionbar-left { @apply min-w-0 flex-1; }
        .detail-actionbar-actions { @apply flex flex-wrap gap-2 shrink-0; }
        .detail-title { @apply text-base font-bold text-slate-900 mt-1 mb-0.5 break-words; }
        .detail-subtitle { @apply text-slate-600 text-sm; }
        .detail-status-badge { @apply inline-block rounded-full px-2.5 py-0.5 text-xs font-bold uppercase tracking-wider; }
        .detail-status-badge.status-unresolved { @apply bg-amber-50 text-amber-800 border border-amber-200; }
        .detail-status-badge.status-resolved { @apply bg-emerald-50 text-emerald-800 border border-emerald-200; }
        .detail-status-badge.status-ignored { @apply bg-slate-100 text-slate-700 border border-slate-200; }
        .detail-status-badge.status-archived { @apply bg-violet-50 text-violet-800 border border-violet-200; }
        .detail-tabs-wrap { @apply rounded-xl bg-white border border-slate-200 shadow-sm p-5; }
        .detail-tabs { @apply flex gap-1 border-b border-slate-200 pb-3 mb-4 flex-wrap; }
        .detail-tab { @apply px-3 py-2 rounded-lg text-sm font-medium text-slate-600 bg-transparent border border-transparent cursor-pointer; }
        .detail-tab:hover { @apply bg-slate-100 text-slate-900; }
        .detail-tab.is-active { @apply bg-blue-50 text-blue-800 border-blue-200 font-semibold; }
        .detail-panel { @apply block; }
        .detail-panel.is-hidden { @apply hidden; }
        .detail-meta-strip { @apply flex flex-wrap gap-4 py-3 border-b border-slate-200 mb-4; }
        .detail-meta-strip > div { @apply flex flex-col gap-0.5; }
        .stacktrace { @apply rounded-lg bg-slate-900 text-slate-100 p-4 text-sm font-mono overflow-auto max-h-[420px] border-0; }
        .stacktrace code { @apply bg-transparent p-0 text-inherit whitespace-pre; }
        .event-meta-list { @apply grid grid-cols-[auto_1fr] gap-x-3 gap-y-1.5 text-sm; }
        .event-meta-list dt { @apply text-slate-500 font-semibold text-xs uppercase tracking-wider; }
        .event-meta-list dd { @apply text-slate-900 break-all m-0; }
        .event-group-card { @apply flex flex-col gap-3 rounded-xl bg-white border border-slate-200 shadow-sm p-5; }
        .event-group-title { @apply font-bold text-slate-900 text-sm m-0 break-words; }
        .event-group-stats { @apply grid grid-cols-2 gap-2 text-sm; }
        .event-group-actions { @apply flex flex-col gap-2 pt-3 border-t border-slate-200; }
        .event-meta-card { @apply rounded-xl bg-white border border-slate-200 shadow-sm p-5 text-sm; }
        .event-breadcrumb { @apply flex flex-col gap-1 py-2; }
        .breadcrumb-link { @apply text-sm text-blue-600 hover:underline no-underline; }
        .context-details { @apply space-y-4; }
        .context-detail-list { @apply grid grid-cols-[minmax(8rem,auto)_1fr] gap-x-3 gap-y-2 text-sm; }
        .context-detail-list dt { @apply text-slate-500 font-semibold text-xs uppercase; }
        .context-detail-list dd { @apply text-slate-900 break-all m-0; }
        .context-json { @apply rounded-lg bg-slate-50 border border-slate-200 p-4 text-sm font-mono overflow-auto max-h-[360px] text-slate-800; }
        .occurrences-table { @apply min-w-full divide-y divide-slate-200; }
        .occurrences-table thead { @apply bg-slate-50; }
        .occurrences-table th { @apply px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider; }
        .occurrences-table td { @apply px-3 py-2 text-sm; }
        .btn-resolve { @apply inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700 border border-emerald-700 cursor-pointer; }
        .btn-reopen { @apply inline-flex items-center justify-center rounded-lg bg-amber-600 px-4 py-2 text-sm font-medium text-white hover:bg-amber-700 border border-amber-700 cursor-pointer; }
        .btn-sm { @apply px-3 py-1.5 text-xs; }
        /* Mobile: ensure nav links have adequate touch targets */
        @media (max-width: 767px) {
          .nav-link { min-height: 2.75rem; display: inline-flex; align-items: center; }
        }
      }
    </style>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-800 antialiased">
    <nav class="bg-white border-b border-slate-200 shadow-sm sticky top-0 z-10">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-14 min-h-[3.5rem] sm:h-16">
          <%= link_to root_path, class: "flex items-center gap-2 text-slate-800 hover:text-slate-600 no-underline font-semibold flex-shrink-0" do %>
            <%= image_tag "logister-logo.svg", alt: "Logister", class: "h-6 w-auto" %>
            <span class="hidden sm:inline">Logister</span>
          <% end %>

          <%# Mobile menu button (min 44px touch target). Toggled by inline script below. %>
          <button type="button"
                  class="md:hidden flex items-center justify-center w-11 h-11 -mr-2 rounded-lg text-slate-600 hover:bg-slate-100 hover:text-slate-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
                  data-nav-toggle
                  aria-expanded="false"
                  aria-controls="nav-menu-panel"
                  aria-label="Toggle menu">
            <svg class="w-6 h-6" data-nav-icon="open" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
            <svg class="w-6 h-6 hidden" data-nav-icon="close" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>

          <%# Nav links: collapsible on mobile, row on md+ %>
          <div id="nav-menu-panel"
               class="hidden md:flex flex-col md:flex-row md:items-center gap-0 md:gap-1 lg:gap-2 absolute md:relative top-full left-0 right-0 md:top-0 bg-white md:bg-transparent border-b md:border-b-0 border-slate-200 md:border-0 shadow-lg md:shadow-none py-3 md:py-0 px-4 md:px-0"
               data-nav-panel>
            <% if user_signed_in? %>
              <%= link_to "Overview", dashboard_path, class: "nav-link py-3 md:py-2 px-3 rounded-lg text-sm font-medium #{current_page?(dashboard_path) ? 'bg-blue-50 text-blue-700' : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900'}" %>
              <%= link_to "Projects", projects_path, class: "nav-link py-3 md:py-2 px-3 rounded-lg text-sm font-medium #{current_page?(projects_path) ? 'bg-blue-50 text-blue-700' : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900'}" %>
              <%= link_to "Account", profile_path, class: "nav-link py-3 md:py-2 px-3 rounded-lg text-sm font-medium #{current_page?(profile_path) ? 'bg-blue-50 text-blue-700' : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900'}" %>
              <% if admin_user? %>
                <%= link_to "Admin", admin_users_path, class: "nav-link py-3 md:py-2 px-3 rounded-lg text-sm font-medium #{request.path.start_with?('/admin') ? 'bg-blue-50 text-blue-700' : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900'}" %>
              <% end %>
              <div class="flex flex-col md:flex-row md:items-center gap-0 md:gap-3 mt-2 md:mt-0 pt-3 md:pt-0 border-t md:border-t-0 border-slate-200 md:border-l md:pl-4">
                <span class="py-3 md:py-0 px-3 text-sm text-slate-500"><%= current_user.email %></span>
                <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "nav-link text-left md:text-center w-full md:w-auto px-3 py-3 md:py-2 rounded-lg text-sm font-medium border border-slate-300 bg-white text-slate-700 hover:bg-slate-50 min-h-[44px] md:min-h-0" %>
              </div>
            <% else %>
              <%= link_to "Home", root_path, class: "nav-link py-3 md:py-2 px-3 rounded-lg text-sm font-medium #{current_page?(root_path) ? 'bg-blue-50 text-blue-700' : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900'}" %>
              <%= link_to "About", about_path, class: "nav-link py-3 md:py-2 px-3 rounded-lg text-sm font-medium #{current_page?(about_path) ? 'bg-blue-50 text-blue-700' : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900'}" %>
              <%= link_to "Privacy", privacy_path, class: "nav-link py-3 md:py-2 px-3 rounded-lg text-sm font-medium #{current_page?(privacy_path) ? 'bg-blue-50 text-blue-700' : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900'}" %>
              <%= link_to "Terms", terms_path, class: "nav-link py-3 md:py-2 px-3 rounded-lg text-sm font-medium #{current_page?(terms_path) ? 'bg-blue-50 text-blue-700' : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900'}" %>
              <div class="flex flex-col sm:flex-row gap-2 mt-2 md:mt-0 pt-3 md:pt-0 border-t md:border-t-0 border-slate-200">
                <%= link_to "Sign in", new_user_session_path, class: "nav-link py-3 md:py-2 px-4 rounded-lg text-sm font-medium text-slate-600 hover:bg-slate-100 text-center min-h-[44px] md:min-h-0 flex items-center justify-center", data: { turbo: false } %>
                <%= link_to "Sign up", new_user_registration_path, class: "nav-link py-3 md:py-2 px-4 rounded-lg text-sm font-medium bg-blue-600 text-white hover:bg-blue-700 text-center min-h-[44px] md:min-h-0 flex items-center justify-center", data: { turbo: false } %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8 min-h-[50vh]">
      <% if notice %>
        <div class="mb-4 rounded-lg bg-blue-50 border border-blue-200 px-4 py-3 text-sm text-blue-800"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>

    <%# Fallback: toggle mobile menu without Stimulus so it works even if nav_controller.js doesn't load %>
    <script>
      (function() {
        var btn = document.querySelector('[data-nav-toggle]');
        var panel = document.getElementById('nav-menu-panel');
        var iconOpen = document.querySelector('[data-nav-icon="open"]');
        var iconClose = document.querySelector('[data-nav-icon="close"]');
        if (!btn || !panel) return;
        function isOpen() { return !panel.classList.contains('hidden'); }
        function openMenu() {
          panel.classList.remove('hidden');
          btn.setAttribute('aria-expanded', 'true');
          if (iconOpen) iconOpen.classList.add('hidden');
          if (iconClose) iconClose.classList.remove('hidden');
        }
        function closeMenu() {
          panel.classList.add('hidden');
          btn.setAttribute('aria-expanded', 'false');
          if (iconOpen) iconOpen.classList.remove('hidden');
          if (iconClose) iconClose.classList.add('hidden');
        }
        btn.addEventListener('click', function(e) {
          e.stopPropagation();
          isOpen() ? closeMenu() : openMenu();
        });
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape' && isOpen()) closeMenu();
        });
        document.addEventListener('click', function(e) {
          if (isOpen() && !panel.contains(e.target) && !btn.contains(e.target)) closeMenu();
        });
        panel.addEventListener('click', function(e) {
          if (e.target.closest && e.target.closest('.nav-link')) closeMenu();
        });
      })();
    </script>
  </body>
</html>
