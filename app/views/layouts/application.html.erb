<!DOCTYPE html>
<html>
  <head>
    <title><%= seo_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Logister">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="<%= seo_description %>">
    <meta name="robots" content="<%= seo_robots %>">
    <link rel="canonical" href="<%= seo_canonical_url %>">
    <meta property="og:site_name" content="Logister">
    <meta property="og:title" content="<%= seo_title %>">
    <meta property="og:description" content="<%= seo_description %>">
    <meta property="og:type" content="<%= seo_og_type %>">
    <meta property="og:url" content="<%= seo_canonical_url %>">
    <meta property="og:image" content="<%= seo_og_image %>">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= seo_title %>">
    <meta name="twitter:description" content="<%= seo_description %>">
    <meta name="twitter:image" content="<%= seo_og_image %>">
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Google Analytics (gtag.js) — loaded only in production and gated by CookieScript consent %>
    <% if Rails.env.production? %>
      <!-- Google tag (gtag.js) -->
      <script type="text/plain"
              data-cookiescript="accepted"
              data-cookiecategory="analytics"
              async
              src="https://www.googletagmanager.com/gtag/js?id=G-3R8CQ5X7XG"></script>
      <script type="text/plain"
              data-cookiescript="accepted"
              data-cookiecategory="analytics">
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());

        // Initial page view
        gtag('config', 'G-3R8CQ5X7XG', { page_path: location.pathname + location.search });

        // Track subsequent Turbo-driven navigations
        document.addEventListener("turbo:load", function() {
          gtag('config', 'G-3R8CQ5X7XG', { page_path: location.pathname + location.search });
        });
      </script>
    <% end %>

    <%# Turbo 8: view transitions (crossfade/slide on navigation and morph). Ignored on Turbo 7. %>
    <meta name="turbo-view-transition" content="true">
    <%# Turbo 8: morphing refresh + preserve scroll when redirecting back to same page. Ignored on Turbo 7. %>
    <meta name="turbo-refresh-method" content="morph">
    <meta name="turbo-refresh-scroll" content="preserve">

    <% if Rails.application.config.x.logister.cookie_script_id.present? %>
      <script type="text/javascript" charset="UTF-8" src="https://cdn.cookie-script.com/s/<%= Rails.application.config.x.logister.cookie_script_id %>.js" crossorigin="anonymous"></script>
    <% end %>

    <%= yield :head %>
    <% if seo_json_ld.present? %>
      <script type="application/ld+json"><%= raw seo_json_ld %></script>
    <% end %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" if tailwind_built? %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-800 antialiased" data-controller="local-time">
    <nav class="bg-white border-b border-slate-200 shadow-sm sticky top-0 z-10" data-controller="nav">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-14 min-h-[3.5rem] sm:h-16">
          <%= link_to root_path, class: "flex items-center gap-2 text-slate-800 hover:text-slate-600 no-underline font-semibold flex-shrink-0" do %>
            <%= image_tag "logister-logo.svg", alt: "Logister", class: "h-6 w-auto" %>
          <% end %>

          <%# Mobile menu button (min 44px touch target). %>
          <button type="button"
                  class="md:hidden flex items-center justify-center w-11 h-11 -mr-2 rounded-lg text-slate-600 hover:bg-slate-100 hover:text-slate-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
                  data-nav-target="toggle"
                  data-action="click->nav#toggle"
                  aria-expanded="false"
                  aria-controls="nav-menu-panel"
                  aria-label="Toggle menu">
            <svg class="w-6 h-6" data-nav-target="iconOpen" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
            <svg class="w-6 h-6 hidden" data-nav-target="iconClose" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>

          <%# Nav links: collapsible on mobile, row on md+ %>
          <div id="nav-menu-panel"
               class="hidden md:flex flex-col md:flex-row md:items-center gap-0 md:gap-1 lg:gap-2 absolute md:relative top-full left-0 right-0 md:top-0 bg-white md:bg-transparent border-b md:border-b-0 border-slate-200 md:border-0 shadow-lg md:shadow-none py-3 md:py-0 px-4 md:px-0"
               data-nav-target="panel">
            <% if user_signed_in? %>
              <%= link_to dashboard_path, class: "nav-link inline-flex items-center gap-2 py-3 md:py-2 px-3 rounded-lg text-sm font-medium #{current_page?(dashboard_path) ? 'bg-blue-50 text-blue-700' : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900'}" do %>
                <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M3 13.5a1.5 1.5 0 0 1 1.5-1.5H9a1.5 1.5 0 0 1 1.5 1.5V19A1.5 1.5 0 0 1 9 20.5H4.5A1.5 1.5 0 0 1 3 19v-5.5Zm10.5-8A1.5 1.5 0 0 1 15 4h4.5A1.5 1.5 0 0 1 21 5.5V11a1.5 1.5 0 0 1-1.5 1.5H15a1.5 1.5 0 0 1-1.5-1.5V5.5ZM3 5.5A1.5 1.5 0 0 1 4.5 4H9a1.5 1.5 0 0 1 1.5 1.5V8A1.5 1.5 0 0 1 9 9.5H4.5A1.5 1.5 0 0 1 3 8V5.5Zm10.5 8A1.5 1.5 0 0 1 15 12h4.5a1.5 1.5 0 0 1 1.5 1.5V19a1.5 1.5 0 0 1-1.5 1.5H15a1.5 1.5 0 0 1-1.5-1.5v-5.5Z"/>
                </svg>
                <span>Overview</span>
              <% end %>
              <%= link_to projects_path, class: "nav-link inline-flex items-center gap-2 py-3 md:py-2 px-3 rounded-lg text-sm font-medium #{current_page?(projects_path) ? 'bg-blue-50 text-blue-700' : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900'}" do %>
                <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M3 7.5A2.5 2.5 0 0 1 5.5 5h4A2.5 2.5 0 0 1 12 7.5v1A2.5 2.5 0 0 1 9.5 11h-4A2.5 2.5 0 0 1 3 8.5v-1Zm9 8A2.5 2.5 0 0 1 14.5 13h4a2.5 2.5 0 0 1 2.5 2.5v1a2.5 2.5 0 0 1-2.5 2.5h-4a2.5 2.5 0 0 1-2.5-2.5v-1Zm-9 0A2.5 2.5 0 0 1 5.5 13h4A2.5 2.5 0 0 1 12 15.5v1A2.5 2.5 0 0 1 9.5 19h-4A2.5 2.5 0 0 1 3 16.5v-1ZM12 7.5A2.5 2.5 0 0 1 14.5 5h4A2.5 2.5 0 0 1 21 7.5v1a2.5 2.5 0 0 1-2.5 2.5h-4A2.5 2.5 0 0 1 12 8.5v-1Z"/>
                </svg>
                <span>Projects</span>
              <% end %>
              <div class="mt-2 md:mt-0 pt-3 md:pt-0 border-t md:border-t-0 border-slate-200 md:border-l md:pl-4">
                <details class="relative">
                  <summary class="list-none flex items-center justify-between gap-2 py-3 md:py-2 px-3 rounded-lg text-sm font-medium text-slate-600 hover:bg-slate-100 hover:text-slate-900 cursor-pointer select-none min-h-[44px] md:min-h-0">
                    <span class="truncate max-w-[220px] text-left"><%= current_user.email %></span>
                    <svg class="w-4 h-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                    </svg>
                  </summary>
                  <div class="md:absolute md:right-0 mt-1 md:mt-2 w-full md:w-56 rounded-lg border border-slate-200 bg-white shadow-sm overflow-hidden z-10">
                    <%= link_to profile_path, class: "nav-link flex items-center gap-2 px-3 py-2.5 text-sm font-medium #{current_page?(profile_path) ? 'bg-blue-50 text-blue-700' : 'text-slate-700 hover:bg-slate-50'}" do %>
                      <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M12 12a4.25 4.25 0 1 0 0-8.5 4.25 4.25 0 0 0 0 8.5ZM4.5 19.25a7.5 7.5 0 1 1 15 0 .75.75 0 0 1-.75.75H5.25a.75.75 0 0 1-.75-.75Z"/>
                      </svg>
                      <span>Account</span>
                    <% end %>
                    <% if admin_user? %>
                      <%= link_to admin_users_path, class: "nav-link flex items-center gap-2 px-3 py-2.5 text-sm font-medium #{request.path.start_with?('/admin') ? 'bg-blue-50 text-blue-700' : 'text-slate-700 hover:bg-slate-50'}" do %>
                        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                          <path d="M12 2.75a.75.75 0 0 1 .75.75v1.027a7.75 7.75 0 0 1 3.521 1.46l.726-.726a.75.75 0 1 1 1.061 1.06l-.726.727a7.75 7.75 0 0 1 1.46 3.522H19.5a.75.75 0 0 1 0 1.5h-1.028a7.75 7.75 0 0 1-1.46 3.521l.727.726a.75.75 0 1 1-1.06 1.061l-.727-.726a7.75 7.75 0 0 1-3.522 1.46V20.5a.75.75 0 0 1-1.5 0v-1.028a7.75 7.75 0 0 1-3.521-1.46l-.726.727a.75.75 0 1 1-1.061-1.06l.726-.727a7.75 7.75 0 0 1-1.46-3.522H4.5a.75.75 0 0 1 0-1.5h1.027a7.75 7.75 0 0 1 1.46-3.521l-.726-.726a.75.75 0 1 1 1.06-1.061l.727.726a7.75 7.75 0 0 1 3.522-1.46V3.5a.75.75 0 0 1 .75-.75Zm0 5a4.25 4.25 0 1 0 0 8.5 4.25 4.25 0 0 0 0-8.5Z"/>
                        </svg>
                        <span>Admin</span>
                      <% end %>
                    <% end %>
                    <div class="border-t border-slate-200 p-2">
                      <%= button_to destroy_user_session_path, method: :delete, class: "nav-link w-full text-left px-3 py-2 rounded-lg text-sm font-medium border border-slate-300 bg-white text-slate-700 hover:bg-slate-50 min-h-[44px] md:min-h-0" do %>
                        <span class="inline-flex items-center gap-2">
                          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M9 3.75A2.25 2.25 0 0 0 6.75 6v12A2.25 2.25 0 0 0 9 20.25h4.5a.75.75 0 0 0 0-1.5H9A.75.75 0 0 1 8.25 18V6A.75.75 0 0 1 9 5.25h4.5a.75.75 0 0 0 0-1.5H9Zm7.28 4.97a.75.75 0 0 0-1.06 1.06l1.72 1.72H11.25a.75.75 0 0 0 0 1.5h5.69l-1.72 1.72a.75.75 0 1 0 1.06 1.06l3-3a.75.75 0 0 0 0-1.06l-3-3Z"/>
                          </svg>
                          <span>Sign out</span>
                        </span>
                      <% end %>
                    </div>
                  </div>
                </details>
              </div>
            <% else %>
              <%= link_to root_path, class: "nav-link inline-flex items-center gap-2 py-3 md:py-2 px-3 rounded-lg text-sm font-medium #{current_page?(root_path) ? 'bg-blue-50 text-blue-700' : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900'}" do %>
                <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12.72 3.53a1.1 1.1 0 0 0-1.44 0l-8 7A1.1 1.1 0 0 0 4 12.5h1.25V19A2.25 2.25 0 0 0 7.5 21.25h3.75v-4.5a.75.75 0 0 1 .75-.75h0a.75.75 0 0 1 .75.75v4.5h3.75A2.25 2.25 0 0 0 19.75 19v-6.5H21a1.1 1.1 0 0 0 .72-1.97l-8-7Z"/>
                </svg>
                <span>Home</span>
              <% end %>
              <%= link_to about_path, class: "nav-link inline-flex items-center gap-2 py-3 md:py-2 px-3 rounded-lg text-sm font-medium #{current_page?(about_path) ? 'bg-blue-50 text-blue-700' : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900'}" do %>
                <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2.75a9.25 9.25 0 1 0 0 18.5 9.25 9.25 0 0 0 0-18.5Zm0 5.5a1 1 0 1 1 0 2 1 1 0 0 1 0-2Zm1 9a.75.75 0 0 1-1.5 0v-4a.75.75 0 0 1 1.5 0v4Z"/>
                </svg>
                <span>About</span>
              <% end %>
              <div class="flex flex-col sm:flex-row gap-2 mt-2 md:mt-0 pt-3 md:pt-0 border-t md:border-t-0 border-slate-200">
                <%= link_to new_user_session_path, class: "nav-link py-3 md:py-2 px-4 rounded-lg text-sm font-medium text-slate-600 hover:bg-slate-100 text-center min-h-[44px] md:min-h-0 inline-flex items-center justify-center gap-2", data: { turbo: false } do %>
                  <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M9 3.75A2.25 2.25 0 0 0 6.75 6v12A2.25 2.25 0 0 0 9 20.25h4.5a.75.75 0 0 0 0-1.5H9A.75.75 0 0 1 8.25 18V6A.75.75 0 0 1 9 5.25h4.5a.75.75 0 0 0 0-1.5H9Zm7.28 4.97a.75.75 0 0 0-1.06 1.06l1.72 1.72H11.25a.75.75 0 0 0 0 1.5h5.69l-1.72 1.72a.75.75 0 1 0 1.06 1.06l3-3a.75.75 0 0 0 0-1.06l-3-3Z"/>
                  </svg>
                  <span>Sign in</span>
                <% end %>
                <%= link_to new_user_registration_path, class: "nav-link py-3 md:py-2 px-4 rounded-lg text-sm font-medium bg-blue-600 text-white hover:bg-blue-700 text-center min-h-[44px] md:min-h-0 inline-flex items-center justify-center gap-2", data: { turbo: false } do %>
                  <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 2.75a.75.75 0 0 1 .75.75v7.75h7.75a.75.75 0 0 1 0 1.5h-7.75v7.75a.75.75 0 0 1-1.5 0v-7.75H3.5a.75.75 0 0 1 0-1.5h7.75V3.5a.75.75 0 0 1 .75-.75Z"/>
                  </svg>
                  <span>Sign up</span>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8 min-h-[50vh]">
      <% if notice %>
        <div class="mb-4 rounded-lg bg-blue-50 border border-blue-200 px-4 py-3 text-sm text-blue-800"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>

    <footer class="border-t border-slate-200 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <p class="text-sm text-slate-500">© <%= Time.current.year %> Logister</p>
        <div class="flex items-center gap-4 text-sm">
          <%= link_to "Privacy", privacy_path, class: "text-slate-600 hover:text-slate-900 no-underline #{current_page?(privacy_path) ? 'font-semibold text-slate-900' : ''}" %>
          <%= link_to "Terms", terms_path, class: "text-slate-600 hover:text-slate-900 no-underline #{current_page?(terms_path) ? 'font-semibold text-slate-900' : ''}" %>
        </div>
      </div>
    </footer>
  </body>
</html>
