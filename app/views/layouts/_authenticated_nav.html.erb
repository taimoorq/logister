<nav class="nav-shell bg-[var(--app-nav-bg)] border-b border-[var(--app-nav-border)] sticky top-0 z-20"
     style="view-transition-name: app-nav; view-transition-class: app-shell;"
     data-nav-state="closed"
     data-controller="nav"
     data-action="click@document->nav#closeOnClickOutside keydown@document->nav#closeOnEscape">
  <div class="w-full px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-14 min-h-[3.5rem]">
      <div class="flex items-center gap-3 min-w-0">
        <%= link_to dashboard_path, class: "flex items-center gap-2 no-underline font-semibold shrink-0 text-white hover:text-blue-100" do %>
          <%= image_tag "logister-logo-light.svg", alt: "Logister", class: "h-6 w-auto", width: 232, height: 48 %>
        <% end %>
        <div class="hidden md:block h-5 w-px bg-blue-300/40"></div>
        <p class="hidden md:block text-sm text-blue-100 truncate max-w-[16rem]"><%= defined?(@project) && @project.present? ? @project.name : "Stability center" %></p>
      </div>

      <button type="button"
              class="md:hidden flex items-center justify-center w-11 h-11 -mr-2 rounded-lg text-blue-100 hover:bg-blue-900/60 hover:text-white focus:outline-none focus:ring-2 focus:ring-blue-300 focus:ring-offset-2 focus:ring-offset-[var(--app-nav-bg)]"
              data-nav-target="toggle"
              data-action="click->nav#toggle"
              aria-expanded="false"
              aria-controls="nav-menu-panel"
              aria-label="Toggle menu">
        <%= app_icon(:menu, css: "nav-icon-open w-6 h-6") %>
        <%= app_icon(:x, css: "nav-icon-close w-6 h-6") %>
      </button>

      <div id="nav-menu-panel"
           class="nav-panel hidden md:flex flex-col md:flex-row md:items-center gap-0 md:gap-1 absolute md:relative top-full left-0 right-0 md:top-0 bg-[var(--app-nav-bg)] md:bg-transparent border-b border-[var(--app-nav-border)] md:border-0 shadow-lg md:shadow-none py-3 md:py-0 px-4 md:px-0"
           data-nav-target="panel"
           data-state="closed"
           aria-hidden="true"
           data-action="click->nav#closeOnNavLink">
        <% projects_nav_active = request.path.start_with?("/projects") %>
        <% notifications = nav_notifications %>
        <%= link_to dashboard_path, class: "nav-link inline-flex items-center gap-2 py-2 px-3 rounded-md text-sm font-medium #{current_page?(dashboard_path) ? 'bg-blue-800/70 text-white' : 'text-blue-100 hover:bg-blue-900/60 hover:text-white'}" do %>
          <%= app_icon(:dashboard, css: "w-4 h-4") %>
          <span>Overview</span>
        <% end %>
        <details class="nav-project-menu">
          <summary class="nav-project-summary <%= projects_nav_active ? 'bg-blue-800/70 text-white' : 'text-blue-100 hover:bg-blue-900/60 hover:text-white' %>">
            <span class="inline-flex min-w-0 items-center gap-2">
              <%= app_icon(:projects, css: "w-4 h-4 shrink-0") %>
              <span>Projects</span>
            </span>
            <%= app_icon(:chevron_down, css: "w-4 h-4 shrink-0") %>
          </summary>
          <div class="nav-project-dropdown">
            <div class="nav-project-list" aria-label="Active projects">
              <% if nav_active_projects.any? %>
                <% nav_active_projects.each do |project| %>
                  <%= link_to project_path(project), class: "nav-link nav-project-item" do %>
                    <%= project_integration_icon(project) %>
                    <span class="nav-project-item-copy">
                      <span class="nav-project-item-title"><%= project.name %></span>
                      <span class="nav-project-item-meta"><%= project.integration_label %></span>
                    </span>
                  <% end %>
                <% end %>
              <% else %>
                <p class="nav-project-empty">No active projects yet</p>
              <% end %>
            </div>
            <div class="nav-project-actions">
              <%= link_to projects_path, class: "nav-link nav-project-action #{current_page?(projects_path) ? 'bg-blue-50 text-blue-700' : ''}" do %>
                <%= app_icon(:all, css: "w-4 h-4") %>
                <span>All projects</span>
              <% end %>
              <%= link_to new_project_path, class: "nav-link nav-project-action nav-project-action-primary" do %>
                <%= app_icon(:plus, css: "w-4 h-4") %>
                <span>Add project</span>
              <% end %>
            </div>
          </div>
        </details>
        <%= link_to docs_site_url, target: "_blank", rel: "noopener noreferrer", class: "nav-link inline-flex items-center gap-2 py-2 px-3 rounded-md text-sm font-medium text-blue-100 hover:bg-blue-900/60 hover:text-white" do %>
          <%= app_icon(:all, css: "w-4 h-4") %>
          <span>Docs</span>
        <% end %>

        <details class="relative">
          <summary class="list-none relative flex items-center justify-between gap-2 py-2 px-3 rounded-md text-sm font-medium text-blue-100 hover:bg-blue-900/60 hover:text-white cursor-pointer select-none min-h-[44px] md:min-h-0"
                   aria-label="<%= notifications.any? ? "#{pluralize(notifications.size, 'notification')} available" : "Notifications" %>">
            <span class="inline-flex items-center gap-2">
              <%= app_icon(:notifications, css: "w-4 h-4") %>
              <span class="md:hidden">Notifications</span>
            </span>
            <% if notifications.any? %>
              <span class="inline-flex min-w-5 h-5 items-center justify-center rounded-full bg-white px-1.5 text-xs font-bold text-blue-700"><%= notifications.size %></span>
            <% end %>
          </summary>
          <div class="md:absolute md:right-0 mt-1 md:mt-2 w-full md:w-80 rounded-lg border border-slate-200 bg-white shadow-sm overflow-hidden z-10">
            <div class="px-3 py-2.5 border-b border-slate-200">
              <p class="text-sm font-semibold text-slate-900">Notifications</p>
            </div>
            <% if notifications.any? %>
              <div class="divide-y divide-slate-200">
                <% notifications.each do |notification| %>
                  <div class="p-3">
                    <div class="flex items-start gap-3">
                      <span class="mt-0.5 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-blue-50 text-blue-700">
                        <%= app_icon(notification.icon, css: "w-4 h-4") %>
                      </span>
                      <div class="min-w-0 flex-1">
                        <p class="text-sm font-semibold text-slate-900"><%= notification.title %></p>
                        <p class="mt-1 text-sm leading-5 text-slate-600"><%= notification.body %></p>
                        <div class="mt-3 flex flex-wrap items-center gap-2">
                          <%= link_to notification.action_label,
                                      notification.url,
                                      target: "_blank",
                                      rel: "noopener noreferrer",
                                      class: "nav-link inline-flex items-center gap-1.5 rounded-md border border-blue-600 bg-blue-600 px-2.5 py-1.5 text-xs font-semibold text-white hover:bg-blue-700" %>
                          <%= button_to "Dismiss",
                                        dismiss_notification_path(notification_key: notification.key),
                                        method: :post,
                                        form: { class: "inline" },
                                        class: "nav-link rounded-md border border-slate-300 bg-white px-2.5 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-50" %>
                        </div>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            <% else %>
              <div class="p-3">
                <p class="text-sm text-slate-600">No new notifications.</p>
              </div>
            <% end %>
          </div>
        </details>

        <div class="mt-2 md:mt-0 pt-3 md:pt-0 border-t md:border-t-0 border-[var(--app-nav-border)] md:border-l md:border-[var(--app-nav-border)] md:pl-3">
          <details class="relative">
            <summary class="list-none flex items-center justify-between gap-2 py-2 px-3 rounded-md text-sm font-medium text-blue-100 hover:bg-blue-900/60 hover:text-white cursor-pointer select-none min-h-[44px] md:min-h-0">
              <span class="truncate max-w-[220px] text-left"><%= user_display_name(current_user) %></span>
              <%= app_icon(:chevron_down, css: "w-4 h-4 shrink-0") %>
            </summary>
            <div class="md:absolute md:right-0 mt-1 md:mt-2 w-full md:w-56 rounded-lg border border-slate-200 bg-white shadow-sm overflow-hidden z-10">
              <%= link_to profile_path, class: "nav-link block px-3 py-2.5 text-sm font-medium #{current_page?(profile_path) ? 'bg-blue-50 text-blue-700' : 'text-slate-700 hover:bg-slate-50'}" do %>
                <span class="inline-flex items-center gap-2"><%= app_icon(:account, css: "w-4 h-4") %><span>Account</span></span>
              <% end %>
              <% if admin_user? %>
                <%= link_to admin_users_path, class: "nav-link block px-3 py-2.5 text-sm font-medium #{request.path.start_with?('/admin') ? 'bg-blue-50 text-blue-700' : 'text-slate-700 hover:bg-slate-50'}" do %>
                  <span class="inline-flex items-center gap-2"><%= app_icon(:shield, css: "w-4 h-4") %><span>Admin</span></span>
                <% end %>
              <% end %>
              <div class="border-t border-slate-200 p-2">
                <%= button_to destroy_user_session_path, method: :delete, class: "nav-link w-full text-left px-3 py-2 rounded-lg text-sm font-medium border border-slate-300 bg-white text-slate-700 hover:bg-slate-50 min-h-[44px] md:min-h-0" do %>
                  <span class="inline-flex items-center gap-2"><%= app_icon(:x, css: "w-4 h-4") %><span>Sign out</span></span>
                <% end %>
              </div>
            </div>
          </details>
        </div>
      </div>
    </div>
  </div>
</nav>
