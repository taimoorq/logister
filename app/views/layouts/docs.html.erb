<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= seo_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Logister Documentation">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="<%= seo_description %>">
    <meta name="robots" content="<%= seo_robots %>">
    <link rel="canonical" href="<%= seo_canonical_url %>">
    <meta property="og:site_name" content="Logister">
    <meta property="og:title" content="<%= seo_title %>">
    <meta property="og:description" content="<%= seo_description %>">
    <meta property="og:type" content="<%= seo_og_type %>">
    <meta property="og:url" content="<%= seo_canonical_url %>">
    <meta property="og:image" content="<%= seo_og_image %>">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= seo_title %>">
    <meta name="twitter:description" content="<%= seo_description %>">
    <meta name="twitter:image" content="<%= seo_og_image %>">
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <% google_tag_id = ENV["GOOGLE_TAG_ID"].to_s.strip.presence %>
    <% if google_tag_id.present? %>
      <meta name="logister-google-tag-id" content="<%= google_tag_id %>">
    <% end %>
    <meta name="turbo-view-transition" content="true">
    <meta name="turbo-refresh-method" content="morph">
    <meta name="turbo-refresh-scroll" content="preserve">

    <%= yield :head %>
    <%= content_tag(:script, seo_json_ld, type: "application/ld+json") if seo_json_ld.present? %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">

    <%= app_stylesheet_tags %>
    <style><%= docs_rouge_theme_css.html_safe %></style>
    <%= app_javascript_tags %>
  </head>

  <body class="docs-app min-h-screen antialiased text-slate-900" data-controller="local-time">
    <header class="docs-topbar" data-controller="nav">
      <div class="docs-topbar-inner">
        <div class="docs-topbar-branding">
          <%= link_to(user_signed_in? ? dashboard_path : root_path, class: "docs-topbar-brand") do %>
            <%= image_tag "logister-logo.svg", alt: "Logister", class: "docs-topbar-logo", width: 232, height: 48 %>
          <% end %>
          <div class="docs-topbar-divider"></div>
          <div class="docs-topbar-context">
            <p class="docs-topbar-kicker">Documentation</p>
            <p class="docs-topbar-title"><%= docs_current_page_label %></p>
          </div>
        </div>

        <button type="button"
                class="docs-topbar-toggle md:hidden"
                data-nav-target="toggle"
                data-action="click->nav#toggle"
                aria-expanded="false"
                aria-controls="docs-nav-panel"
                aria-label="Toggle documentation navigation">
          <svg class="w-5 h-5" data-nav-target="iconOpen" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
          <svg class="w-5 h-5 hidden" data-nav-target="iconClose" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>

        <div id="docs-nav-panel" class="hidden docs-topbar-panel md:flex" data-nav-target="panel">
          <div class="docs-topbar-actions">
            <% if user_signed_in? %>
              <%= link_to "Overview", dashboard_path, class: "nav-link docs-topbar-action" %>
              <%= link_to "Projects", projects_path, class: "nav-link docs-topbar-action" %>
              <%= link_to current_user.email, profile_path, class: "nav-link docs-topbar-account" %>
            <% else %>
              <%= link_to "About", about_path, class: "nav-link docs-topbar-action" %>
              <%= link_to "Sign in", new_user_session_path, class: "nav-link docs-topbar-action", data: { turbo: false } %>
              <%= link_to "Sign up", new_user_registration_path, class: "nav-link docs-topbar-cta", data: { turbo: false } %>
            <% end %>
          </div>
        </div>
      </div>
    </header>

    <main class="docs-layout-main">
      <% if notice %>
        <div class="docs-flash docs-flash-notice"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="docs-flash docs-flash-alert"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>

    <footer class="docs-footer">
      <div class="docs-footer-inner">
        <div>
          <p class="docs-footer-title">Logister documentation</p>
          <p class="docs-footer-copy">Reference material for integrating errors, metrics, logs, and check-ins into Logister.</p>
        </div>

        <div class="docs-footer-links">
          <% docs_navigation_sections.each do |section| %>
            <div class="docs-footer-column">
              <p class="docs-footer-heading"><%= section[:title] %></p>
              <% section[:items].each do |label, path| %>
                <%= link_to label, path, class: "docs-footer-link" %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </footer>
  </body>
</html>
