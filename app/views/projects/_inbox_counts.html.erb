<nav id="inbox_counts" class="inbox-filters">
  <%= link_to project_path(project, filter: "unresolved", q: query),
              class: "inbox-filter-link #{"is-active" if filter == "unresolved"}",
              aria: { current: ("page" if filter == "unresolved") },
              data: { turbo_frame: "project_inbox", turbo_action: "advance",
                      action: "click->inbox#activateFilter", inbox_target: "filterLink" } do %>
    <span class="filter-label inline-flex items-center gap-1.5"><%= app_icon(:warning, css: "w-3.5 h-3.5") %><span>Open</span></span>
    <span class="filter-count"><%= counts[:unresolved] %></span>
  <% end %>

  <%= link_to project_path(project, filter: "introduced_today", q: query),
              class: "inbox-filter-link #{"is-active" if filter == "introduced_today"}",
