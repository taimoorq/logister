    <span class="filter-count"><%= counts[:ignored] %></span>
  <% end %>

  <%= link_to project_path(project, filter: "archived", q: query),
              class: "inbox-filter-link #{"is-active" if filter == "archived"}",
              aria: { current: ("page" if filter == "archived") },
