                      action: "click->inbox#activateFilter", inbox_target: "filterLink" } do %>
    <span class="filter-label">Introduced today</span>
    <span class="filter-count"><%= counts[:introduced_today] %></span>
  <% end %>

  <%= link_to project_events_path(project, filter: "resolved", q: query),
              class: "inbox-filter-link #{"is-active" if filter == "resolved"}",
              data: { turbo_frame: "project_inbox", turbo_action: "advance",
                      action: "click->inbox#activateFilter", inbox_target: "filterLink" } do %>
    <span class="filter-label">Resolved</span>
    <span class="filter-count"><%= counts[:resolved] %></span>
  <% end %>

  <%= link_to project_events_path(project, filter: "ignored", q: query),
              class: "inbox-filter-link #{"is-active" if filter == "ignored"}",
              data: { turbo_frame: "project_inbox", turbo_action: "advance",
                      action: "click->inbox#activateFilter", inbox_target: "filterLink" } do %>
    <span class="filter-label">Ignored</span>
    <span class="filter-count"><%= counts[:ignored] %></span>
  <% end %>

  <%= link_to project_events_path(project, filter: "archived", q: query),
              class: "inbox-filter-link #{"is-active" if filter == "archived"}",
