    <span class="filter-count"><%= counts[:archived] %></span>
  <% end %>

  <%= link_to project_path(project, filter: "all", q: query),
              class: "inbox-filter-link #{"is-active" if filter == "all"}",
              aria: { current: ("page" if filter == "all") },
              data: { turbo_frame: "project_inbox", turbo_action: "advance",
                      action: "click->inbox#activateFilter", inbox_target: "filterLink" } do %>
