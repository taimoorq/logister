<div class="card section-head">
  <div>
    <h1>Your monitored apps</h1>
    <p class="muted">Each project has its own API keys and event stream.</p>
  </div>
  <%= link_to "New project", new_project_path, class: "action-link" %>
</div>

<section class="card">
  <% if @projects.any? %>
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Slug</th>
          <th>API keys</th>
          <th>Events</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @projects.each do |project| %>
          <tr>
            <td><%= project.name %></td>
            <td><code><%= project.slug %></code></td>
            <td><%= project.api_keys.active.count %></td>
            <td><%= project.ingest_events.count %></td>
            <td><%= link_to "Open", project_path(project) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="muted">No projects created yet.</p>
  <% end %>
</section>
