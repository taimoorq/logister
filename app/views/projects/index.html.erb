<div class="section-head projects-head">
  <div>
    <h1>Projects</h1>
    <p class="muted">Browse project health, open errors, and activity at a glance.</p>
  </div>
  <%= link_to "New project", new_project_path, class: "action-link" %>
</div>

<section class="projects-toolbar card">
  <input type="search" placeholder="Search projects" aria-label="Search projects"
         data-controller="project-search" data-action="input->project-search#filter">
</section>

<section class="project-grid">
  <% if @projects.any? %>
    <% @projects.each do |project| %>
      <% stats = @project_stats[project.id] || { total_events: 0, open_groups: 0, trend: Array.new(7, 0) } %>
      <article class="project-card" data-project-name="<%= project.name.downcase %>">
        <div class="project-card-top">
          <div>
            <h2><%= project.name %></h2>
            <p class="muted"><%= project.slug %></p>
          </div>
          <span class="pill"><%= project.owned_by?(current_user) ? "Owner" : "Shared" %></span>
        </div>

        <div class="project-metrics">
          <div>
            <p class="kicker">Open errors</p>
            <p class="metric-value"><%= stats[:open_groups] %></p>
          </div>
          <div>
            <p class="kicker">Total events</p>
            <p class="metric-value"><%= stats[:total_events] %></p>
          </div>
          <div>
            <p class="kicker">Errors (7d)</p>
            <p class="metric-value"><%= stats[:trend].sum %></p>
          </div>
        </div>

        <%= render "shared/widgets/sparkline", points: stats[:trend] %>

        <div class="project-card-foot">
          <p class="muted">
            <% if stats[:open_groups] > 0 %>
              <strong class="text-danger"><%= stats[:open_groups] %> open</strong> error <%= "group".pluralize(stats[:open_groups]) %>
            <% else %>
              No open errors
            <% end %>
          </p>
          <%= link_to "Open inbox →", project_path(project), class: "inline-link" %>
        </div>
      </article>
    <% end %>
  <% else %>
    <section class="card">
      <p class="muted">No projects yet. Create your first project to start ingesting events.</p>
      <%= link_to "Create project", new_project_path, class: "action-link" %>
    </section>
  <% end %>
</section>
