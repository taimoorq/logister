<% tour_group = "projects-index" %>

<%= render layout: "shared/product_tour_frame",
           locals: { tour_group: tour_group, controllers: "project-search", html_options: { class: "projects-page" } } do %>
  <section class="projects-command-row"
           <%= tag.attributes(data: product_tour_step_data(tour_group, :command_row)) %>>
    <div class="projects-search">
      <span class="projects-search-icon"><%= app_icon(:search, css: "w-4 h-4") %></span>
      <input type="search" placeholder="Search projects" aria-label="Search projects"
             class="form-input projects-search-input"
             data-action="input->project-search#filter">
    </div>

    <div class="projects-action-row">
      <%= tour_help_button %>
      <%= link_to "Docs", docs_site_url, target: "_blank", rel: "noopener noreferrer", class: "projects-secondary-button" %>
      <%= link_to new_project_path, class: "projects-new-button" do %>
        <%= app_icon(:plus, css: "w-4 h-4") %>
        <span>New project</span>
      <% end %>
    </div>
  </section>

  <section class="projects-title-row">
    <div>
      <h1>Projects</h1>
      <p>
        Need setup help?
        <%= link_to "Open the docs", docs_site_url, target: "_blank", rel: "noopener noreferrer", class: "projects-inline-link" %>.
      </p>
    </div>
  </section>

  <nav class="projects-filter-tabs"
       aria-label="Project status"
       <%= tag.attributes(data: product_tour_step_data(tour_group, :filters)) %>>
    <%= link_to projects_path,
                class: "projects-filter-tab #{"is-active" if @project_filter == "active"}",
                aria: { current: ("page" if @project_filter == "active") } do %>
      <%= app_icon(:check, css: "w-3.5 h-3.5") %>
      <span>Active</span>
      <strong><%= number_with_delimiter(@project_filter_counts.fetch(:active, 0)) %></strong>
    <% end %>
    <%= link_to projects_path(filter: "archived"),
                class: "projects-filter-tab #{"is-active" if @project_filter == "archived"}",
                aria: { current: ("page" if @project_filter == "archived") } do %>
      <%= app_icon(:archive, css: "w-3.5 h-3.5") %>
      <span>Archived</span>
      <strong><%= number_with_delimiter(@project_filter_counts.fetch(:archived, 0)) %></strong>
    <% end %>
    <%= link_to projects_path(filter: "all"),
                class: "projects-filter-tab #{"is-active" if @project_filter == "all"}",
                aria: { current: ("page" if @project_filter == "all") } do %>
      <%= app_icon(:all, css: "w-3.5 h-3.5") %>
      <span>All</span>
      <strong><%= number_with_delimiter(@project_filter_counts.fetch(:all, 0)) %></strong>
    <% end %>
  </nav>

  <section class="projects-overview-strip"
           aria-label="Project overview"
           <%= tag.attributes(data: product_tour_step_data(tour_group, :summary)) %>>
    <span class="project-overview-cell">
      <span class="project-overview-icon"><%= app_icon(:projects, css: "w-4 h-4") %></span>
      <span>
        <strong><%= number_with_delimiter(@projects_overview.fetch(:projects_count, 0)) %></strong>
        <span><%= @project_filter == "archived" ? "Archived apps" : (@project_filter == "all" ? "Total apps" : "Active apps") %></span>
      </span>
    </span>

    <% open_groups_count = @projects_overview.fetch(:open_groups_count, 0) %>
    <% open_groups_cell_class = "project-overview-cell #{dashboard_metric_state_class(open_groups_count)}" %>
    <% if @project_filter == "active" %>
      <%= link_to dashboard_path, class: open_groups_cell_class do %>
        <span class="project-overview-icon"><%= app_icon(:warning, css: "w-4 h-4") %></span>
        <span>
          <strong><%= number_with_delimiter(open_groups_count) %></strong>
          <span>Open errors</span>
        </span>
      <% end %>
    <% else %>
      <span class="<%= open_groups_cell_class %>">
        <span class="project-overview-icon"><%= app_icon(:warning, css: "w-4 h-4") %></span>
        <span>
          <strong><%= number_with_delimiter(open_groups_count) %></strong>
          <span>Open errors</span>
        </span>
      </span>
    <% end %>

    <span class="project-overview-cell">
      <span class="project-overview-icon"><%= app_icon(:chart, css: "w-4 h-4") %></span>
      <span>
        <strong><%= number_with_delimiter(@projects_overview.fetch(:activity_events_count, 0)) %></strong>
        <span>Events 7d</span>
      </span>
    </span>

    <span class="project-overview-cell">
      <span class="project-overview-icon"><%= app_icon(:check, css: "w-4 h-4") %></span>
      <span>
        <strong><%= number_with_delimiter(@projects_overview.fetch(:quiet_projects_count, 0)) %></strong>
        <span>Quiet apps</span>
      </span>
    </span>
  </section>

  <%= render "project_cards", projects: @projects, project_stats: @project_stats, project_filter: @project_filter, tour_group: tour_group %>
<% end %>
