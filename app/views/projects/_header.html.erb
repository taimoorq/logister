<%# locals: (tour_group: nil, archived_notice_settings_link: true, highlight_header: false, highlight_navigation: false) %>
<% highlight_header = local_assigns.fetch(:highlight_header, false) %>
<% highlight_navigation = local_assigns.fetch(:highlight_navigation, false) %>
<% section_label = [
  [ project_path(@project), "Project home" ],
  [ inbox_project_path(@project), "Project inbox" ],
  [ insights_project_path(@project), "Project insights" ],
  [ deployments_project_path(@project), "Project deployments" ],
  [ setup_project_path(@project), "Project setup" ],
  [ settings_project_path(@project), "Project settings" ],
  [ edit_project_path(@project), "Project settings" ],
  [ activity_project_path(@project), "Project events" ],
  [ performance_project_path(@project), "Project performance" ],
  [ monitors_project_path(@project), "Project monitors" ]
].find { |path, _label| request.path == path }&.second || "Project" %>

<header class="project-command-panel"
        <%= tag.attributes(data: product_tour_step_data(tour_group, :project_header)) if tour_group.present? && highlight_header %>>
  <div class="project-command-main">
    <div class="project-command-identity">
      <%= project_integration_icon(@project) %>
      <div class="min-w-0">
        <p class="dashboard-kicker"><%= section_label %></p>
        <h1><%= @project.name %></h1>
        <p>
          <code><%= @project.slug %></code>
          <span><%= @project.integration_label %></span>
          <span><%= @project.owned_by?(current_user) ? "Owner" : "Shared" %></span>
          <% if @project.archived? %>
            <span>Archived</span>
          <% end %>
        </p>
      </div>
    </div>

    <div class="project-command-actions">
      <%= render "projects/nav", tour_group: (highlight_navigation ? tour_group : nil) %>
      <%= tour_help_button if tour_group.present? %>
    </div>
  </div>
</header>

<%= render "projects/archived_notice",
           project: @project,
           show_settings_link: archived_notice_settings_link %>
