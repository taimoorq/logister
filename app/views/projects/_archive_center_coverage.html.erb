<%# locals: (project:, archive_overview:) %>

<section class="mt-5" aria-labelledby="archive-coverage-heading">
  <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h3 id="archive-coverage-heading" class="text-sm font-semibold text-slate-900">Coverage by data type</h3>
      <p class="mt-1 text-xs text-slate-500">Coverage is measured against the latest recorded retention cleanup cutoff.</p>
    </div>
    <%= link_to settings_project_path(project, section: "data", archive_path: "catalog", anchor: "archive-center"),
                class: "btn-ghost inline-flex items-center gap-2" do %>
      <%= app_icon(:archive, css: "h-4 w-4") %>
      <span>View catalog</span>
    <% end %>
  </div>

  <%= responsive_scroll_region(class: "mt-3") do %>
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50">
        <tr>
          <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Data</th>
          <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Retention</th>
          <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Cutoff</th>
          <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Archived through</th>
          <th scope="col" class="px-3 py-2 text-right text-xs font-semibold text-slate-500 uppercase">Candidates</th>
          <th scope="col" class="px-3 py-2 text-right text-xs font-semibold text-slate-500 uppercase">Archived rows</th>
          <th scope="col" class="px-3 py-2 text-right text-xs font-semibold text-slate-500 uppercase">Deleted</th>
          <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Status</th>
          <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Path</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200 bg-white">
        <% archive_overview.coverage_rows.each do |row| %>
          <tr>
            <td class="px-3 py-2 text-slate-900">
              <strong class="block font-semibold"><%= row.label %></strong>
              <span class="block text-xs text-slate-500"><%= row.description %></span>
              <% if row.note.present? %>
                <span class="mt-1 block text-xs text-slate-500"><%= row.note %></span>
              <% end %>
            </td>
            <td class="px-3 py-2 text-slate-600">
              <%= row.retention_forever? ? "Forever" : pluralize(row.retention_days, "day") %>
            </td>
            <td class="px-3 py-2 text-slate-600"><%= row.cutoff_at.present? ? retention_timestamp(row.cutoff_at) : "--" %></td>
            <td class="px-3 py-2 text-slate-600"><%= row.archived_through_at.present? ? retention_timestamp(row.archived_through_at) : "--" %></td>
            <td class="px-3 py-2 text-right text-slate-600"><%= archive_count_or_dash(row.candidate_count) %></td>
            <td class="px-3 py-2 text-right text-slate-600"><%= archive_count_or_dash(row.last_rows) %></td>
            <td class="px-3 py-2 text-right text-slate-600"><%= archive_count_or_dash(row.last_deleted) %></td>
            <td class="px-3 py-2 text-slate-600">
              <span class="inline-flex rounded-full border px-2 py-1 text-xs font-semibold <%= archive_status_badge_class(row.status_tone) %>">
                <%= row.status_label %>
              </span>
            </td>
            <td class="px-3 py-2 text-slate-600">
              <% if row.archive_scope.present? %>
                <%= link_to "Runs",
                            settings_project_path(project, section: "data", archive_path: "catalog", archive_scope: row.archive_scope, anchor: "archive-center"),
                            class: "text-sm font-semibold text-blue-700 hover:text-blue-800" %>
              <% else %>
                <span class="text-slate-400">Policy</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</section>
