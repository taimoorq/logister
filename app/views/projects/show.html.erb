<%# ── Project inbox workbench ──────────────────────────────────────────── %>
<div class="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-6 items-start" data-controller="inbox"
     data-inbox-project-uuid-value="<%= @project.uuid %>">

  <%# ── Left sidebar ──────────────────────────────────────────────────── %>
  <aside class="flex flex-col gap-4 lg:sticky lg:top-24">
    <div class="rounded-xl bg-white border border-slate-200 shadow-sm p-4">
      <h1 class="text-lg font-bold text-slate-900 mb-0.5"><%= @project.name %></h1>
      <p class="text-slate-500 text-sm"><code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-700"><%= @project.slug %></code></p>
    </div>

    <div class="rounded-xl bg-white border border-slate-200 shadow-sm p-3">
      <%= form_with url: project_path(@project), method: :get,
                    data: { turbo_frame: "project_inbox",
                            turbo_action: "advance",
                            inbox_target: "searchForm",
                            action: "submit->inbox#onSearchSubmit" } do |f| %>
        <%= f.hidden_field :filter, value: @filter, data: { inbox_target: "filterField" } %>
        <%= f.search_field :q, value: @query,
                           placeholder: "Search errors…",
                           class: "form-input",
                           data: { action: "input->inbox#debouncedSearch", inbox_target: "searchInput" } %>
      <% end %>
    </div>

    <%= render "inbox_counts",
               project: @project,
               counts:  @counts,
               filter:  @filter,
               query:   @query %>

    <div class="rounded-xl bg-white border border-slate-200 shadow-sm p-4">
      <p class="kicker mb-2">Project</p>
      <%= link_to "API keys & settings", "#project-configuration", class: "sidebar-action-link" %>
      <%= link_to "All projects", projects_path, class: "sidebar-action-link" %>
    </div>
  </aside>

  <%# ── Main workbench area ───────────────────────────────────────────── %>
  <div class="min-w-0 flex flex-col gap-4">

    <%# Inbox list — Turbo Frame %>
    <%= render "inbox_table",
               project:       @project,
               groups:        @groups,
               selected_uuid: @selected_group&.uuid,
               filter:        @filter,
               query:         @query %>

    <%# Error detail — Turbo Frame %>
    <% if @selected_group&.latest_event %>
      <%= render "project_events/event_detail",
                 project:     @project,
                 event:       @selected_group.latest_event,
                 group:       @selected_group,
                 occurrences: @selected_group.error_occurrences.includes(:ingest_event).recent_first.limit(50),
                 related_logs: IngestEvent.related_logs(project: @project, event: @selected_group.latest_event, window: 5.minutes, limit: 50),
                 filter:      @filter,
                 query:       @query %>
    <% else %>
      <%= render "empty_detail" %>
    <% end %>

  </div>
</div>

<%# ── Project configuration (below the fold) ─────────────────────────── %>
<section class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mt-8 mb-4" id="project-configuration">
  <h2 class="text-lg font-bold text-slate-900">Project configuration</h2>
  <span class="text-slate-500 text-sm"><code class="px-1.5 py-0.5 rounded bg-slate-100"><%= @project.slug %></code></span>
</section>

<section class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <% if @project.owned_by?(current_user) %>
    <article class="rounded-xl bg-white border border-slate-200 shadow-sm p-5" id="api-key-form">
      <h3 class="text-base font-bold text-slate-900 mb-3">Create API key</h3>
      <%= form_with model: [@project, ApiKey.new] do |f| %>
        <div class="space-y-3 mb-4">
          <%= f.label :name, "Key label", class: "form-label" %>
          <%= f.text_field :name, required: true, placeholder: "production", class: "form-input" %>
        </div>
        <%= f.submit "Generate key", class: "btn-primary" %>
      <% end %>

      <% if flash[:new_api_key_token].present? %>
        <div class="rounded-lg bg-blue-50 border border-blue-200 px-4 py-3 text-sm text-blue-800 mb-4">New API token: <code class="font-mono text-xs break-all"><%= flash[:new_api_key_token] %></code></div>
      <% end %>

      <h3 class="text-base font-bold text-slate-900 mt-6 mb-3">Existing keys</h3>
      <% if @api_keys.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-slate-200">
            <thead class="bg-slate-50">
              <tr>
                <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Name</th>
                <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Status</th>
                <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Last used</th>
                <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 bg-white">
              <% @api_keys.each do |key| %>
                <tr>
                  <td class="px-3 py-2 text-sm text-slate-900"><%= key.name %></td>
                  <td class="px-3 py-2 text-sm text-slate-600"><%= key.active? ? "active" : "revoked" %></td>
                  <td class="px-3 py-2 text-sm text-slate-600"><%= key.last_used_at ? local_time_tag(key.last_used_at) : "never" %></td>
                  <td class="px-3 py-2"><%= button_to "Revoke", project_api_key_path(@project, key), method: :delete, class: "text-sm font-medium text-red-600 hover:text-red-700" if key.active? %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-slate-600 text-sm">No API keys yet.</p>
      <% end %>
    </article>

    <article class="rounded-xl bg-white border border-slate-200 shadow-sm p-5">
      <h3 class="text-base font-bold text-slate-900 mb-3">Project access</h3>
      <%= form_with model: [@project, ProjectMembership.new] do |f| %>
        <div class="space-y-3 mb-4">
          <%= f.label :email, "Invite by email", class: "form-label" %>
          <%= f.email_field :email, required: true, placeholder: "teammate@example.com", class: "form-input" %>
        </div>
        <%= f.submit "Share project", class: "btn-primary" %>
      <% end %>

      <h3 class="text-base font-bold text-slate-900 mt-6 mb-3">Members</h3>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200">
          <thead class="bg-slate-50">
            <tr>
              <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Email</th>
              <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Role</th>
              <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200 bg-white">
            <tr>
              <td class="px-3 py-2 text-sm text-slate-900"><%= @owner.email %></td>
              <td class="px-3 py-2 text-sm text-slate-600">owner</td>
              <td class="px-3 py-2"></td>
            </tr>
            <% @project_memberships.each do |m| %>
              <tr>
                <td class="px-3 py-2 text-sm text-slate-900"><%= m.user.email %></td>
                <td class="px-3 py-2 text-sm text-slate-600"><%= m.role %></td>
                <td class="px-3 py-2"><%= button_to "Remove", project_project_membership_path(@project, m), method: :delete, class: "text-sm font-medium text-red-600 hover:text-red-700" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </article>

    <article class="rounded-xl bg-white border border-slate-200 shadow-sm p-5 lg:col-span-2">
      <h3 class="text-base font-bold text-slate-900 mb-2">Danger zone</h3>
      <p class="text-slate-600 text-sm mb-3">Deleting a project permanently removes its API keys, memberships, and event data.</p>
      <%= button_to "Delete project",
                    project_path(@project),
                    method: :delete,
                    class: "btn-ghost text-red-600 border-red-300 hover:bg-red-50",
                    form: { data: { turbo_confirm: "Delete this project permanently?" } } %>
    </article>
  <% end %>

  <article class="rounded-xl bg-white border border-slate-200 shadow-sm p-5 <%= 'lg:col-span-2' unless @project.owned_by?(current_user) %>">
    <h3 class="text-base font-bold text-slate-900 mb-2">Ingest endpoint</h3>
    <p class="text-slate-600 text-sm mb-3">POST to <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">/api/v1/ingest_events</code> with header <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">Authorization: Bearer &lt;token&gt;</code>.</p>
    <pre class="rounded-lg bg-slate-900 text-slate-100 p-4 text-sm overflow-x-auto font-mono"><code>{
  "event": {
    "event_type": "error",
    "level": "error",
    "message": "NoMethodError in CheckoutService",
    "fingerprint": "checkout-nomethoderror",
    "occurred_at": "2026-02-14T12:00:00Z",
    "context": { "environment": "production" }
  }
}</code></pre>
  </article>
</section>

<% if @db_stats[:count] > 0 %>
  <section class="rounded-xl bg-white border border-slate-200 shadow-sm p-5 mt-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-4">
      <h2 class="text-lg font-bold text-slate-900">Database load (24h)</h2>
      <p class="text-slate-500 text-sm"><%= @db_stats[:count] %> queries captured</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <article class="rounded-lg bg-slate-50 border border-slate-200 p-4">
        <p class="kicker mb-1">Avg query time</p>
        <p class="text-xl font-bold text-slate-900"><%= @db_stats[:avg_ms] %> ms</p>
      </article>
      <article class="rounded-lg bg-slate-50 border border-slate-200 p-4">
        <p class="kicker mb-1">P95 query time</p>
        <p class="text-xl font-bold text-slate-900"><%= @db_stats[:p95_ms] %> ms</p>
      </article>
    </div>
  </section>
<% end %>

<% if @release_cards.any? %>
  <section class="rounded-xl bg-white border border-slate-200 shadow-sm p-5 mt-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-4">
      <h2 class="text-lg font-bold text-slate-900">Release health</h2>
      <p class="text-slate-500 text-sm">Introduced/regressed issue tracking</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @release_cards.each do |card| %>
        <article class="rounded-lg bg-slate-50 border border-slate-200 p-4">
          <p class="kicker mb-1"><%= card[:release] %></p>
          <p class="text-slate-600 text-sm mb-2">Last seen <%= local_time_tag(card[:last_seen_at]) %></p>
          <div class="text-sm text-slate-700 space-y-1">
            <p><strong><%= card[:total_events] %></strong> total events</p>
            <p><strong><%= card[:error_events] %></strong> error events</p>
            <p><strong><%= card[:introduced_issues] %></strong> introduced issues</p>
            <p><strong><%= card[:regressed_issues] %></strong> regressed issues</p>
          </div>
        </article>
      <% end %>
    </div>
  </section>
<% end %>

<section class="rounded-xl bg-white border border-slate-200 shadow-sm p-5 mt-6">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-4">
    <h2 class="text-lg font-bold text-slate-900">Transactions (24h)</h2>
    <p class="text-slate-500 text-sm"><%= @transaction_stats[:count] %> transactions captured</p>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <article class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="kicker mb-1">P50 latency</p>
      <p class="text-xl font-bold text-slate-900"><%= @transaction_stats[:p50_ms] %> ms</p>
    </article>
    <article class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="kicker mb-1">P95 latency</p>
      <p class="text-xl font-bold text-slate-900"><%= @transaction_stats[:p95_ms] %> ms</p>
    </article>
    <article class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="kicker mb-1">Throughput / min</p>
      <p class="text-xl font-bold text-slate-900"><%= @transaction_stats[:throughput_per_minute] %></p>
    </article>
    <article class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="kicker mb-1">Error rate</p>
      <p class="text-xl font-bold text-slate-900"><%= (@transaction_stats[:error_rate] * 100.0).round(1) %>%</p>
    </article>
    <article class="rounded-lg bg-slate-50 border border-slate-200 p-4">
      <p class="kicker mb-1">Apdex</p>
      <p class="text-xl font-bold text-slate-900"><%= @transaction_stats[:apdex] %></p>
    </article>
  </div>

  <% if @slow_transactions.any? %>
    <div class="overflow-x-auto mt-4">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Transaction</th>
            <th class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Duration</th>
            <th class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Related errors</th>
            <th class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200 bg-white">
          <% @slow_transactions.each do |tx| %>
            <tr>
              <td class="px-3 py-2 text-sm text-slate-900"><%= tx[:transaction_name] %></td>
              <td class="px-3 py-2 text-sm text-slate-700"><%= tx[:duration_ms] %> ms</td>
              <td class="px-3 py-2 text-sm text-slate-700"><%= tx[:related_error_count] %></td>
              <td class="px-3 py-2 text-sm">
                <% if tx[:related_error_event] %>
                  <%= link_to "Open error", project_event_path(@project, tx[:related_error_event]), class: "text-blue-600 hover:underline" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</section>

<section class="rounded-xl bg-white border border-slate-200 shadow-sm p-5 mt-6">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-4">
    <h2 class="text-lg font-bold text-slate-900">Cron and uptime monitors</h2>
    <p class="text-slate-500 text-sm"><%= @missed_check_ins_count %> missed</p>
  </div>
  <% if @check_in_monitors.any? %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Monitor</th>
            <th class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Environment</th>
            <th class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Status</th>
            <th class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Last check-in</th>
            <th class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Expected interval</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200 bg-white">
          <% @check_in_monitors.each do |monitor| %>
            <% monitor_status = monitor.status %>
            <tr>
              <td class="px-3 py-2 text-sm text-slate-900"><%= monitor.slug %></td>
              <td class="px-3 py-2 text-sm text-slate-700"><%= monitor.environment %></td>
              <td class="px-3 py-2 text-sm">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold <%= monitor_status == "ok" ? "bg-blue-50 text-blue-800 border border-blue-200" : "bg-red-50 text-red-800 border border-red-200" %>">
                  <%= monitor_status %>
                </span>
              </td>
              <td class="px-3 py-2 text-sm text-slate-700"><%= monitor.last_check_in_at ? local_time_tag(monitor.last_check_in_at, format: :long) : "never" %></td>
              <td class="px-3 py-2 text-sm text-slate-700"><%= monitor.expected_interval_seconds %>s</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-slate-600 text-sm">No check-ins yet. Send heartbeats to <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">/api/v1/check_ins</code>.</p>
  <% end %>
</section>
