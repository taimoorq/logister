<% tour_group = "project-overview" %>

<%= render layout: "shared/product_tour_frame", locals: { tour_group: tour_group } do %>
<%= render "projects/header", tour_group: tour_group, highlight_header: true, highlight_navigation: true %>

<% open_errors_count = @counts.fetch(:unresolved, 0) %>
<% introduced_today_count = @counts.fetch(:introduced_today, 0) %>
<% all_error_groups_count = @counts.fetch(:all, 0) %>
<% transaction_count = @transaction_stats.fetch(:count, 0).to_i %>
<% db_query_count = @db_stats.fetch(:count, 0).to_i %>
<% request_span_count = @request_span_count_last_24h.to_i %>
<% performance_events_count = transaction_count + db_query_count + request_span_count %>
<% error_rate_percent = (@transaction_stats.fetch(:error_rate, 0.0).to_f * 100.0).round(1) %>

<section class="space-y-6">
  <section class="grid grid-cols-1 gap-4 lg:grid-cols-[minmax(0,1fr)_24rem]"
           aria-label="Recent project signals"
           <%= tag.attributes(data: product_tour_step_data(tour_group, :recent_signals)) %>>
    <section class="project-insights project-overview-insights"
             data-controller="project-insights"
             data-project-insights-payload-value="<%= json_escape(@insights_payload.to_json) %>">
      <%= render "projects/insights_metric_panel",
                 title: "Telemetry timeline",
                 subtitle: "Counts, durations, and custom values in the current scope",
                 header_link: { label: "Insights", url: insights_project_path(@project) } %>
    </section>

    <aside class="dashboard-panel">
      <section aria-label="Project error groups summary">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="dashboard-kicker">Inbox</p>
            <h2 class="text-lg font-bold text-slate-900">Error groups</h2>
          </div>
          <span class="project-overview-icon <%= dashboard_metric_state_class(open_errors_count) %>"><%= app_icon(:warning, css: "w-5 h-5") %></span>
        </div>

        <div class="mt-4 grid grid-cols-3 gap-2 text-sm">
          <%= link_to inbox_project_path(@project, filter: "unresolved"), class: "rounded-lg border border-slate-200 bg-slate-50 p-3 text-slate-600 no-underline hover:bg-white" do %>
            <strong class="block text-xl font-semibold text-slate-900"><%= number_with_delimiter(open_errors_count) %></strong>
            <span class="text-xs font-semibold uppercase text-slate-500">Open</span>
          <% end %>
          <%= link_to inbox_project_path(@project, filter: "introduced_today"), class: "rounded-lg border border-slate-200 bg-slate-50 p-3 text-slate-600 no-underline hover:bg-white" do %>
            <strong class="block text-xl font-semibold text-slate-900"><%= number_with_delimiter(introduced_today_count) %></strong>
            <span class="text-xs font-semibold uppercase text-slate-500">New today</span>
          <% end %>
          <%= link_to inbox_project_path(@project, filter: "all"), class: "rounded-lg border border-slate-200 bg-slate-50 p-3 text-slate-600 no-underline hover:bg-white" do %>
            <strong class="block text-xl font-semibold text-slate-900"><%= number_with_delimiter(all_error_groups_count) %></strong>
            <span class="text-xs font-semibold uppercase text-slate-500">All groups</span>
          <% end %>
        </div>

        <p class="mt-4 text-sm text-slate-600">
          <%= open_errors_count.positive? ? "#{pluralize(open_errors_count, "open error group")} waiting for review." : "No open error groups right now." %>
        </p>

        <%= link_to inbox_project_path(@project), class: "mt-4 inline-flex items-center gap-2 rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 no-underline hover:bg-slate-50" do %>
          <%= app_icon(:folder_open, css: "w-4 h-4") %>
          <span>Open inbox</span>
        <% end %>
      </section>

      <section class="mt-5 border-t border-slate-200 pt-4" aria-label="Project performance summary">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="dashboard-kicker">Performance</p>
            <h3 class="text-base font-bold text-slate-900">Request timing</h3>
          </div>
          <span class="project-overview-icon"><%= app_icon(:dashboard, css: "w-5 h-5") %></span>
        </div>

        <div class="mt-4 grid grid-cols-3 gap-2 text-sm">
          <div class="rounded-lg border border-slate-200 bg-slate-50 p-3">
            <strong class="block text-xl font-semibold text-slate-900"><%= number_with_delimiter(transaction_count) %></strong>
            <span class="text-xs font-semibold uppercase text-slate-500">Transactions</span>
          </div>
          <div class="rounded-lg border border-slate-200 bg-slate-50 p-3">
            <strong class="block text-xl font-semibold text-slate-900"><%= @transaction_stats.fetch(:p95_ms, 0.0) %> ms</strong>
            <span class="text-xs font-semibold uppercase text-slate-500">P95</span>
          </div>
          <div class="rounded-lg border border-slate-200 bg-slate-50 p-3">
            <strong class="block text-xl font-semibold text-slate-900"><%= number_with_delimiter(db_query_count) %></strong>
            <span class="text-xs font-semibold uppercase text-slate-500">DB queries</span>
          </div>
        </div>

        <p class="mt-4 text-sm text-slate-600">
          <%= performance_events_count.positive? ? "#{pluralize(performance_events_count, "performance signal")} collected in the last 24 hours, including #{pluralize(request_span_count, "request span")}. Transaction error rate is #{error_rate_percent}%." : "No spans, transactions, or database timing events in the last 24 hours." %>
        </p>

        <%= link_to performance_project_path(@project), class: "mt-4 inline-flex items-center gap-2 rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 no-underline hover:bg-slate-50" do %>
          <%= app_icon(:dashboard, css: "w-4 h-4") %>
          <span>View performance</span>
        <% end %>
      </section>
    </aside>
  </section>
</section>
<% end %>
