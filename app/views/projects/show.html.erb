<%# ── Project inbox workbench ──────────────────────────────────────────── %>
<div class="project-workbench" data-controller="inbox"
     data-inbox-project-uuid-value="<%= @project.uuid %>">

  <%# ── Left sidebar ──────────────────────────────────────────────────── %>
  <aside class="inbox-sidebar">
    <div class="sidebar-project-header card">
      <h1 class="sidebar-project-name"><%= @project.name %></h1>
      <p class="muted"><code><%= @project.slug %></code></p>
    </div>

    <div class="card sidebar-search-card">
      <%= form_with url: project_path(@project), method: :get,
                    data: { turbo_frame: "project_inbox",
                            turbo_action: "advance",
                            inbox_target: "searchForm",
                            action: "submit->inbox#onSearchSubmit" } do |f| %>
        <%= f.hidden_field :filter, value: @filter, data: { inbox_target: "filterField" } %>
        <%= f.search_field :q, value: @query,
                           placeholder: "Search errors…",
                           class: "inbox-search-input",
                           data: { action: "input->inbox#debouncedSearch", inbox_target: "searchInput" } %>
      <% end %>
    </div>

    <%= render "inbox_counts",
               project: @project,
               counts:  @counts,
               filter:  @filter,
               query:   @query %>

    <div class="card sidebar-links">
      <p class="kicker">Project</p>
      <%= link_to "API keys &amp; settings", "#project-configuration", class: "sidebar-action-link" %>
      <%= link_to "All projects", projects_path, class: "sidebar-action-link" %>
    </div>
  </aside>

  <%# ── Main workbench area ───────────────────────────────────────────── %>
  <div class="workbench-columns">

    <%# Inbox list — Turbo Frame %>
    <%= render "inbox_table",
               project:       @project,
               groups:        @groups,
               selected_uuid: @selected_group&.uuid,
               filter:        @filter,
               query:         @query %>

    <%# Error detail — Turbo Frame %>
    <% if @selected_group&.latest_event %>
      <%= render "project_events/event_detail",
                 project:     @project,
                 event:       @selected_group.latest_event,
                 group:       @selected_group,
                 occurrences: @selected_group.error_occurrences.includes(:ingest_event).recent_first.limit(50),
                 filter:      @filter,
                 query:       @query %>
    <% else %>
      <%= render "empty_detail" %>
    <% end %>

  </div>
</div>

<%# ── Project configuration (below the fold) ─────────────────────────── %>
<section class="section-head" id="project-configuration" style="margin-top:2rem">
  <h2>Project configuration</h2>
  <span class="muted"><code><%= @project.slug %></code></span>
</section>

<section class="project-config-grid">
  <% if @project.owned_by?(current_user) %>
    <article class="card" id="api-key-form">
      <h3>Create API key</h3>
      <%= form_with model: [@project, ApiKey.new] do |f| %>
        <p>
          <%= f.label :name, "Key label" %>
          <%= f.text_field :name, required: true, placeholder: "production" %>
        </p>
        <%= f.submit "Generate key" %>
      <% end %>

      <% if flash[:new_api_key_token].present? %>
        <p class="flash notice">New API token: <code><%= flash[:new_api_key_token] %></code></p>
      <% end %>

      <h3>Existing keys</h3>
      <% if @api_keys.any? %>
        <table>
          <thead>
            <tr><th>Name</th><th>Status</th><th>Last used</th><th></th></tr>
          </thead>
          <tbody>
            <% @api_keys.each do |key| %>
              <tr>
                <td><%= key.name %></td>
                <td><%= key.active? ? "active" : "revoked" %></td>
                <td><%= key.last_used_at&.strftime("%Y-%m-%d %H:%M") || "never" %></td>
                <td><%= button_to "Revoke", project_api_key_path(@project, key), method: :delete if key.active? %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="muted">No API keys yet.</p>
      <% end %>
    </article>

    <article class="card">
      <h3>Project access</h3>
      <%= form_with model: [@project, ProjectMembership.new] do |f| %>
        <p>
          <%= f.label :email, "Invite by email" %>
          <%= f.email_field :email, required: true, placeholder: "teammate@example.com" %>
        </p>
        <%= f.submit "Share project" %>
      <% end %>

      <h3>Members</h3>
      <table>
        <thead>
          <tr><th>Email</th><th>Role</th><th></th></tr>
        </thead>
        <tbody>
          <tr>
            <td><%= @owner.email %></td>
            <td>owner</td>
            <td></td>
          </tr>
          <% @project_memberships.each do |m| %>
            <tr>
              <td><%= m.user.email %></td>
              <td><%= m.role %></td>
              <td><%= button_to "Remove", project_project_membership_path(@project, m), method: :delete %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </article>
  <% end %>

  <article class="card">
    <h3>Ingest endpoint</h3>
    <p>POST to <code>/api/v1/ingest_events</code> with header <code>Authorization: Bearer &lt;token&gt;</code>.</p>
    <pre><code>{
  "event": {
    "event_type": "error",
    "level": "error",
    "message": "NoMethodError in CheckoutService",
    "fingerprint": "checkout-nomethoderror",
    "occurred_at": "2026-02-14T12:00:00Z",
    "context": { "environment": "production" }
  }
}</code></pre>
  </article>
</section>

<% if @db_stats[:count] > 0 %>
  <section class="card">
    <div class="section-head">
      <h2>Database load (24h)</h2>
      <p class="muted"><%= @db_stats[:count] %> queries captured</p>
    </div>
    <div class="stat-strip">
      <article class="card stat-card">
        <p class="kicker">Avg query time</p>
        <p class="stat"><%= @db_stats[:avg_ms] %> ms</p>
      </article>
      <article class="card stat-card">
        <p class="kicker">P95 query time</p>
        <p class="stat"><%= @db_stats[:p95_ms] %> ms</p>
      </article>
    </div>
  </section>
<% end %>
