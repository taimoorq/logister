<%# locals: (tour_group: nil) %>

<nav class="mobile-x-scroll mb-4 flex w-full max-w-full flex-nowrap gap-2 pb-1 text-sm"
     aria-label="Project sections"
     <%= tag.attributes(data: product_tour_step_data(tour_group, :project_navigation)) if tour_group.present? %>>
  <% sections = [
    [ "Home", :home, project_path(@project), "At-a-glance status and next steps" ],
    [ "Inbox", :inbox, inbox_project_path(@project), "Errors that need triage" ],
    [ "Events", :events, activity_project_path(@project), "Logs, metrics, transactions, and check-ins" ],
    [ "Performance", :performance, performance_project_path(@project), "Slow or failing requests and jobs" ],
    [ "Insights", :insights, insights_project_path(@project), "Trends and deeper telemetry exploration" ],
    [ "Deployments", :deployments, deployments_project_path(@project), "Releases, commits, and deploy metadata" ],
    [ "Monitors", :monitors, monitors_project_path(@project), "Scheduled jobs and heartbeat status" ],
    [ "Setup", :setup, setup_project_path(@project), "Connect data and verify instrumentation" ],
    [ "Settings", :settings, settings_project_path(@project), "Project management and preferences" ]
  ] %>

  <% sections.each do |label, icon, path, description| %>
    <% active = request.path == path %>
    <%= link_to path,
                title: description,
                class: "inline-flex h-9 shrink-0 items-center gap-1.5 rounded-md border px-3 text-xs font-semibold no-underline #{active ? 'border-blue-200 bg-blue-50 text-blue-700' : 'border-slate-200 bg-white text-slate-600 hover:border-slate-300 hover:bg-slate-50'}",
                aria: { current: ("page" if active) } do %>
      <%= app_icon(icon, css: "h-3.5 w-3.5 shrink-0") %>
      <span><%= label %></span>
    <% end %>
  <% end %>
</nav>
