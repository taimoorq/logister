<% tour_group = "project-performance" %>

<%= render layout: "shared/product_tour_frame", locals: { tour_group: tour_group } do %>

<%= render "projects/header", tour_group: tour_group %>

<section class="space-y-6">
  <section class="rounded-xl bg-white border border-slate-200 shadow-sm p-5"
           <%= tag.attributes(data: product_tour_step_data(tour_group, :instrumentation_help)) %>>
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
      <div>
        <h2 class="text-lg font-bold text-slate-900">Instrumentation help</h2>
        <p class="text-sm text-slate-600 mt-1">
          Performance views are powered by spans, transactions, and metric events from your
          <%= @project.integration_label %> integration.
        </p>
      </div>
      <%= link_to project_integration_docs_label(@project), project_integration_docs_path(@project), target: "_blank", rel: "noopener noreferrer", class: "inline-flex items-center justify-center rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 no-underline hover:bg-slate-50" %>
    </div>
  </section>

  <%= turbo_frame_tag "performance_request_breakdown",
                      src: performance_request_breakdown_project_path(@project),
                      loading: :lazy do %>
    <section class="rounded-xl bg-white border border-slate-200 shadow-sm p-5">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-4">
        <div>
          <h2 class="text-lg font-bold text-slate-900">Request load breakdown (24h)</h2>
          <p class="text-sm text-slate-600 mt-1">Loading request timings...</p>
        </div>
      </div>
      <div class="performance-breakdown-chart rounded-lg border border-slate-200 bg-slate-50"></div>
    </section>
  <% end %>

  <%= turbo_frame_tag "performance_database_load",
                      src: performance_database_load_project_path(@project),
                      loading: :lazy %>

  <%= turbo_frame_tag "performance_release_health",
                      src: performance_release_health_project_path(@project),
                      loading: :lazy %>

  <%= turbo_frame_tag "performance_transactions",
                      src: performance_transactions_project_path(@project, @transaction_frame_params),
                      loading: :lazy do %>
    <section class="rounded-xl bg-white border border-slate-200 shadow-sm p-5">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-4">
        <h2 class="text-lg font-bold text-slate-900">Transactions (24h)</h2>
        <p class="text-slate-500 text-sm">Loading transactions...</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <% 5.times do %>
          <article class="rounded-lg bg-slate-50 border border-slate-200 p-4">
            <p class="kicker mb-1">Loading</p>
            <p class="text-xl font-bold text-slate-400">--</p>
          </article>
        <% end %>
      </div>
    </section>
  <% end %>
</section>
<% end %>
