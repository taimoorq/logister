<% tour_group = "project-new" %>

<%= render layout: "shared/product_tour_frame",
           locals: { tour_group: tour_group, tag_name: :section, html_options: { class: "max-w-3xl mx-auto" } } do %>
  <div class="rounded-xl bg-white border border-slate-200 shadow-sm p-6 sm:p-8">
    <div class="mb-2 flex items-center justify-between gap-3">
      <h1 class="text-2xl font-bold text-slate-900 inline-flex items-center gap-2"><%= app_icon(:plus, css: "w-6 h-6") %><span>Create a project</span></h1>
      <%= tour_help_button %>
    </div>
    <p class="text-slate-600 text-sm mb-6">A project represents one monitored application and its integration setup.</p>

    <%= form_with model: @project do |f| %>
      <div class="space-y-4">
        <div <%= tag.attributes(data: product_tour_step_data(tour_group, :app_name)) %>>
          <%= f.label :name, class: "form-label" %>
          <%= f.text_field :name, required: true, class: "form-input" %>
        </div>

        <div>
          <%= f.label :description, class: "form-label" %>
          <%= f.text_area :description, rows: 4, class: "form-input" %>
        </div>

        <%= render "integration_picker", f: f, tour_group: tour_group %>

        <fieldset class="border-t border-slate-200 pt-5"
                  <%= tag.attributes(data: product_tour_step_data(tour_group, :retention_policy)) %>>
          <legend class="form-label">Data retention</legend>
          <p class="text-slate-500 text-xs mb-3">
            Set the data lifecycle before sending the first event.
          </p>

          <%= f.fields_for :retention_policy do |retention_fields| %>
            <% retention_policy = retention_fields.object %>

            <% if retention_policy.errors.any? %>
              <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">
                <%= retention_policy.errors.full_messages.to_sentence %>
              </div>
            <% end %>

            <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
              <div>
                <%= retention_fields.label :hot_retention_days, "Event retention", class: "form-label" %>
                <%= retention_fields.select :hot_retention_days,
                                            options_for_select(retention_day_options, retention_policy.hot_retention_days),
                                            {},
                                            required: true,
                                            class: "form-input" %>
                <p class="mt-1 text-xs text-slate-500">Logs, metrics, transactions, and check-ins.</p>
              </div>

              <div>
                <%= retention_fields.label :trace_retention_days, "Trace retention", class: "form-label" %>
                <%= retention_fields.select :trace_retention_days,
                                            options_for_select(retention_day_options, retention_policy.trace_retention_days),
                                            {},
                                            required: true,
                                            class: "form-input" %>
                <p class="mt-1 text-xs text-slate-500">Request span waterfall data.</p>
              </div>

              <div>
                <%= retention_fields.label :error_retention_days, "Closed error retention", class: "form-label" %>
                <%= retention_fields.select :error_retention_days,
                                            options_for_select(retention_day_options(include_forever: true), retention_policy.error_retention_days),
                                            {},
                                            class: "form-input" %>
                <p class="mt-1 text-xs text-slate-500">Resolved, ignored, or archived groups.</p>
              </div>
            </div>

            <div class="mt-4">
              <%= render "projects/retention_archive_controls", form: retention_fields %>
            </div>
          <% end %>
        </fieldset>

        <% if @project.errors.any? %>
          <div class="rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">
            <%= @project.errors.full_messages.to_sentence %>
          </div>
        <% end %>

        <div class="pt-2">
          <%= f.button class: "btn-primary inline-flex items-center gap-2" do %>
            <%= app_icon(:upload) %><span>Create project</span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
