<% open_errors_count = @counts.fetch(:unresolved, 0) %>
<% introduced_today_count = @counts.fetch(:introduced_today, 0) %>
<% events_last_24h = @project_overview.fetch(:events_last_24h, 0) %>
<% unhealthy_monitors_count = @project_overview.fetch(:unhealthy_monitors_count, 0) %>
<% monitors_count = @project_overview.fetch(:monitors_count, 0) %>
<% monitors_label = monitors_count.positive? ? "#{pluralize(monitors_count, "monitor")} tracked" : "No monitors" %>
<% tour_group = "project-errors" %>

<%= render layout: "shared/product_tour_frame", locals: { tour_group: tour_group } do %>

<section class="project-command-panel"
         <%= tag.attributes(data: product_tour_step_data(tour_group, :command_center)) %>>
  <div class="project-command-main">
    <div class="project-command-identity">
      <%= project_integration_icon(@project) %>
      <div>
        <p class="dashboard-kicker">Project inbox</p>
        <h1><%= @project.name %></h1>
        <p>
          <code><%= @project.slug %></code>
          <span><%= @project.integration_label %></span>
          <span><%= @project.owned_by?(current_user) ? "Owner" : "Shared" %></span>
          <% if @project.archived? %>
            <span>Archived</span>
          <% end %>
        </p>
      </div>
    </div>

    <div class="project-command-actions">
      <%= tour_help_button %>
      <details class="project-signals-menu">
        <summary>
          <%= app_icon(:chart, css: "w-4 h-4") %>
          <span>Project signals</span>
        </summary>

        <div class="project-overview-strip" aria-label="Project status">
          <%= link_to inbox_project_path(@project, filter: "unresolved"),
                      class: "project-overview-cell #{dashboard_metric_state_class(open_errors_count)}" do %>
            <span class="project-overview-icon"><%= app_icon(:warning, css: "w-4 h-4") %></span>
            <span>
              <strong><%= number_with_delimiter(open_errors_count) %></strong>
              <span>Open errors</span>
            </span>
          <% end %>

          <%= link_to inbox_project_path(@project, filter: "introduced_today"),
                      class: "project-overview-cell #{dashboard_metric_state_class(introduced_today_count)}" do %>
            <span class="project-overview-icon"><%= app_icon(:calendar, css: "w-4 h-4") %></span>
            <span>
              <strong><%= number_with_delimiter(introduced_today_count) %></strong>
              <span>Introduced today</span>
            </span>
          <% end %>

          <%= link_to activity_project_path(@project), class: "project-overview-cell" do %>
            <span class="project-overview-icon"><%= app_icon(:chart, css: "w-4 h-4") %></span>
            <span>
              <strong><%= number_with_delimiter(events_last_24h) %></strong>
              <span>Events 24h</span>
            </span>
          <% end %>

          <%= link_to monitors_project_path(@project),
                      class: "project-overview-cell #{dashboard_metric_state_class(unhealthy_monitors_count)}" do %>
            <span class="project-overview-icon"><%= app_icon(:check, css: "w-4 h-4") %></span>
            <span>
              <strong><%= number_with_delimiter(unhealthy_monitors_count) %></strong>
              <span><%= monitors_label %></span>
            </span>
          <% end %>
        </div>
      </details>

      <%= link_to project_collection_path(@project), class: "projects-secondary-button" do %>
        <%= app_icon(:projects, css: "w-4 h-4") %>
        <span>All projects</span>
      <% end %>
      <% if @project.owned_by?(current_user) %>
        <%= link_to settings_project_path(@project), class: "projects-secondary-button" do %>
          <%= app_icon(:settings, css: "w-4 h-4") %>
          <span>Settings</span>
        <% end %>
      <% end %>
    </div>
  </div>

  <%= render "nav", tour_group: tour_group %>
</section>

<%= render "projects/archived_notice", project: @project %>

<div class="inbox-workbench min-w-0"
     data-controller="inbox"
     data-inbox-project-uuid-value="<%= @project.uuid %>"
     data-action="turbo:frame-load@document->inbox#onFrameLoaded turbo:before-fetch-request@document->inbox#onBeforeFetch">
  <section class="inbox-workbench-filters"
           aria-label="Inbox filters"
           <%= tag.attributes(data: product_tour_step_data(tour_group, :filters)) %>>
    <div class="inbox-filter-bar">
      <%= form_with url: inbox_project_path(@project), method: :get,
                    class: "inbox-filter-search",
                    data: { turbo_frame: "project_inbox", turbo_action: "advance", inbox_target: "searchForm", action: "submit->inbox#onSearchSubmit" } do |f| %>
        <%= f.hidden_field :filter, value: @filter, data: { inbox_target: "filterField" } %>
        <%= f.hidden_field :assignee, value: @assignee_filter, data: { inbox_target: "assigneeField" } %>
        <%= f.label :q, "Search inbox", class: "kicker inbox-filter-search-label" %>
        <%= f.search_field :q, value: @query, placeholder: "Search errors...",
                           class: "form-input inbox-filter-search-input",
                           data: { action: "input->inbox#debouncedSearch", inbox_target: "searchInput" } %>
      <% end %>

      <%= form_with url: inbox_project_path(@project), method: :get,
                    class: "inbox-assignee-filter",
                    data: { turbo_frame: "project_inbox", turbo_action: "advance", inbox_target: "assigneeForm" } do |f| %>
        <%= f.hidden_field :filter, value: @filter %>
        <%= f.hidden_field :q, value: @query %>
        <%= f.label :assignee, "Assignee", class: "kicker inbox-filter-search-label" %>
        <%= f.select :assignee,
                     inbox_assignee_options(@project, current_user, @assignable_users),
                     { selected: @assignee_filter },
                     class: "form-input inbox-assignee-select",
                     data: { action: "change->inbox#submitAssigneeFilter" } %>
      <% end %>

      <%= render "inbox_counts", project: @project, counts: @counts, filter: @filter, query: @query, assignee: @assignee_filter %>

      <%= link_to "All projects", project_collection_path(@project), class: "inbox-filter-projects-link" %>
    </div>
  </section>

  <section class="inbox-workbench-list"
           data-inbox-target="listPane"
           aria-busy="false"
           <%= tag.attributes(data: product_tour_step_data(tour_group, :groups)) %>>
    <header class="inbox-pane-header">
      <h2 class="text-sm font-semibold text-slate-900 uppercase tracking-[0.14em]">Error groups</h2>
      <p class="text-xs text-slate-500"><%= @groups.size %> shown · newest first</p>
    </header>
    <%= render "inbox_table",
               project:       @project,
               groups:        @groups,
               latest_events: @latest_events,
               group_trends:  @group_trends,
               has_activity_events: @has_activity_events,
               selected_uuid: @selected_group&.uuid,
               filter:        @filter,
               query:         @query,
               assignee:      @assignee_filter %>
  </section>

  <section class="inbox-workbench-detail"
           data-inbox-target="detailPane"
           aria-busy="false"
           <%= tag.attributes(data: product_tour_step_data(tour_group, :detail)) %>>
    <% if @detail_event.present? %>
      <%= render "project_events/event_detail",
                 project:     @project,
                 event:       @detail_event,
                 group:       @detail_group,
                 occurrences: @detail_occurrences,
                 related_logs: @detail_related_logs,
                 filter:      @filter,
                 assignee:    @assignee_filter,
                 assignable_users: @assignable_users,
                 query:       @query,
                 tab:         @tab,
                 frame_scope: params[:frame_scope],
                 frame:       params[:frame] %>
    <% else %>
      <%= render "empty_detail" %>
    <% end %>
  </section>
<% end %>
</div>
