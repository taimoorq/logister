    <article id="integration-guide"
             class="rounded-xl bg-white border border-slate-200 shadow-sm p-5 scroll-mt-24 lg:col-span-2"
             <%= tag.attributes(data: product_tour_step_data(tour_group, :integration_guide)) %>>
      <h2 class="text-base font-bold text-slate-900 mb-2">First event guide</h2>
      <p class="text-slate-600 text-sm mb-4">
        Send one representative event from
        <strong class="text-slate-900"><%= @project.integration_label %></strong>
        before adding optional telemetry.
      </p>

      <details class="mt-4 rounded-lg border border-slate-200 bg-slate-50 p-4">
        <summary class="cursor-pointer text-sm font-semibold text-slate-900">Examples and package links</summary>
        <div class="mt-4">
      <% if @project.integration_cfml? %>
        <div class="space-y-4">
          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-2">First event checklist</h3>
            <ul class="list-disc pl-5 text-sm text-slate-600 space-y-1">
              <li>Wrap <code>cfhttp</code> in a small <code>LogisterClient.cfc</code>.</li>
              <li>Capture one controlled exception from <code>Application.cfc.onError()</code>.</li>
              <li>Verify the grouped issue in the inbox before adding transactions or metrics.</li>
            </ul>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-2">Start with</h3>
            <pre class="<%= project_setup_code_block_class %>"><code>application.logister.sendEvent(
  eventType = "error",
  level = "error",
  message = exception.message ?: "Unhandled CFML exception",
  context = {
    exception = {
      type = exception.type ?: "Exception",
      detail = exception.detail ?: "",
      tagContext = exception.tagContext ?: []
    }
  }
);</code></pre>
          </div>

          <p class="text-sm text-slate-600">
            Full setup guide:
            <%= link_to "CFML integration docs",
                        docs_site_url(:cfml_integration),
                        target: "_blank",
                        rel: "noopener noreferrer",
                        class: "text-blue-600 hover:text-blue-700 no-underline font-semibold" %>.
          </p>
        </div>
      <% elsif @project.integration_python? %>
        <div class="space-y-4">
          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-2">First event checklist</h3>
            <ul class="list-disc pl-5 text-sm text-slate-600 space-y-1">
              <li>Install <code>logister-python</code> in one service or worker.</li>
              <li>Use the matching framework hook for FastAPI, Django, Flask, or Celery.</li>
              <li>Send one controlled exception with environment and release metadata.</li>
              <li>Add logging, spans, deployments, and source context after the first event appears.</li>
            </ul>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-2">Start with</h3>
            <pre class="<%= project_setup_code_block_class %>"><code>pip install 'logister-python[fastapi]'

from logister import LogisterClient, instrument_fastapi

client = LogisterClient.from_env(default_context={"service": "api"})
instrument_fastapi(app, client, capture_spans=True)</code></pre>
          </div>

          <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
            <h3 class="text-sm font-semibold text-slate-900 mb-2">Also supported</h3>
            <p class="text-sm text-slate-600">
              Django, Flask, Celery, logging capture, spans, check-ins, and source context are covered in the Python docs.
            </p>
          </div>

          <p class="text-sm text-slate-600">
            Public setup guide:
            <%= link_to "Python integration docs",
                        docs_site_url(:python_integration),
                        target: "_blank",
                        rel: "noopener noreferrer",
                        class: "text-blue-600 hover:text-blue-700 no-underline font-semibold" %>.
            Package page:
            <%= link_to "PyPI",
                        "https://pypi.org/project/logister-python/",
                        target: "_blank",
                        rel: "noopener noreferrer",
                        class: "text-blue-600 hover:text-blue-700 no-underline font-semibold" %>.
          </p>
        </div>
      <% elsif @project.integration_dotnet? %>
        <div class="space-y-4">
          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-2">First event checklist</h3>
            <ul class="list-disc pl-5 text-sm text-slate-600 space-y-1">
              <li>Install <code>Logister.AspNetCore</code> in one ASP.NET Core app.</li>
              <li>Register the client with <code>AddLogister()</code>.</li>
              <li>Capture one request exception with <code>UseLogisterExceptionReporting()</code>.</li>
              <li>Add transactions, spans, check-ins, deployments, and source context after the first event appears.</li>
            </ul>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-2">Start with ASP.NET Core</h3>
            <pre class="<%= project_setup_code_block_class %>"><code>dotnet add package Logister.AspNetCore

using Logister.AspNetCore;

builder.Services.AddLogister(builder.Configuration, options =>
{
  options.CaptureRequestSpans = true;
  options.Client.Repository = builder.Configuration["LOGISTER_REPOSITORY"];
  options.Client.CommitSha = builder.Configuration["LOGISTER_COMMIT_SHA"];
  options.Client.Branch = builder.Configuration["LOGISTER_BRANCH"];
});

app.UseLogisterExceptionReporting();
app.UseLogisterRequestTransactions();</code></pre>
          </div>

          <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
            <h3 class="text-sm font-semibold text-slate-900 mb-2">Custom metrics</h3>
            <p class="text-sm text-slate-600">
              Use <code>LogisterClient</code> for app-specific metrics, transactions, spans, messages, check-ins, and deployments.
            </p>
          </div>

          <p class="text-sm text-slate-600">
            Public setup guide:
            <%= link_to ".NET integration docs",
                        docs_site_url(:dotnet_integration),
                        target: "_blank",
                        rel: "noopener noreferrer",
                        class: "text-blue-600 hover:text-blue-700 no-underline font-semibold" %>.
            Package pages:
            <%= link_to "Logister",
                        "https://www.nuget.org/packages/Logister",
                        target: "_blank",
                        rel: "noopener noreferrer",
                        class: "text-blue-600 hover:text-blue-700 no-underline font-semibold" %>
            and
            <%= link_to "Logister.AspNetCore",
                        "https://www.nuget.org/packages/Logister.AspNetCore",
                        target: "_blank",
                        rel: "noopener noreferrer",
                        class: "text-blue-600 hover:text-blue-700 no-underline font-semibold" %>.
          </p>
        </div>
      <% elsif @project.integration_javascript? %>
        <div class="space-y-4">
          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-2">First event checklist</h3>
            <ul class="list-disc pl-5 text-sm text-slate-600 space-y-1">
              <li>Install <code>logister-js</code> in one Node, Express, or TypeScript service.</li>
              <li>Use the base client or Express middleware to capture one controlled exception.</li>
              <li>Include environment, release, route, and request identifiers when available.</li>
              <li>Add console capture, browser timing, deployments, and source maps after the first event appears.</li>
            </ul>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-2">Start with Node or Express</h3>
            <pre class="<%= project_setup_code_block_class %>"><code>npm install logister-js

import { LogisterClient } from "logister-js";
import { createLogisterMiddleware, createLogisterErrorHandler } from "logister-js/express";

const client = new LogisterClient({
  apiKey: process.env.LOGISTER_API_KEY,
  baseUrl: "https://your-logister-host.example",
  environment: process.env.LOGISTER_ENVIRONMENT,
  release: process.env.LOGISTER_RELEASE,
  repository: process.env.LOGISTER_REPOSITORY,
  commitSha: process.env.LOGISTER_COMMIT_SHA,
  branch: process.env.LOGISTER_BRANCH
});</code></pre>
          </div>

          <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
            <h3 class="text-sm font-semibold text-slate-900 mb-2">What good JavaScript events should include</h3>
            <p class="text-sm text-slate-600">
              Useful reports include route or screen, release, runtime details, chained causes, and stack context.
