          <p class="text-sm text-slate-600">
            Public setup guide:
            <%= link_to "Cloudflare Pages docs", docs_site_url(:cloudflare_pages_integration), target: "_blank", rel: "noopener noreferrer", class: "text-blue-600 hover:text-blue-700 no-underline font-semibold" %>.
          </p>
        </div>
      <% elsif @project.integration_android? %>
        <div class="space-y-4">
          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-2">First event checklist</h3>
            <ul class="list-disc pl-5 text-sm text-slate-600 space-y-1">
              <li>Install <code>org.logister:logister-android</code> from Maven Central through Gradle.</li>
              <li>Issue short-lived mobile ingest tokens from your backend.</li>
