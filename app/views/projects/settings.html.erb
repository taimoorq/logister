<%= render "projects/header" %>

<section class="space-y-6">
  <% if @project.owned_by?(current_user) %>
    <div class="flex flex-wrap items-center gap-2">
      <%= link_to edit_project_path(@project), class: "btn-ghost inline-flex items-center gap-2" do %>
        <%= app_icon(:pencil) %><span>Edit project</span>
      <% end %>
    </div>
  <% end %>

  <section class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <% if @project.owned_by?(current_user) %>
      <article class="rounded-xl bg-white border border-slate-200 shadow-sm p-5" id="api-key-form">
        <turbo-frame id="project_api_keys">
          <h2 class="text-base font-bold text-slate-900 mb-3">API keys</h2>
          <%= form_with model: [@project, ApiKey.new] do |f| %>
            <div class="space-y-3 mb-4">
              <%= f.label :name, "Key label", class: "form-label" %>
              <%= f.text_field :name, required: true, placeholder: "production", class: "form-input" %>
            </div>
            <%= f.submit "Generate key", class: "btn-primary" %>
          <% end %>

          <div id="api_key_new_token" class="mt-3">
            <% if flash[:new_api_key_token].present? %>
              <div class="rounded-lg bg-blue-50 border border-blue-200 px-4 py-3 text-sm text-blue-800 mb-4">
                New API token:
                <code class="font-mono text-xs break-all"><%= flash[:new_api_key_token] %></code>
                — copy it now; it will not be shown again.
              </div>
            <% end %>
          </div>

          <h3 class="text-sm font-semibold text-slate-900 mt-6 mb-2">Existing keys</h3>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200">
              <thead class="bg-slate-50">
                <tr>
                  <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Name</th>
                  <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Status</th>
                  <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Last used</th>
                  <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase"></th>
                </tr>
              </thead>
              <tbody id="api_keys_tbody" class="divide-y divide-slate-200 bg-white">
                <% if @api_keys.any? %>
                  <% @api_keys.each do |key| %>
                    <%= render "api_keys/row", api_key: key, project: @project %>
                  <% end %>
                <% else %>
                  <tr id="api_keys_empty"><td colspan="4" class="px-3 py-2 text-slate-600 text-sm">No API keys yet.</td></tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </turbo-frame>
      </article>

      <article class="rounded-xl bg-white border border-slate-200 shadow-sm p-5">
        <h2 class="text-base font-bold text-slate-900 mb-3">Project access</h2>
        <%= form_with model: [@project, ProjectMembership.new] do |f| %>
          <div class="space-y-3 mb-4">
            <%= f.label :email, "Invite by email", class: "form-label" %>
            <%= f.email_field :email, required: true, placeholder: "teammate@example.com", class: "form-input" %>
          </div>
          <%= f.submit "Share project", class: "btn-primary" %>
        <% end %>

        <div id="project_membership_message" class="mt-3"></div>

        <h3 class="text-sm font-semibold text-slate-900 mt-6 mb-2">Members</h3>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-slate-200">
            <thead class="bg-slate-50">
              <tr>
                <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Email</th>
                <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Role</th>
                <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase"></th>
              </tr>
            </thead>
            <tbody id="project_memberships_tbody" class="divide-y divide-slate-200 bg-white">
              <tr>
                <td class="px-3 py-2 text-sm text-slate-900"><%= @owner.email %></td>
                <td class="px-3 py-2 text-sm text-slate-600">owner</td>
                <td class="px-3 py-2"></td>
              </tr>
              <% @project_memberships.each do |m| %>
                <%= render "project_memberships/row", membership: m, project: @project %>
              <% end %>
            </tbody>
          </table>
        </div>
      </article>

      <article class="rounded-xl bg-white border border-slate-200 shadow-sm p-5 lg:col-span-2">
        <h2 class="text-base font-bold text-slate-900 mb-2">Danger zone</h2>
        <p class="text-slate-600 text-sm mb-3">
          Deleting a project permanently removes its API keys, memberships, and event data.
        </p>
        <%= button_to "Delete project",
                      project_path(@project),
                      method: :delete,
                      class: "btn-ghost text-red-600 border-red-300 hover:bg-red-50",
                      form: { data: { turbo_confirm: "Delete this project permanently?" } } %>
      </article>
    <% end %>

    <article class="rounded-xl bg-white border border-slate-200 shadow-sm p-5 <%= 'lg:col-span-2' unless @project.owned_by?(current_user) %>">
      <h2 class="text-base font-bold text-slate-900 mb-2">Integration guide</h2>
      <p class="text-slate-600 text-sm mb-4">
        Recommended setup for
        <strong class="text-slate-900"><%= @project.integration_label %></strong>
        projects.
      </p>

      <% if @project.integration_cfml? %>
        <div class="space-y-4">
          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-2">Best path</h3>
            <ul class="list-disc pl-5 text-sm text-slate-600 space-y-1">
              <li>Use a small `LogisterClient.cfc` wrapper around `cfhttp`.</li>
              <li>Capture uncaught exceptions in `Application.cfc.onError()`.</li>
              <li>Send request timings as `transaction` events and query timings as `metric` events.</li>
            </ul>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-2">Start with</h3>
            <pre class="rounded-lg bg-slate-900 text-slate-100 p-4 text-sm overflow-x-auto font-mono"><code>application.logister.sendEvent(
  eventType = "error",
  level = "error",
  message = exception.message ?: "Unhandled CFML exception",
  context = {
    exception = {
      type = exception.type ?: "Exception",
      detail = exception.detail ?: "",
      tagContext = exception.tagContext ?: []
    }
  }
);</code></pre>
          </div>

          <p class="text-sm text-slate-600">
            Full setup guide:
            <%= link_to "CFML integration docs",
                        docs_site_url(:cfml_integration),
                        target: "_blank",
                        rel: "noopener noreferrer",
                        class: "text-blue-600 hover:text-blue-700 no-underline font-semibold" %>.
          </p>
        </div>
      <% elsif @project.integration_python? %>
        <div class="space-y-4">
          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-2">Best path</h3>
            <ul class="list-disc pl-5 text-sm text-slate-600 space-y-1">
              <li>Install <code>logister-python</code> in the Python service or worker you want to monitor.</li>
              <li>Use <code>instrument_fastapi</code> for FastAPI apps, <code>LogisterMiddleware</code> for Django apps, and <code>instrument_celery</code> for Celery workers.</li>
              <li>Send custom metrics, logs, transactions, and check-ins through the shared client when you need deeper app visibility.</li>
            </ul>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-2">Start with</h3>
            <pre class="rounded-lg bg-slate-900 text-slate-100 p-4 text-sm overflow-x-auto font-mono"><code>pip install 'logister-python[fastapi]'

from logister import LogisterClient, instrument_fastapi

client = LogisterClient.from_env(default_context={"service": "api"})
instrument_fastapi(app, client)</code></pre>
          </div>

          <p class="text-sm text-slate-600">
            Public setup guide:
            <%= link_to "Python integration docs",
                        docs_site_url(:python_integration),
                        target: "_blank",
                        rel: "noopener noreferrer",
                        class: "text-blue-600 hover:text-blue-700 no-underline font-semibold" %>.
          </p>
        </div>
      <% elsif @project.integration_javascript? %>
        <div class="space-y-4">
          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-2">Best path</h3>
            <ul class="list-disc pl-5 text-sm text-slate-600 space-y-1">
              <li>Install <code>logister-js</code> in the JavaScript or TypeScript service you want to monitor.</li>
              <li>Use the base client for Node workers and scripts, or add <code>createLogisterMiddleware()</code> and <code>createLogisterErrorHandler()</code> if the app runs on Express.</li>
              <li>Set <code>LOGISTER_RELEASE</code> and include route, browser, component, or request metadata in event context so JavaScript errors are easier to triage.</li>
              <li>If your frontend stack produces bundles, keep source maps available in your release pipeline so minified frames can be traced back to real source.</li>
            </ul>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-2">Start with Node or Express</h3>
            <pre class="rounded-lg bg-slate-900 text-slate-100 p-4 text-sm overflow-x-auto font-mono"><code>npm install logister-js

import { LogisterClient } from "logister-js";
import { createLogisterMiddleware, createLogisterErrorHandler } from "logister-js/express";

const client = new LogisterClient({
  apiKey: process.env.LOGISTER_API_KEY,
  baseUrl: "https://your-logister-host.example",
  environment: process.env.LOGISTER_ENVIRONMENT,
  release: process.env.LOGISTER_RELEASE
});</code></pre>
          </div>

          <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
            <h3 class="text-sm font-semibold text-slate-900 mb-2">What good JavaScript events should include</h3>
            <p class="text-sm text-slate-600">
              The most useful JavaScript reports include the route or screen, release, browser or runtime details, and enough stack context to tell whether source maps are missing or whether the error came from app code, a network edge, or bundled output.
            </p>
          </div>

          <p class="text-sm text-slate-600">
            Public setup guide:
            <%= link_to "JavaScript integration docs",
                        docs_site_url(:javascript_integration),
                        target: "_blank",
                        rel: "noopener noreferrer",
                        class: "text-blue-600 hover:text-blue-700 no-underline font-semibold" %>.
          </p>
        </div>
      <% else %>
        <div class="space-y-4">
          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-2">Best path</h3>
            <ul class="list-disc pl-5 text-sm text-slate-600 space-y-1">
              <li>Install the `logister-ruby` gem in the Rails app you want to monitor.</li>
              <li>Configure the project API token and ingest endpoint in the initializer.</li>
              <li>Enable database metrics if you want query timing in the performance view.</li>
            </ul>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-2">Start with</h3>
            <pre class="rounded-lg bg-slate-900 text-slate-100 p-4 text-sm overflow-x-auto font-mono"><code>gem "logister-ruby", "~> 0.1.2"

Logister.configure do |config|
  config.api_key = "your-project-api-token"
  config.endpoint = "https://your-logister-host.example/api/v1/ingest_events"
end</code></pre>
          </div>

          <p class="text-sm text-slate-600">
            Public setup guide:
            <%= link_to "Ruby integration docs", docs_site_url(:ruby_integration), target: "_blank", rel: "noopener noreferrer", class: "text-blue-600 hover:text-blue-700 no-underline font-semibold" %>.
          </p>
        </div>
      <% end %>
    </article>

    <article class="rounded-xl bg-white border border-slate-200 shadow-sm p-5 <%= 'lg:col-span-2' unless @project.owned_by?(current_user) %>">
      <h2 class="text-base font-bold text-slate-900 mb-2">Ingest endpoint</h2>
      <p class="text-slate-600 text-sm mb-3">
        POST to
        <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">/api/v1/ingest_events</code>
        with header
        <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">Authorization: Bearer &lt;token&gt;</code>.
      </p>
      <p class="text-slate-600 text-sm mb-3">
        This project uses
        <strong class="text-slate-900"><%= @project.integration_label %></strong>.
        <% if @project.integration_cfml? %>
          Send JSON from Lucee or ColdFusion with `cfhttp`.
        <% elsif @project.integration_python? %>
          Use the <code>logister-python</code> client directly, or add the FastAPI, Django, or Celery helpers for framework-aware reporting.
        <% elsif @project.integration_javascript? %>
          Use the <code>logister-js</code> client directly, or add the Express middleware if your JavaScript app runs on Express.
        <% else %>
          Send events through the Ruby gem integration.
        <% end %>
      </p>
      <pre class="rounded-lg bg-slate-900 text-slate-100 p-4 text-sm overflow-x-auto font-mono"><code>{
  "event": {
    "event_type": "error",
    "level": "error",
    "message": "NoMethodError in CheckoutService",
    "fingerprint": "checkout-nomethoderror",
    "occurred_at": "2026-02-14T12:00:00Z",
    "context": { "environment": "production" }
  }
}</code></pre>
    </article>
  </section>
</section>
