                            method: :patch,
                            class: "btn-ghost inline-flex items-center gap-2",
                            form: { data: { turbo_confirm: "Archive this project? Its data will be kept and hidden from active dashboards." } } do %>
                <%= app_icon(:archive, css: "w-4 h-4") %><span>Archive project</span>
              <% end %>
            <% end %>
          </div>

          <div class="rounded-lg border border-red-200 bg-red-50 p-4">
            <h3 class="text-sm font-semibold text-red-900 mb-1">Delete project</h3>
            <p class="text-red-800 text-sm mb-3">
              Deleting a project permanently removes its API keys, memberships, and event data.
            </p>
            <%= button_to "Delete project",
                          project_path(@project),
                          method: :delete,
                          class: "btn-ghost text-red-700 border-red-300 hover:bg-red-100",
                          form: { data: { turbo_confirm: "Delete this project permanently?" } } %>
          </div>
        </div>
      </article>
    <% end %>

    <% if admin_user? %>
      <article class="rounded-xl bg-white border border-slate-200 shadow-sm p-5 lg:col-span-2"
               id="rate-limits">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
          <div>
            <h2 class="text-base font-bold text-slate-900 mb-2">Public API rate limits</h2>
            <p class="text-slate-600 text-sm">
              App-admin override for this project. Blank fields use the global defaults.
            </p>
          </div>
          <div class="rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-600">
            Global default:
            <span class="font-semibold text-slate-900"><%= number_with_delimiter(@public_api_rate_limit_defaults[:requests]) %>/minute</span>
          </div>
        </div>

        <%= form_with model: @project,
                      url: project_rate_limit_path(@project),
                      method: :patch,
                      class: "mt-5 space-y-5" do |f| %>
          <% if @project.errors.any? %>
            <div class="rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">
              <%= @project.errors.full_messages.to_sentence %>
            </div>
          <% end %>

          <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
            <div>
              <%= f.label :public_api_rate_limit_requests_override, "Accepted requests", class: "form-label" %>
              <%= f.number_field :public_api_rate_limit_requests_override,
                                 min: Project::MIN_PUBLIC_API_RATE_LIMIT_REQUESTS,
                                 max: Project::MAX_PUBLIC_API_RATE_LIMIT_REQUESTS,
                                 placeholder: @public_api_rate_limit_defaults[:requests],
                                 class: "form-input" %>
              <p class="mt-1 text-xs text-slate-500">Per API token and endpoint.</p>
            </div>

            <div>
              <%= f.label :public_api_rate_limit_period_seconds_override, "Window seconds", class: "form-label" %>
              <%= f.number_field :public_api_rate_limit_period_seconds_override,
                                 min: Project::MIN_PUBLIC_API_RATE_LIMIT_PERIOD_SECONDS,
                                 max: Project::MAX_PUBLIC_API_RATE_LIMIT_PERIOD_SECONDS,
                                 placeholder: @public_api_rate_limit_defaults[:period_seconds],
                                 class: "form-input" %>
              <p class="mt-1 text-xs text-slate-500">Fixed-window duration.</p>
            </div>

            <div>
              <%= f.label :public_api_auth_failure_rate_limit_requests_override, "Auth failures", class: "form-label" %>
              <%= f.number_field :public_api_auth_failure_rate_limit_requests_override,
                                 min: Project::MIN_PUBLIC_API_RATE_LIMIT_REQUESTS,
                                 max: Project::MAX_PUBLIC_API_RATE_LIMIT_REQUESTS,
                                 placeholder: @public_api_rate_limit_defaults[:auth_failure_requests],
                                 class: "form-input" %>
              <p class="mt-1 text-xs text-slate-500">Per source IP when the token maps to this project.</p>
            </div>
          </div>

          <div class="flex flex-wrap items-center justify-between gap-3">
            <p class="text-xs text-slate-500">
              Global limits still apply to missing or unknown tokens.
            </p>
            <%= f.submit "Save rate limits", class: "btn-primary" %>
          </div>
        <% end %>
      </article>
    <% end %>

    <article id="integration-guide"
             class="rounded-xl bg-white border border-slate-200 shadow-sm p-5 scroll-mt-24 <%= 'lg:col-span-2' unless @project.owned_by?(current_user) %>"
             <%= tag.attributes(data: product_tour_step_data(tour_group, :integration_guide)) %>>
      <h2 class="text-base font-bold text-slate-900 mb-2">Integration guide</h2>
      <p class="text-slate-600 text-sm mb-4">
        Recommended setup for
        <strong class="text-slate-900"><%= @project.integration_label %></strong>
        projects.
      </p>

      <% if @project.integration_cfml? %>
        <div class="space-y-4">
          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-2">Best path</h3>
            <ul class="list-disc pl-5 text-sm text-slate-600 space-y-1">
              <li>Use a small `LogisterClient.cfc` wrapper around `cfhttp`.</li>
              <li>Capture uncaught exceptions in `Application.cfc.onError()`.</li>
              <li>Send request timings as `transaction` events and query timings as `metric` events.</li>
            </ul>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-2">Start with</h3>
            <pre class="<%= project_setup_code_block_class %>"><code>application.logister.sendEvent(
  eventType = "error",
  level = "error",
  message = exception.message ?: "Unhandled CFML exception",
  context = {
    exception = {
      type = exception.type ?: "Exception",
      detail = exception.detail ?: "",
      tagContext = exception.tagContext ?: []
    }
  }
);</code></pre>
          </div>

          <p class="text-sm text-slate-600">
            Full setup guide:
            <%= link_to "CFML integration docs",
                        docs_site_url(:cfml_integration),
                        target: "_blank",
                        rel: "noopener noreferrer",
                        class: "text-blue-600 hover:text-blue-700 no-underline font-semibold" %>.
          </p>
        </div>
      <% elsif @project.integration_python? %>
        <div class="space-y-4">
          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-2">Best path</h3>
            <ul class="list-disc pl-5 text-sm text-slate-600 space-y-1">
              <li>Install <code>logister-python</code> in the Python service or worker you want to monitor.</li>
              <li>Use <code>instrument_fastapi</code> for FastAPI apps, <code>LogisterMiddleware</code> for Django apps, <code>instrument_flask</code> for Flask apps, and <code>instrument_celery</code> for Celery workers.</li>
              <li>Pass <code>capture_spans=True</code> to FastAPI, Django, or Flask instrumentation when you want request load waterfall charts.</li>
              <li>Attach <code>instrument_logging(client, logger=...)</code> if you want standard Python <code>logging</code> records and <code>logger.exception(...)</code> events to flow into Logister automatically.</li>
              <li>Use the shared client for the parts Python teams usually customize after that: business metrics, job heartbeats, and service-specific logs or transactions.</li>
              <li>Set <code>LOGISTER_RELEASE</code>, <code>LOGISTER_REPOSITORY</code>, <code>LOGISTER_COMMIT_SHA</code>, and <code>LOGISTER_BRANCH</code> so source-aware error detail can resolve frames to the right code.</li>
              <li>Call <code>record_deployment()</code> from CI/CD after a deploy so release history links back to the deployed commit.</li>
              <li>Set <code>LOGISTER_CAPTURE_LOCALS=true</code> only when you want frame locals in Python error details.</li>
            </ul>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-2">Start with</h3>
            <pre class="<%= project_setup_code_block_class %>"><code>pip install 'logister-python[fastapi]'

from logister import LogisterClient, instrument_fastapi

client = LogisterClient.from_env(default_context={"service": "api"})
instrument_fastapi(app, client, capture_spans=True)</code></pre>
          </div>

          <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
            <h3 class="text-sm font-semibold text-slate-900 mb-2">Also supported</h3>
            <p class="text-sm text-slate-600">
              Django apps can use <code>LogisterMiddleware</code>, Flask apps can use <code>instrument_flask(app, client)</code>, Celery workers can use <code>instrument_celery()</code> with optional monitor slugs for check-ins, and any Python app can forward built-in logging records with <code>instrument_logging()</code>. Python events now include structured frames, chained exceptions, runtime metadata, and logger metadata when events come through the logging integration.
            </p>
          </div>

          <p class="text-sm text-slate-600">
            Public setup guide:
            <%= link_to "Python integration docs",
                        docs_site_url(:python_integration),
                        target: "_blank",
                        rel: "noopener noreferrer",
                        class: "text-blue-600 hover:text-blue-700 no-underline font-semibold" %>.
            Package page:
            <%= link_to "PyPI",
                        "https://pypi.org/project/logister-python/",
                        target: "_blank",
                        rel: "noopener noreferrer",
                        class: "text-blue-600 hover:text-blue-700 no-underline font-semibold" %>.
          </p>
        </div>
      <% elsif @project.integration_dotnet? %>
        <div class="space-y-4">
          <div>
            <h3 class="text-sm font-semibold text-slate-900 mb-2">Best path</h3>
            <ul class="list-disc pl-5 text-sm text-slate-600 space-y-1">
              <li>Install <code>Logister.AspNetCore</code> in the ASP.NET Core app you want to monitor.</li>
              <li>Use <code>AddLogister(builder.Configuration)</code> to register the client and <code>UseLogisterExceptionReporting()</code> to capture uncaught request exceptions.</li>
              <li>Turn on <code>UseLogisterRequestTransactions()</code> when you want ASP.NET Core request timings in the performance view.</li>
              <li>Set <code>CaptureRequestSpans = true</code> when you want request load waterfall charts.</li>
              <li>Use the shared <code>LogisterClient</code> for business metrics, spans, check-ins, worker errors, and service-specific logs.</li>
              <li>Set <code>LOGISTER_RELEASE</code>, <code>LOGISTER_REPOSITORY</code>, <code>LOGISTER_COMMIT_SHA</code>, and <code>LOGISTER_BRANCH</code> so source-aware error detail can resolve frames to the right code.</li>
              <li>Call <code>RecordDeploymentAsync()</code> from CI/CD after a deploy so release history links back to the deployed commit.</li>
            </ul>
          </div>

