            <h3 class="text-sm font-semibold text-slate-900 mb-2">Start with ASP.NET Core</h3>
            <pre class="<%= project_setup_code_block_class %>"><code>dotnet add package Logister.AspNetCore

using Logister.AspNetCore;

builder.Services.AddLogister(builder.Configuration, options =>
{
  options.CaptureRequestSpans = true;
  options.Client.Repository = builder.Configuration["LOGISTER_REPOSITORY"];
  options.Client.CommitSha = builder.Configuration["LOGISTER_COMMIT_SHA"];
  options.Client.Branch = builder.Configuration["LOGISTER_BRANCH"];
});

app.UseLogisterExceptionReporting();
app.UseLogisterRequestTransactions();</code></pre>
          </div>

