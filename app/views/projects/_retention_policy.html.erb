<%# locals: (project:, retention_policy:, tour_group:) %>
<% retention_settings_collapsed = retention_policy.persisted? && retention_policy.errors.blank? %>
<% archive_summary = if !retention_policy.archive_enabled?
     "Not archiving"
   elsif retention_policy.archive_before_delete?
     "Protected before deletion"
   else
     "Archiving, deletion not protected"
   end %>
<% retention_summary_items = [
  [ "Events", pluralize(retention_policy.hot_retention_days, "day") ],
  [ "Traces", pluralize(retention_policy.trace_retention_days, "day") ],
  [ "Closed errors", retention_policy.error_retention_days.present? ? pluralize(retention_policy.error_retention_days, "day") : "Forever" ],
  [ "Archive", archive_summary ]
] %>
<% retention_form_class = retention_settings_collapsed ? "space-y-5" : "mt-5 space-y-5" %>

<article class="rounded-xl bg-white border border-slate-200 shadow-sm p-5 lg:col-span-2"
         id="retention"
         <%= tag.attributes(data: product_tour_step_data(tour_group, :retention)) if tour_group.present? %>>
  <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <h2 class="text-base font-bold text-slate-900 mb-2">Data retention</h2>
      <p class="text-slate-600 text-sm">
        Keep recent diagnostic data hot, then archive or prune old telemetry by project.
      </p>
    </div>
    <div class="rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-600">
      Last cleanup: <span class="font-semibold text-slate-900"><%= retention_timestamp(retention_policy.last_retention_run_at) %></span>
    </div>
  </div>

  <% retention_form = capture do %>
  <%= form_with model: retention_policy,
                url: project_retention_policy_path(project),
                method: :patch,
                class: retention_form_class do |f| %>
    <% if retention_policy.errors.any? %>
      <div class="rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">
        <%= retention_policy.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
      <div>
        <%= f.label :hot_retention_days, "Event retention", class: "form-label" %>
        <%= f.select :hot_retention_days,
                     options_for_select(retention_day_options, retention_policy.hot_retention_days),
                     {},
                     class: "form-input" %>
        <p class="mt-1 text-xs text-slate-500">Logs, metrics, transactions, and check-ins.</p>
      </div>

      <div>
        <%= f.label :trace_retention_days, "Trace retention", class: "form-label" %>
        <%= f.select :trace_retention_days,
                     options_for_select(retention_day_options, retention_policy.trace_retention_days),
                     {},
                     class: "form-input" %>
        <p class="mt-1 text-xs text-slate-500">Request span waterfall data.</p>
      </div>

      <div>
        <%= f.label :error_retention_days, "Closed error retention", class: "form-label" %>
        <%= f.select :error_retention_days,
                     options_for_select(retention_day_options(include_forever: true), retention_policy.error_retention_days),
                     {},
                     class: "form-input" %>
        <p class="mt-1 text-xs text-slate-500">Resolved, ignored, or archived groups.</p>
      </div>
    </div>

    <%= render "projects/retention_archive_controls", form: f %>

    <div class="flex flex-wrap items-center justify-between gap-3">
      <p class="text-xs text-slate-500">
        Open error groups stay hot. Closed groups follow the retention window you choose.
      </p>
      <%= f.submit "Save retention policy", class: "btn-primary" %>
    </div>
  <% end %>
  <% end %>

  <% if retention_settings_collapsed %>
    <details id="retention-policy-settings" class="group mt-5 rounded-lg border border-slate-200 bg-slate-50">
      <summary class="flex cursor-pointer list-none flex-col gap-3 px-4 py-3 text-left marker:hidden sm:flex-row sm:items-center sm:justify-between">
        <div class="min-w-0">
          <span class="block text-sm font-semibold text-slate-900">Retention settings</span>
          <span class="block text-xs text-slate-500">Saved policy</span>
        </div>

        <div class="flex min-w-0 flex-1 flex-wrap gap-2 sm:justify-end">
          <% retention_summary_items.each do |label, value| %>
            <span class="inline-flex max-w-full items-center gap-1 rounded-full border border-slate-200 bg-white px-2.5 py-1 text-xs text-slate-600">
              <span class="font-semibold text-slate-900"><%= label %>:</span>
              <span class="truncate"><%= value %></span>
            </span>
          <% end %>
        </div>

        <span class="inline-flex shrink-0 items-center gap-1 text-xs font-semibold text-blue-700">
          <span>Edit</span>
          <%= app_icon(:chevron_down, css: "h-3.5 w-3.5 transition-transform group-open:rotate-180") %>
        </span>
      </summary>

      <div class="border-t border-slate-200 bg-white px-4 py-4">
        <%= retention_form %>
      </div>
    </details>
  <% else %>
    <%= retention_form %>
  <% end %>

</article>
