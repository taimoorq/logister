<%# locals: (project:, retention_policy:, recent_archives:, tour_group:) %>

<article class="rounded-xl bg-white border border-slate-200 shadow-sm p-5 lg:col-span-2"
         id="retention"
         <%= tag.attributes(data: product_tour_step_data(tour_group, :retention)) if tour_group.present? %>>
  <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <h2 class="text-base font-bold text-slate-900 mb-2">Data retention</h2>
      <p class="text-slate-600 text-sm">
        Keep recent diagnostic data hot, then archive or prune old telemetry by project.
      </p>
    </div>
    <div class="rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-600">
      Last cleanup: <span class="font-semibold text-slate-900"><%= retention_timestamp(retention_policy.last_retention_run_at) %></span>
    </div>
  </div>

  <%= form_with model: retention_policy,
                url: project_retention_policy_path(project),
                method: :patch,
                class: "mt-5 space-y-5" do |f| %>
    <% if retention_policy.errors.any? %>
      <div class="rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">
        <%= retention_policy.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
      <div>
        <%= f.label :hot_retention_days, "Event retention", class: "form-label" %>
        <%= f.select :hot_retention_days,
                     options_for_select(retention_day_options, retention_policy.hot_retention_days),
                     {},
                     class: "form-input" %>
        <p class="mt-1 text-xs text-slate-500">Logs, metrics, transactions, and check-ins.</p>
      </div>

      <div>
        <%= f.label :trace_retention_days, "Trace retention", class: "form-label" %>
        <%= f.select :trace_retention_days,
                     options_for_select(retention_day_options, retention_policy.trace_retention_days),
                     {},
                     class: "form-input" %>
        <p class="mt-1 text-xs text-slate-500">Request span waterfall data.</p>
      </div>

      <div>
        <%= f.label :error_retention_days, "Closed error retention", class: "form-label" %>
        <%= f.select :error_retention_days,
                     options_for_select(retention_day_options(include_forever: true), retention_policy.error_retention_days),
                     {},
                     class: "form-input" %>
        <p class="mt-1 text-xs text-slate-500">Resolved, ignored, or archived groups.</p>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
      <label class="flex items-start gap-3 rounded-lg border border-slate-200 bg-slate-50 p-4">
        <%= f.check_box :archive_enabled, class: "mt-1 h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500" %>
        <span>
          <span class="block text-sm font-semibold text-slate-900">Enable archive exports</span>
          <span class="block text-sm text-slate-600">Write gzip JSONL exports to the configured archive service.</span>
        </span>
      </label>

      <label class="flex items-start gap-3 rounded-lg border border-slate-200 bg-slate-50 p-4">
        <%= f.check_box :archive_before_delete, class: "mt-1 h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500" %>
        <span>
          <span class="block text-sm font-semibold text-slate-900">Archive before deleting</span>
          <span class="block text-sm text-slate-600">Export matching rows as gzip JSONL before they are removed.</span>
        </span>
      </label>
    </div>

    <div class="flex flex-wrap items-center justify-between gap-3">
      <p class="text-xs text-slate-500">
        Open error groups stay hot. Closed groups follow the retention window you choose.
      </p>
      <%= f.submit "Save retention policy", class: "btn-primary" %>
    </div>
  <% end %>

  <div class="mt-6 border-t border-slate-200 pt-5">
    <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
      <h3 class="text-sm font-semibold text-slate-900">Recent archive runs</h3>
      <p class="text-xs text-slate-500">Last archive: <%= retention_timestamp(retention_policy.last_archive_run_at) %></p>
    </div>

    <% if recent_archives.any? %>
      <%= responsive_scroll_region(class: "mt-3") do %>
        <table class="min-w-full divide-y divide-slate-200 text-sm">
          <thead class="bg-slate-50">
            <tr>
              <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Scope</th>
              <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Before</th>
              <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Rows</th>
              <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Objects</th>
              <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Bytes</th>
              <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200 bg-white">
            <% recent_archives.each do |archive| %>
              <% archive_object_keys = archive.object_keys %>
              <tr>
                <td class="px-3 py-2 text-slate-900"><%= retention_archive_scope_label(archive.scope) %></td>
                <td class="px-3 py-2 text-slate-600"><%= retention_timestamp(archive.before_at) %></td>
                <td class="px-3 py-2 text-slate-600"><%= number_with_delimiter(archive.rows) %></td>
                <td class="px-3 py-2 text-slate-600">
                  <% if archive_object_keys.any? %>
                    <details>
                      <summary class="cursor-pointer text-sm font-semibold text-blue-700 hover:text-blue-800">
                        <%= pluralize(archive_object_keys.size, "object") %>
                      </summary>
                      <div class="mt-2 space-y-1">
                        <% archive_object_keys.each do |object_key| %>
                          <code class="block max-w-96 truncate rounded bg-slate-100 px-2 py-1 text-xs text-slate-700" title="<%= object_key %>"><%= object_key %></code>
                        <% end %>
                      </div>
                    </details>
                  <% else %>
                    <span class="text-slate-400">No objects</span>
                  <% end %>
                </td>
                <td class="px-3 py-2 text-slate-600"><%= number_to_human_size(archive.bytes) %></td>
                <td class="px-3 py-2 text-slate-600">
                  <span class="inline-flex rounded-full px-2 py-1 text-xs font-semibold <%= archive.completed? ? "bg-emerald-50 text-emerald-700" : "bg-red-50 text-red-700" %>">
                    <%= archive.status.humanize %>
                  </span>
                  <% if archive.failed? && archive.error_message.present? %>
                    <p class="mt-1 max-w-80 text-xs text-red-700"><%= archive.error_message %></p>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
    <% else %>
      <div class="mt-3 rounded-lg border border-dashed border-slate-300 bg-slate-50 px-4 py-3 text-sm text-slate-600">
        No archive runs have been recorded for this project yet.
      </div>
    <% end %>
  </div>
</article>
