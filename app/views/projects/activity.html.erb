<% tour_group = "project-activity" %>

<%= render layout: "shared/product_tour_frame", locals: { tour_group: tour_group } do %>

<%= render "projects/header", tour_group: tour_group %>

<section class="space-y-6">
  <section class="rounded-xl bg-white border border-slate-200 shadow-sm p-5"
           <%= tag.attributes(data: product_tour_step_data(tour_group, :events)) %>>
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-4">
      <h2 class="text-lg font-bold text-slate-900">Events</h2>
      <p class="text-slate-500 text-sm">
        Metrics, logs, transactions, and check-ins sent from your
        <%= @project.integration_label %> integration.
        <%= link_to project_integration_docs_label(@project), project_integration_docs_path(@project), target: "_blank", rel: "noopener noreferrer", class: "text-blue-600 hover:underline" %>
      </p>
    </div>

    <%= form_with url: activity_project_path(@project), method: :get, local: true, class: "mb-4 grid grid-cols-1 md:grid-cols-6 gap-3 items-end" do %>
      <div>
        <%= label_tag :event_type, "Type", class: "block text-xs font-semibold text-slate-500 uppercase mb-1" %>
        <%= select_tag :event_type,
                       options_for_select(@activity_event_type_options, @activity_filters[:event_type]),
                       class: "w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-700" %>
      </div>
      <div>
        <%= label_tag :period, "Period", class: "block text-xs font-semibold text-slate-500 uppercase mb-1" %>
        <%= select_tag :period,
                       options_for_select(@activity_period_options, @activity_filters[:period]),
                       class: "w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-700" %>
      </div>
      <div>
        <%= label_tag :environment, "Environment", class: "block text-xs font-semibold text-slate-500 uppercase mb-1" %>
        <%= text_field_tag :environment,
                           @activity_filters[:environment],
                           placeholder: "production",
                           class: "w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-700" %>
      </div>
      <div>
        <%= label_tag :release, "Release", class: "block text-xs font-semibold text-slate-500 uppercase mb-1" %>
        <%= text_field_tag :release,
                           @activity_filters[:release],
                           placeholder: "2026.05.22",
                           class: "w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-700" %>
      </div>
      <div>
        <%= label_tag :q, "Search", class: "block text-xs font-semibold text-slate-500 uppercase mb-1" %>
        <%= text_field_tag :q,
                           @activity_filters[:q],
                           placeholder: "message or name",
                           class: "w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-700" %>
      </div>
      <div class="flex gap-2">
        <%= hidden_field_tag :per_page, @activity_filters[:per_page] %>
        <%= submit_tag "Apply", class: "inline-flex items-center justify-center rounded-md border border-blue-600 bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700" %>
        <% if @activity_filters_active %>
          <%= link_to "Reset", activity_project_path(@project), class: "inline-flex items-center justify-center rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 no-underline hover:bg-slate-50" %>
        <% end %>
      </div>
    <% end %>

    <div class="mb-4 flex flex-wrap items-center gap-2">
      <span class="text-xs font-semibold text-slate-500 uppercase">Rows</span>
      <% @per_page_options.each do |per_page| %>
        <%= link_to per_page,
                    activity_project_path(@project, @activity_filters.merge(per_page: per_page).compact_blank),
                    class: "inline-flex items-center justify-center rounded-md border px-3 py-1.5 text-xs font-semibold no-underline #{@activity_filters[:per_page] == per_page ? 'border-blue-600 bg-blue-50 text-blue-700' : 'border-slate-300 bg-white text-slate-700 hover:bg-slate-50'}" %>
      <% end %>
    </div>

    <% if @activity_events.any? %>
      <%= responsive_scroll_region do %>
        <table class="min-w-full divide-y divide-slate-200" aria-label="Events">
          <thead class="bg-slate-50">
            <tr>
              <th class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Type</th>
              <th class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">When</th>
              <th class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Message</th>
              <th class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200 bg-white">
            <% @activity_events.each do |event| %>
              <% python_log_summary = @project.integration_python? && event.log? ? python_activity_summary(event) : nil %>
              <% javascript_log_summary = @project.integration_javascript? && event.log? ? javascript_activity_summary(event) : nil %>
              <% dotnet_log_summary = @project.integration_dotnet? && event.log? ? dotnet_activity_summary(event) : nil %>
              <tr>
                <td class="px-3 py-2 text-sm">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                    <%= case event.event_type
                        when 'metric' then 'bg-violet-50 text-violet-800 border border-violet-200'
                        when 'log' then 'bg-slate-100 text-slate-700 border border-slate-200'
                        when 'transaction' then 'bg-emerald-50 text-emerald-800 border border-emerald-200'
                        when 'check_in' then 'bg-blue-50 text-blue-800 border border-blue-200'
                        else 'bg-slate-100 text-slate-600 border border-slate-200'
                        end %>">
                    <%= event.event_type %>
                  </span>
                </td>
                <td class="px-3 py-2 text-sm text-slate-700"><%= local_time_tag(event.occurred_at, format: :long) %></td>
                <td class="px-3 py-2 text-sm text-slate-900">
                  <div><%= truncate(event.message.to_s.lines.first, length: 80) %></div>
                  <% if python_log_summary.present? %>
                    <div class="text-xs text-slate-500 mt-1"><%= python_log_summary %></div>
                  <% elsif javascript_log_summary.present? %>
                    <div class="text-xs text-slate-500 mt-1"><%= javascript_log_summary %></div>
                  <% elsif dotnet_log_summary.present? %>
                    <div class="text-xs text-slate-500 mt-1"><%= dotnet_log_summary %></div>
                  <% end %>
                </td>
                <td class="px-3 py-2 text-sm">
                  <%= link_to "View", partitioned_project_event_path(@project, event), class: "text-blue-600 hover:underline" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
      <%= render "shared/cursor_pagination",
                 page: @activity_page,
                 base_path: activity_project_path(@project),
                 params: @activity_filters,
                 page_label: "events" %>
    <% else %>
      <p class="text-slate-600 text-sm">
        <% if @activity_filters_active %>
          No events match these filters.
        <% elsif @project.integration_cfml? %>
          No events yet. Send one controlled CFML exception, then verify it here.
          <%= link_to "CFML integration docs", docs_site_url(:cfml_integration), target: "_blank", rel: "noopener noreferrer", class: "text-blue-600 hover:underline" %>
        <% elsif @project.integration_python? %>
          No events yet. Install <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">logister-python</code>, send one web or worker event, then verify it here.
          <%= link_to "Python integration docs", docs_site_url(:python_integration), target: "_blank", rel: "noopener noreferrer", class: "text-blue-600 hover:underline" %>.
        <% elsif @project.integration_dotnet? %>
          No events yet. Install <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">Logister.AspNetCore</code>, send one request or worker event, then verify it here.
          <%= link_to ".NET integration docs", docs_site_url(:dotnet_integration), target: "_blank", rel: "noopener noreferrer", class: "text-blue-600 hover:underline" %>.
        <% elsif @project.integration_javascript? %>
          No events yet. Install <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">logister-js</code>, send one Node, Express, or worker event, then verify it here.
          <%= link_to "JavaScript integration docs", docs_site_url(:javascript_integration), target: "_blank", rel: "noopener noreferrer", class: "text-blue-600 hover:underline" %>.
        <% elsif @project.integration_cloudflare_pages? %>
          No events yet. Manual telemetry is the working path today; send one metric or deployment record.
          <%= link_to "Cloudflare Pages docs", docs_site_url(:cloudflare_pages_manual_telemetry), target: "_blank", rel: "noopener noreferrer", class: "text-blue-600 hover:underline" %>.
        <% elsif @project.integration_android? %>
          No events yet. Install <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">logister-android</code>, use a backend-issued token, then send one app event.
          <%= link_to "Android SDK docs", docs_site_url(:android_integration), target: "_blank", rel: "noopener noreferrer", class: "text-blue-600 hover:underline" %>.
        <% elsif @project.integration_ios? %>
          No events yet. Add <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">logister-ios</code>, use a backend-issued token, then send one app event.
          <%= link_to "iOS SDK docs", docs_site_url(:ios_integration), target: "_blank", rel: "noopener noreferrer", class: "text-blue-600 hover:underline" %>.
        <% elsif @project.integration_http_api? %>
          No events yet. POST one metric, log, transaction, span, or check-in payload with environment and release when available.
          <%= link_to "HTTP API docs", docs_site_url(:http_api), target: "_blank", rel: "noopener noreferrer", class: "text-blue-600 hover:underline" %>.
        <% else %>
          No events yet. Install <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">logister-ruby</code>, send one known error or metric, then verify it here.
          <%= link_to "Ruby integration docs", docs_site_url(:ruby_integration), target: "_blank", rel: "noopener noreferrer", class: "text-blue-600 hover:underline" %>.
        <% end %>
      </p>
    <% end %>
  </section>
</section>
<% end %>
