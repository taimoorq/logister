<%= render "projects/header" %>

<section class="space-y-6">
  <section class="rounded-xl bg-white border border-slate-200 shadow-sm p-5">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-4">
      <h2 class="text-lg font-bold text-slate-900">Custom events</h2>
      <p class="text-slate-500 text-sm">
        Metrics, logs, transactions, and check-ins sent from your
        <%= @project.integration_label %> integration (last 200).
        <%= link_to project_integration_docs_label(@project), project_integration_docs_path(@project), target: "_blank", rel: "noopener noreferrer", class: "text-blue-600 hover:underline" %>
      </p>
    </div>
    <% if @activity_events.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200">
          <thead class="bg-slate-50">
            <tr>
              <th class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Type</th>
              <th class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">When</th>
              <th class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase">Message</th>
              <th class="px-3 py-2 text-left text-xs font-semibold text-slate-500 uppercase"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200 bg-white">
            <% @activity_events.each do |event| %>
              <% python_log_summary = @project.integration_python? && event.log? ? python_activity_summary(event) : nil %>
              <% javascript_log_summary = @project.integration_javascript? && event.log? ? javascript_activity_summary(event) : nil %>
              <% dotnet_log_summary = @project.integration_dotnet? && event.log? ? dotnet_activity_summary(event) : nil %>
              <tr>
                <td class="px-3 py-2 text-sm">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                    <%= case event.event_type
                        when 'metric' then 'bg-violet-50 text-violet-800 border border-violet-200'
                        when 'log' then 'bg-slate-100 text-slate-700 border border-slate-200'
                        when 'transaction' then 'bg-emerald-50 text-emerald-800 border border-emerald-200'
                        when 'check_in' then 'bg-blue-50 text-blue-800 border border-blue-200'
                        else 'bg-slate-100 text-slate-600 border border-slate-200'
                        end %>">
                    <%= event.event_type %>
                  </span>
                </td>
                <td class="px-3 py-2 text-sm text-slate-700"><%= local_time_tag(event.occurred_at, format: :long) %></td>
                <td class="px-3 py-2 text-sm text-slate-900">
                  <div><%= truncate(event.message.to_s.lines.first, length: 80) %></div>
                  <% if python_log_summary.present? %>
                    <div class="text-xs text-slate-500 mt-1"><%= python_log_summary %></div>
                  <% elsif javascript_log_summary.present? %>
                    <div class="text-xs text-slate-500 mt-1"><%= javascript_log_summary %></div>
                  <% elsif dotnet_log_summary.present? %>
                    <div class="text-xs text-slate-500 mt-1"><%= dotnet_log_summary %></div>
                  <% end %>
                </td>
                <td class="px-3 py-2 text-sm">
                  <%= link_to "View", project_event_path(@project, event), class: "text-blue-600 hover:underline" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-slate-600 text-sm">
        <% if @project.integration_cfml? %>
          No custom events yet. Follow the
          <%= link_to "CFML integration docs", docs_site_url(:cfml_integration), target: "_blank", rel: "noopener noreferrer", class: "text-blue-600 hover:underline" %>
          to send metrics, logs, transactions, and check-ins from your Lucee or ColdFusion app.
        <% elsif @project.integration_python? %>
          No custom events yet. Use
          <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">client.capture_metric()</code>,
          <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">client.capture_message()</code>,
          <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">client.capture_transaction()</code>, or
          <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">client.check_in()</code>
          from <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">logister-python</code>. For Python services, the usual starting point is framework hooks plus worker instrumentation: pair that with <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">instrument_fastapi()</code>, <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">instrument_flask()</code>, or <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">LogisterMiddleware</code> so request-level errors arrive with framework context, and use <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">instrument_logging()</code> if you want standard Python log records to show up automatically. Set <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">LOGISTER_CAPTURE_LOCALS=true</code> if you want frame locals visible in Python error details. You can also start with the
          <%= link_to "Python integration docs", docs_site_url(:python_integration), target: "_blank", rel: "noopener noreferrer", class: "text-blue-600 hover:underline" %>.
        <% elsif @project.integration_dotnet? %>
          No custom events yet. Inject
          <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">LogisterClient</code>
          and call
          <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">CaptureMetricAsync()</code>,
          <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">CaptureMessageAsync()</code>,
          <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">CaptureTransactionAsync()</code>, or
          <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">CheckInAsync()</code>
          from <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">logister-dotnet</code>. For ASP.NET Core apps, start with <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">AddLogister()</code>, <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">UseLogisterExceptionReporting()</code>, and optional request transactions. You can also start with the
          <%= link_to ".NET integration docs", docs_site_url(:dotnet_integration), target: "_blank", rel: "noopener noreferrer", class: "text-blue-600 hover:underline" %>.
        <% elsif @project.integration_javascript? %>
          No custom events yet. Use
          <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">client.captureMetric()</code>,
          <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">client.captureMessage()</code>,
          <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">client.captureTransaction()</code>, or
          <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">client.checkIn()</code>
          from <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">logister-js</code>. For JavaScript and TypeScript services, the usual starting point is request errors plus operational logging: use <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">instrumentConsole()</code> if you want standard console events to show up automatically, and include release, route, browser, and request context when you send events so issues can be grouped with more than a raw stack trace. You can also start with the
          <%= link_to "JavaScript integration docs", docs_site_url(:javascript_integration), target: "_blank", rel: "noopener noreferrer", class: "text-blue-600 hover:underline" %>.
        <% else %>
          No custom events yet. Use
          <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">Logister.report_metric</code>,
          <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">Logister.report_log</code>,
          <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">Logister.report_transaction</code>, or
          <code class="px-1.5 py-0.5 rounded bg-slate-100 text-slate-800">Logister.report_check_in</code>
          from the logister-ruby gem to send events here. You can also start with the
          <%= link_to "Ruby integration docs", docs_site_url(:ruby_integration), target: "_blank", rel: "noopener noreferrer", class: "text-blue-600 hover:underline" %>.
        <% end %>
      </p>
    <% end %>
  </section>
</section>
