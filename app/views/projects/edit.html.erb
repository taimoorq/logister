<% tour_group = "project-edit" %>

<%= render layout: "shared/product_tour_frame", locals: { tour_group: tour_group } do %>

<%= render "header", tour_group: tour_group %>

<section class="max-w-3xl">
  <div class="rounded-xl bg-white border border-slate-200 shadow-sm p-6 sm:p-8"
       <%= tag.attributes(data: product_tour_step_data(tour_group, :edit_project)) %>>
    <div class="mb-2 flex items-center justify-between gap-3">
      <h2 class="text-lg font-bold text-slate-900">Edit project</h2>
      <%= tour_help_button %>
    </div>
    <p class="text-slate-600 text-sm mb-6">Update the project name or description. Project type is locked after creation because collected telemetry is shaped for that integration.</p>

    <%= form_with model: @project, url: project_path(@project), method: :patch do |f| %>
      <div class="space-y-4">
        <div>
          <%= f.label :name, class: "form-label" %>
          <%= f.text_field :name, required: true, class: "form-input" %>
        </div>

        <div>
          <%= f.label :description, class: "form-label" %>
          <%= f.text_area :description, rows: 4, class: "form-input" %>
        </div>

        <div>
          <span class="form-label">Project type</span>
          <div class="mt-2 flex items-start gap-3 rounded-lg border border-slate-200 bg-slate-50 p-4">
            <%= project_integration_icon(@project) %>
            <div>
              <strong class="block text-sm font-semibold text-slate-900"><%= @project.integration_label %></strong>
              <p class="mt-1 text-sm text-slate-600">
                Project type is locked after creation. Create a new project for a different integration.
              </p>
            </div>
          </div>
        </div>

        <% if @project.errors.any? %>
          <div class="rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">
            <%= @project.errors.full_messages.to_sentence %>
          </div>
        <% end %>

        <div class="pt-2 flex flex-wrap gap-2">
          <%= f.button class: "btn-primary inline-flex items-center gap-2" do %>
            <%= app_icon(:check) %><span>Update project</span>
          <% end %>
          <%= link_to "Cancel", settings_project_path(@project, section: "general"), class: "btn-ghost" %>
        </div>
      </div>
    <% end %>
  </div>
</section>
<% end %>
