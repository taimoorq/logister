<% tour_group = "project-edit" %>

<%= render layout: "shared/product_tour_frame", locals: { tour_group: tour_group } do %>

<%= render "header", tour_group: tour_group %>

<section class="max-w-3xl">
  <div class="rounded-xl bg-white border border-slate-200 shadow-sm p-6 sm:p-8"
       <%= tag.attributes(data: product_tour_step_data(tour_group, :edit_project)) %>>
    <div class="mb-2 flex items-center justify-between gap-3">
      <h2 class="text-lg font-bold text-slate-900">Edit project</h2>
      <%= tour_help_button %>
    </div>
    <p class="text-slate-600 text-sm mb-6">Update the project name, description, or integration type.</p>

    <%= form_with model: @project, url: project_path(@project), method: :patch do |f| %>
      <div class="space-y-4">
        <%= render "integration_picker", f: f %>

        <div>
          <%= f.label :name, class: "form-label" %>
          <%= f.text_field :name, required: true, class: "form-input" %>
        </div>

        <div>
          <%= f.label :description, class: "form-label" %>
          <%= f.text_area :description, rows: 4, class: "form-input" %>
        </div>

        <% if @project.errors.any? %>
          <div class="rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">
            <%= @project.errors.full_messages.to_sentence %>
          </div>
        <% end %>

        <div class="pt-2 flex flex-wrap gap-2">
          <%= f.button class: "btn-primary inline-flex items-center gap-2" do %>
            <%= app_icon(:check) %><span>Update project</span>
          <% end %>
          <%= link_to "Cancel", settings_project_path(@project), class: "btn-ghost" %>
        </div>
      </div>
    <% end %>
  </div>
</section>
<% end %>
