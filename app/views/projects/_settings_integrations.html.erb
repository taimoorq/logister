<% if @project.integration_cloudflare_pages? %>
        <article class="rounded-xl bg-white border border-slate-200 shadow-sm p-5 lg:col-span-2"
                 id="platform-integration">
          <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <h2 class="text-base font-bold text-slate-900 mb-2">Cloudflare Pages connection</h2>
              <p class="text-slate-600 text-sm">
                Store Pages identifiers for the future importer. Use manual telemetry for data today.
              </p>
            </div>
            <% if @cloudflare_integration_setting&.configured? %>
              <span class="inline-flex items-center rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-800">Configured</span>
            <% else %>
              <span class="inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs font-semibold text-slate-600">Draft</span>
            <% end %>
          </div>

          <%= form_with model: @cloudflare_integration_setting,
                        url: project_integration_setting_path(@project),
                        method: :patch,
                        class: "mt-5 space-y-5" do |f| %>
            <%= f.hidden_field :provider, value: ProjectIntegrationSetting::PROVIDERS[:cloudflare_pages] %>

            <% if @cloudflare_integration_setting.errors.any? %>
              <div class="rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">
                <%= @cloudflare_integration_setting.errors.full_messages.to_sentence %>
              </div>
            <% end %>

            <label class="flex items-start gap-3">
              <%= f.check_box :enabled, class: "mt-1 h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500" %>
              <span>
                <span class="block text-sm font-semibold text-slate-900">Enable Cloudflare imports</span>
                <span class="block text-sm text-slate-600">Marks this project eligible for future importer jobs.</span>
              </span>
            </label>

            <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
              <div>
                <%= f.label :account_id, "Cloudflare account ID", class: "form-label" %>
                <%= f.text_field :account_id,
                                 placeholder: "a1b2c3d4e5f6",
                                 class: "form-input" %>
              </div>
              <div>
                <%= f.label :external_project_name, "Pages project name", class: "form-label" %>
                <%= f.text_field :external_project_name,
                                 placeholder: "marketing-site",
                                 class: "form-input" %>
              </div>
              <div>
                <%= f.label :external_project_id, "Pages project ID", class: "form-label" %>
                <%= f.text_field :external_project_id,
                                 placeholder: "optional",
                                 class: "form-input" %>
              </div>
              <div>
                <%= f.label :credential_reference, "Credential reference", class: "form-label" %>
                <%= f.text_field :credential_reference,
                                 placeholder: "CLOUDFLARE_API_TOKEN",
                                 class: "form-input" %>
                <p class="mt-1 text-xs text-slate-500">Reference an environment secret or external secret key. Do not paste raw Cloudflare tokens here.</p>
              </div>
            </div>

            <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
              <h3 class="text-sm font-semibold text-slate-900 mb-2">Importer status</h3>
              <p class="text-sm text-slate-600">
                Importer jobs are not live yet. Send Cloudflare Pages metrics or deployment records through manual HTTP telemetry when you need events now.
              </p>
            </div>

            <div class="flex flex-wrap items-center justify-between gap-3">
              <p class="text-xs text-slate-500">
                Last imported:
                <span class="font-semibold text-slate-700"><%= @cloudflare_integration_setting.last_imported_at.present? ? local_time_tag(@cloudflare_integration_setting.last_imported_at, format: :long) : "Never" %></span>
              </p>
              <%= f.submit "Save Cloudflare settings", class: "btn-primary" %>
            </div>
          <% end %>
        </article>
<% end %>

      <% github_connection_healthy = @github_integration_state.app_connection_healthy? %>
      <% github_connection_tone = @github_integration_state.app_connection_tone %>
      <% github_connection_classes = github_integration_status_classes(github_connection_tone) %>

      <article class="rounded-xl bg-white border border-slate-200 shadow-sm p-5 lg:col-span-2"
               id="source-repositories">
        <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
          <div>
            <p class="dashboard-kicker">GitHub Integration</p>
            <h2 class="text-base font-bold text-slate-900 mb-2">GitHub integration dashboard</h2>
            <p class="text-slate-600 text-sm">
              GitHub repositories power source-aware stack frames, CODEOWNERS hints, deployments, and GitHub issue actions.
            </p>
          </div>
          <span class="inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-semibold <%= github_connection_classes %>">
            <%= app_icon(github_connection_healthy ? :check : :warning, css: "h-3.5 w-3.5 shrink-0") %>
            <span><%= @github_integration_state.app_connection_status_label %></span>
          </span>
        </div>

        <section class="mt-5 rounded-lg border p-4 <%= github_connection_classes %>" aria-labelledby="github-health-heading">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div class="min-w-0">
              <div class="flex items-center gap-2">
                <%= app_icon(github_connection_healthy ? :check : :warning, css: "h-4 w-4 shrink-0") %>
                <h3 id="github-health-heading" class="text-sm font-semibold"><%= @github_integration_state.app_connection_label %></h3>
              </div>
              <p class="mt-1 text-sm"><%= @github_integration_state.app_connection_message %></p>
            </div>

            <div class="flex flex-wrap gap-2">
              <% @github_integration_state.dashboard_actions.each do |action| %>
                <% action_href = github_integration_action_href(action) %>
                <% next if action_href.blank? %>
                <%= link_to action_href,
                            class: github_integration_action_classes(action),
                            target: (action.external? ? "_blank" : nil),
                            rel: (action.external? ? "noopener" : nil) do %>
                  <%= app_icon(action.icon, css: "h-4 w-4 shrink-0") %>
                  <span><%= action.label %></span>
                <% end %>
              <% end %>
            </div>
          </div>
        </section>

        <div class="mt-5 grid grid-cols-1 gap-3 sm:grid-cols-2 xl:grid-cols-4">
          <% @github_integration_state.dashboard_metrics.each do |metric| %>
            <div class="min-h-28 rounded-md border-0 border-l-4 p-4 ring-1 <%= github_integration_metric_classes(metric.tone) %>">
              <div class="flex items-center gap-2">
                <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-md bg-white/80 text-slate-700 ring-1 ring-slate-200">
                  <%= app_icon(metric.icon, css: "h-4 w-4") %>
                </span>
                <span class="text-xs font-semibold uppercase text-slate-500"><%= metric.label %></span>
              </div>
              <strong class="mt-3 block text-xl font-bold leading-tight text-slate-900"><%= metric.value %></strong>
              <p class="mt-1 text-xs leading-5 text-slate-600"><%= metric.detail %></p>
            </div>
          <% end %>
        </div>

        <section class="mt-5" aria-labelledby="github-routes-heading">
          <h3 id="github-routes-heading" class="text-sm font-semibold text-slate-900">Management paths</h3>
          <div class="mt-3 grid grid-cols-1 gap-3 lg:grid-cols-3">
            <% @github_integration_state.dashboard_actions.each do |action| %>
              <% action_href = github_integration_action_href(action) %>
              <% next if action_href.blank? %>
              <%= link_to action_href,
                          class: "group flex min-h-28 flex-col justify-between rounded-lg border border-slate-200 bg-slate-50 p-4 no-underline hover:border-blue-200 hover:bg-blue-50/60",
                          target: (action.external? ? "_blank" : nil),
                          rel: (action.external? ? "noopener" : nil) do %>
                <span>
                  <span class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-white text-slate-700 ring-1 ring-slate-200 group-hover:text-blue-700">
                    <%= app_icon(action.icon, css: "h-4 w-4") %>
                  </span>
                  <span class="mt-3 block text-sm font-semibold text-slate-900"><%= action.label %></span>
                  <span class="mt-1 block text-xs leading-5 text-slate-600"><%= action.description %></span>
                </span>
              <% end %>
            <% end %>
          </div>
        </section>

        <details id="github-app-access"
                 class="mt-6 rounded-lg border <%= github_connection_healthy ? "border-slate-200 bg-white" : "border-amber-200 bg-amber-50" %> p-4"
                 <%= "open" if @github_integration_state.app_access_details_open? %>>
          <summary class="flex cursor-pointer list-none flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <h3 class="text-sm font-semibold text-slate-900">GitHub App access</h3>
              <p class="mt-1 text-sm <%= github_connection_healthy ? "text-slate-600" : "text-amber-800" %>">
                <%= @github_integration_state.app_connection_message %>
              </p>
            </div>
            <span class="inline-flex items-center rounded-full border px-3 py-1 text-xs font-semibold <%= github_connection_classes %>">
              <%= @github_integration_state.app_connection_label %> · <%= pluralize(@github_integration_state.linked_installation_count, "linked installation") %>
            </span>
          </summary>

          <div class="mt-4 space-y-5">
            <% if @github_integration_state.app_connection_needs_attention? %>
              <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                <p class="text-sm text-slate-700">
                  <%= link_to "Read setup docs", docs_site_url(:github_app), class: "font-semibold text-blue-700 hover:text-blue-900", target: "_blank", rel: "noopener" %>
                  for the GitHub App callback, webhook, and permission settings.
                </p>
                <% if @github_app_install_url.present? %>
                  <%= link_to @github_app_install_url,
                              class: "inline-flex items-center justify-center gap-2 rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 no-underline hover:bg-slate-50",
                              target: "_blank",
                              rel: "noopener" do %>
                    <%= app_icon(:external, css: "w-4 h-4") %><span>Install GitHub App</span>
                  <% end %>
                <% elsif @github_app_configured %>
                  <span class="text-xs font-semibold text-slate-600">
                    Set <code>LOGISTER_GITHUB_APP_SLUG</code> or <code>LOGISTER_GITHUB_APP_INSTALL_URL</code>.
                  </span>
                <% end %>
              </div>

              <div class="grid grid-cols-1 gap-3 md:grid-cols-4">
                <% @github_app_diagnostics.checks.each do |check| %>
                  <div class="rounded-lg border <%= check.ok? ? "border-emerald-200 bg-emerald-50" : "border-amber-200 bg-white" %> px-3 py-2">
                    <span class="block text-xs font-semibold uppercase <%= check.ok? ? "text-emerald-700" : "text-amber-700" %>"><%= check.label %></span>
                    <span class="mt-1 block text-sm font-semibold <%= check.ok? ? "text-emerald-900" : "text-amber-900" %>"><%= check.ok? ? "Configured" : "Missing" %></span>
                    <span class="mt-1 block text-xs <%= check.ok? ? "text-emerald-700" : "text-amber-800" %>"><%= check.message %></span>
                  </div>
                <% end %>
              </div>

              <div class="grid grid-cols-1 gap-3 lg:grid-cols-2">
                <div>
                  <span class="form-label">GitHub setup callback</span>
                  <code class="mt-1 block break-all rounded-lg border border-slate-200 bg-white px-3 py-2 text-xs text-slate-700"><%= @github_app_diagnostics.setup_url %></code>
                </div>
                <div>
                  <span class="form-label">Webhook URL</span>
                  <code class="mt-1 block break-all rounded-lg border border-slate-200 bg-white px-3 py-2 text-xs text-slate-700"><%= @github_app_diagnostics.webhook_url %></code>
                </div>
              </div>
            <% end %>

            <div id="linked-github-installations" class="space-y-2">
              <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
                <h4 class="text-sm font-semibold text-slate-900">Linked installations</h4>
                <span class="text-xs text-slate-500"><%= pluralize(@github_integration_state.linked_installation_count, "installation") %> linked</span>
              </div>
              <% if @project_github_installations.any? %>
                <% @project_github_installations.each do |project_installation| %>
                  <% installation = project_installation.github_installation %>
                  <div class="flex flex-col gap-3 rounded-lg border border-slate-200 bg-white px-3 py-3 md:flex-row md:items-center md:justify-between">
                    <div>
                      <div class="flex flex-wrap items-center gap-2">
                        <span class="text-sm font-semibold text-slate-900"><%= installation.account_login %></span>
                        <% if installation.available? %>
                          <span class="inline-flex items-center rounded-full border border-emerald-200 bg-emerald-50 px-2 py-0.5 text-xs font-semibold text-emerald-800">Active</span>
                        <% else %>
                          <span class="inline-flex items-center rounded-full border border-amber-200 bg-amber-50 px-2 py-0.5 text-xs font-semibold text-amber-800">Unavailable</span>
                        <% end %>
                      </div>
                      <p class="mt-1 text-xs text-slate-500">
                        <%= pluralize(installation.active_repository_count, "active repository") %>
                        · Last synced:
                        <span class="font-semibold text-slate-700"><%= installation.last_repository_synced_at.present? ? local_time_tag(installation.last_repository_synced_at, format: :long) : "Never" %></span>
                      </p>
                    </div>
                    <div class="flex flex-wrap items-center gap-2">
                      <%= button_to "Sync repositories",
                                    project_github_installation_sync_path(@project, installation),
                                    method: :post,
                                    class: "inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50",
                                    disabled: !installation.available? %>
                      <%= button_to "Unlink",
                                    project_github_installation_link_path(@project, project_installation),
                                    method: :delete,
                                    class: "inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-red-700 hover:bg-red-50 hover:text-red-700",
                                    form: { data: { turbo_confirm: "Unlink #{installation.account_login} from this project?" } } %>
                    </div>
                  </div>
                <% end %>
              <% else %>
                <div class="rounded-lg border border-dashed border-slate-300 bg-white px-4 py-3 text-sm text-slate-600">
                  <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                    <p>No GitHub App installations are linked to this project yet.</p>
                    <% if @github_app_install_url.present? %>
                      <%= link_to @github_app_install_url,
                                  class: "inline-flex items-center justify-center gap-2 rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white no-underline hover:bg-blue-700",
                                  target: "_blank",
                                  rel: "noopener" do %>
                        <%= app_icon(:external, css: "w-4 h-4") %><span>Install GitHub App</span>
                      <% end %>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>

            <% if @linkable_github_installations.any? %>
              <div id="available-github-installations" class="space-y-2 border-t border-slate-200 pt-4">
                <h4 class="text-sm font-semibold text-slate-900">Available installations</h4>
                <% @linkable_github_installations.each do |installation| %>
                  <div class="flex flex-col gap-3 rounded-lg border border-slate-200 bg-white px-3 py-3 md:flex-row md:items-center md:justify-between">
                    <div>
                      <div class="flex flex-wrap items-center gap-2">
                        <span class="text-sm font-semibold text-slate-900"><%= installation.account_login %></span>
                        <span class="text-xs text-slate-500">Installed by <%= installation.installed_by&.email || "unknown user" %></span>
                      </div>
                      <p class="mt-1 text-xs text-slate-500">
                        <%= pluralize(installation.active_repository_count, "active repository") %>
                        · Last synced:
                        <span class="font-semibold text-slate-700"><%= installation.last_repository_synced_at.present? ? local_time_tag(installation.last_repository_synced_at, format: :long) : "Never" %></span>
                      </p>
                    </div>
                    <%= button_to "Link to project",
                                  project_github_installation_links_path(@project),
                                  method: :post,
                                  params: { github_installation: { uuid: installation.uuid } },
                                  class: "inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50",
                                  disabled: !installation.available? %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </details>

        <section id="connected-source-repositories" class="mt-6 space-y-3" aria-labelledby="connected-source-repositories-heading">
          <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <h3 id="connected-source-repositories-heading" class="text-sm font-semibold text-slate-900">Connected repositories</h3>
              <p class="mt-1 text-xs text-slate-500">Manage the repositories this project uses for source lookup and GitHub actions.</p>
            </div>
            <span class="text-xs text-slate-500"><%= pluralize(@github_integration_state.connected_repository_count, "repository") %> connected</span>
          </div>
          <% if @source_repositories.any? %>
            <% @source_repositories.each do |source_repository| %>
              <% github_repository = source_repository.github_repository %>
              <% installation = source_repository.effective_github_installation %>
              <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
                <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                  <div>
                    <div class="flex flex-wrap items-center gap-2">
                      <h4 class="text-sm font-semibold text-slate-900"><%= source_repository.full_name %></h4>
                      <% if github_repository.present? %>
                        <span class="inline-flex items-center rounded-full border border-blue-200 bg-blue-50 px-2 py-0.5 text-xs font-semibold text-blue-800">Synced</span>
                      <% else %>
                        <span class="inline-flex items-center rounded-full border border-slate-200 bg-white px-2 py-0.5 text-xs font-semibold text-slate-600">Manual</span>
                      <% end %>
                      <% if source_repository.configured? %>
                        <span class="inline-flex items-center rounded-full border border-emerald-200 bg-emerald-50 px-2 py-0.5 text-xs font-semibold text-emerald-800">GitHub access ready</span>
                      <% else %>
                        <span class="inline-flex items-center rounded-full border border-amber-200 bg-amber-50 px-2 py-0.5 text-xs font-semibold text-amber-800">Needs setup</span>
                      <% end %>
                    </div>
                    <p class="mt-1 text-xs text-slate-500">
                      <% if source_repository.configured? %>
                        GitHub App can read this repo via <%= installation.account_login %>.
                      <% elsif github_repository.present? %>
                        Waiting for an active GitHub App installation.
                      <% else %>
                        Connect the synced GitHub repository when App access is available.
                      <% end %>
                    </p>
                  </div>
                  <%= button_to "Remove",
                                project_source_repository_path(@project, source_repository),
                                method: :delete,
                                class: "inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-red-700 hover:bg-red-50 hover:text-red-700",
                                form: { data: { turbo_confirm: "Remove #{source_repository.full_name} from this project?" } } %>
                </div>

                <%= form_with model: [ @project, source_repository ],
                              url: project_source_repository_path(@project, source_repository),
                              method: :patch,
                              class: "mt-4 grid grid-cols-1 gap-4 md:grid-cols-4" do |f| %>
                  <%= f.hidden_field :provider, value: source_repository.provider %>
                  <%= f.hidden_field :github_repository_id, value: source_repository.github_repository_id %>
                  <%= f.hidden_field :full_name, value: source_repository.full_name %>
                  <div>
                    <%= f.label :default_branch, "Default branch", class: "form-label" %>
                    <%= f.text_field :default_branch, placeholder: "main", class: "form-input" %>
                  </div>
                  <div>
                    <%= f.label :runtime_root, "Runtime prefix", class: "form-label" %>
                    <%= f.text_field :runtime_root, placeholder: "/app", class: "form-input" %>
                  </div>
                  <div>
                    <%= f.label :source_root, "Source root", class: "form-label" %>
                    <%= f.text_field :source_root, placeholder: "src", class: "form-input" %>
                  </div>
                  <div class="flex items-end justify-between gap-3">
                    <label class="flex items-center gap-2 pb-2">
                      <%= f.check_box :enabled, class: "h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500" %>
                      <span class="text-sm font-semibold text-slate-900">Enabled</span>
                    </label>
                    <%= f.submit "Save", class: "inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
                  </div>
                <% end %>
              </div>
            <% end %>
          <% else %>
            <p class="rounded-lg border border-dashed border-slate-300 bg-slate-50 px-4 py-3 text-sm text-slate-600">
              No source repositories are connected yet.
            </p>
          <% end %>
        </section>

        <details id="available-source-repositories"
                 class="mt-5 rounded-lg border border-slate-200 bg-slate-50 p-4"
                 <%= "open" if @source_repository_form.errors.any? %>>
          <summary class="flex cursor-pointer list-none flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <h3 class="text-sm font-semibold text-slate-900">Show available repositories</h3>
              <p class="mt-1 text-sm text-slate-600">
                <%= pluralize(@github_integration_state.connectable_repository_count, "synced repository") %> can be connected from linked installations.
              </p>
            </div>
            <span class="inline-flex items-center justify-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white">Add repository</span>
          </summary>

          <div class="mt-4 space-y-3">
            <% if @connectable_github_repositories.any? %>
              <% @connectable_github_repositories.each do |repository| %>
                <div class="flex flex-col gap-3 rounded-lg border border-slate-200 bg-white px-4 py-3 md:flex-row md:items-center md:justify-between">
                  <div>
                    <div class="flex flex-wrap items-center gap-2">
                      <span class="text-sm font-semibold text-slate-900"><%= repository.full_name %></span>
                      <span class="inline-flex items-center rounded-full border border-blue-200 bg-blue-50 px-2 py-0.5 text-xs font-semibold text-blue-800"><%= repository.github_installation.account_login %></span>
                    </div>
                    <p class="mt-1 text-xs text-slate-500">
                      Default branch <span class="font-semibold text-slate-700"><%= repository.default_branch || "unknown" %></span>
                    </p>
                  </div>
                  <%= button_to "Connect",
                                project_source_repositories_path(@project),
                                method: :post,
                                params: {
                                  project_source_repository: {
                                    provider: ProjectSourceRepository::PROVIDERS[:github],
                                    github_repository_id: repository.id,
                                    enabled: "1"
                                  }
                                },
                                class: "btn-primary" %>
                </div>
              <% end %>
            <% elsif @available_github_repositories.any? %>
              <p class="rounded-lg border border-dashed border-slate-300 bg-white px-4 py-3 text-sm text-slate-600">
                Every available repository is already connected to this project.
              </p>
            <% else %>
              <p class="rounded-lg border border-dashed border-slate-300 bg-white px-4 py-3 text-sm text-slate-600">
                Link a GitHub App installation and sync repositories before connecting synced repositories.
              </p>
            <% end %>

            <div class="rounded-lg border border-slate-200 bg-white px-4 py-4">
              <div class="mb-4">
                <h4 class="text-sm font-semibold text-slate-900">Manual repository</h4>
                <p class="mt-1 text-sm text-slate-600">Add an owner/repo mapping when a synced repository is not available yet.</p>
              </div>

              <%= form_with model: [ @project, @source_repository_form ],
                            url: project_source_repositories_path(@project),
                            class: "space-y-5" do |f| %>
                <%= f.hidden_field :provider, value: ProjectSourceRepository::PROVIDERS[:github] %>

                <% if @source_repository_form.errors.any? %>
                  <div class="rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">
                    <%= @source_repository_form.errors.full_messages.to_sentence %>
                  </div>
                <% end %>

                <div class="grid grid-cols-1 gap-4 md:grid-cols-4">
                  <div class="md:col-span-2">
                    <%= f.label :full_name, "GitHub repository", class: "form-label" %>
                    <%= f.text_field :full_name,
                                     placeholder: "owner/repository",
                                     class: "form-input" %>
                  </div>
                  <div>
                    <%= f.label :default_branch, "Default branch", class: "form-label" %>
                    <%= f.text_field :default_branch,
                                     placeholder: "main",
                                     class: "form-input" %>
                  </div>
                  <label class="flex items-center gap-2 pt-6">
                    <%= f.check_box :enabled, class: "h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500" %>
                    <span class="text-sm font-semibold text-slate-900">Enabled</span>
                  </label>
                  <div class="md:col-span-2">
                    <%= f.label :runtime_root, "Runtime path prefix", class: "form-label" %>
                    <%= f.text_field :runtime_root,
                                     placeholder: "/app or /workspace/service",
                                     class: "form-input" %>
                    <p class="mt-1 text-xs text-slate-500">Prefix seen in stack frames before the repo-relative path.</p>
                  </div>
                  <div class="md:col-span-2">
                    <%= f.label :source_root, "Repository source root", class: "form-label" %>
                    <%= f.text_field :source_root,
                                     placeholder: "packages/api or src",
                                     class: "form-input" %>
                    <p class="mt-1 text-xs text-slate-500">Optional folder to prepend inside the repository.</p>
                  </div>
                </div>

                <div class="flex flex-wrap items-center justify-between gap-3">
                  <p class="text-xs text-slate-500">
                    Self-hosters configure <code>LOGISTER_GITHUB_APP_ID</code>,
                    <code>LOGISTER_GITHUB_APP_PRIVATE_KEY</code>, and <code>LOGISTER_GITHUB_WEBHOOK_SECRET</code>.
                  </p>
                  <%= f.submit "Add manual repository", class: "btn-primary" %>
                </div>
              <% end %>
            </div>
          </div>
        </details>
      </article>
