<% content_for :title, "#{@project.name} insights" %>
<% tour_group = "project-insights" %>

<%= render layout: "shared/product_tour_frame", locals: { tour_group: tour_group } do %>

<%= render "projects/header", tour_group: tour_group %>

<section class="project-insights"
         data-controller="project-insights"
         data-project-insights-payload-value="<%= json_escape(@insights_payload.to_json) %>">
  <div class="project-insights-lens-bar"
       aria-label="Workbook views"
       <%= tag.attributes(data: product_tour_step_data(tour_group, :lenses)) %>
       style="view-transition-name: insights-lenses; view-transition-class: project-insights-panel;">
    <div class="project-insights-lens-actions" role="tablist" aria-label="Insight view presets">
      <button type="button"
              class="project-insights-lens"
              data-project-insights-target="lensButton"
              data-action="project-insights#selectLens"
              data-lens="overview"
              role="tab">
        <span>Overview</span>
        <small>Activity + quality</small>
      </button>
      <button type="button"
              class="project-insights-lens"
              data-project-insights-target="lensButton"
              data-action="project-insights#selectLens"
              data-lens="health"
              role="tab">
        <span>Health</span>
        <small>Errors + logs</small>
      </button>
      <button type="button"
              class="project-insights-lens"
              data-project-insights-target="lensButton"
              data-action="project-insights#selectLens"
              data-lens="performance"
              role="tab">
        <span>Performance</span>
        <small>Transactions + DB</small>
      </button>
      <button type="button"
              class="project-insights-lens"
              data-project-insights-target="lensButton"
              data-action="project-insights#selectLens"
              data-lens="monitors"
              role="tab">
        <span>Monitors</span>
        <small>Check-ins</small>
      </button>
      <button type="button"
              class="project-insights-lens"
              data-project-insights-target="lensButton"
              data-action="project-insights#selectLens"
              data-lens="custom"
              role="tab">
        <span>Custom</span>
        <small>App metrics</small>
      </button>
    </div>
    <div class="project-insights-toolbar-actions">
      <div class="project-insights-status" data-project-insights-target="status">Waiting for data</div>
      <button type="button" class="project-insights-refresh-button" data-action="project-insights#refreshNow">
        <%= app_icon(:chart, css: "w-4 h-4") %>
        <span>Refresh</span>
      </button>
    </div>
  </div>

  <div class="project-insights-scope"
       aria-label="Dashboard controls"
       <%= tag.attributes(data: product_tour_step_data(tour_group, :scope)) %>
       style="view-transition-name: insights-scope; view-transition-class: project-insights-panel;">
    <div class="project-insights-scope-row">
      <div class="project-insights-time-control">
        <span class="project-insights-control-label">Time range</span>
        <div class="project-insights-control-group" role="group" aria-label="Time range">
          <% @insights_payload[:windows].each do |window| %>
            <button type="button"
                    class="project-insights-segment"
                    data-project-insights-target="windowButton"
                    data-action="project-insights#selectWindow"
                    data-window="<%= window.fetch(:key) %>"
                    aria-pressed="<%= window.fetch(:key) == @insights_payload[:default_window] %>">
              <%= window.fetch(:label) %>
            </button>
          <% end %>
        </div>
      </div>

      <label class="project-insights-select">
        <span>Environment</span>
        <select data-project-insights-target="environmentSelect" data-action="project-insights#changeEnvironment">
          <option value="">All environments</option>
          <% @insights_payload[:environments].each do |environment| %>
            <option value="<%= environment.fetch(:name) %>"><%= environment.fetch(:name) %></option>
          <% end %>
        </select>
      </label>

      <label class="project-insights-select">
        <span>Release</span>
        <select data-project-insights-target="releaseSelect" data-action="project-insights#changeRelease">
          <option value="">All releases</option>
          <% @insights_payload[:releases].each do |release| %>
            <option value="<%= release.fetch(:name) %>"><%= release.fetch(:name) %></option>
          <% end %>
        </select>
      </label>

      <label class="project-insights-select project-insights-refresh">
        <span>Live refresh</span>
        <select data-project-insights-target="refreshSelect" data-action="project-insights#changeRefresh">
          <option value="15">15s</option>
          <option value="30" selected>30s</option>
          <option value="60">60s</option>
          <option value="0">Off</option>
        </select>
      </label>
    </div>

    <div class="project-insights-scope-row project-insights-attribute-row" aria-label="Attribute filters">
      <label class="project-insights-select project-insights-attribute-select">
        <span>Attribute</span>
        <select data-project-insights-target="attributeKeySelect" data-action="project-insights#changeAttributeKey">
          <option value="">Choose attribute</option>
          <% @insights_payload[:attributes].each do |attribute| %>
            <option value="<%= attribute.fetch(:key) %>">
              <%= attribute.fetch(:label) %> (<%= number_with_delimiter(attribute.fetch(:count)) %>)
            </option>
          <% end %>
        </select>
      </label>

      <label class="project-insights-select project-insights-attribute-select">
        <span>Value</span>
        <select data-project-insights-target="attributeValueSelect">
          <option value="">Choose value</option>
        </select>
      </label>

      <button type="button" class="project-insights-filter-add" data-action="project-insights#addAttributeFilter">
        <%= app_icon(:filter, css: "w-4 h-4") %>
        <span>Add filter</span>
      </button>

      <div class="project-insights-filter-list" data-project-insights-target="attributeFilters">
        <span class="project-insights-filter-empty">No attribute filters</span>
      </div>
    </div>
  </div>

  <div class="project-insights-summary"
       data-project-insights-target="summary"
       aria-live="polite"
       <%= tag.attributes(data: product_tour_step_data(tour_group, :summary)) %>
       style="view-transition-name: insights-summary; view-transition-class: project-insights-panel;">
    <div class="project-insights-summary-cell">
      <strong>--</strong>
      <span>Events</span>
    </div>
    <div class="project-insights-summary-cell">
      <strong>--</strong>
      <span>Errors</span>
    </div>
    <div class="project-insights-summary-cell">
      <strong>--</strong>
      <span>Transactions</span>
    </div>
    <div class="project-insights-summary-cell">
      <strong>--</strong>
      <span>Metrics</span>
    </div>
    <div class="project-insights-summary-cell">
      <strong>--</strong>
      <span>Check-ins</span>
    </div>
  </div>

  <div class="project-insights-layout">
    <div class="project-insights-main">
      <%= render "projects/insights_metric_panel",
                 article_data: product_tour_step_data(tour_group, :timeline),
                 article_style: "view-transition-name: insights-timeline; view-transition-class: project-insights-panel;" %>

      <article class="project-insights-panel"
               <%= tag.attributes(data: product_tour_step_data(tour_group, :signal_mix)) %>
               style="view-transition-name: insights-signal-mix; view-transition-class: project-insights-panel;">
        <div class="project-insights-panel-header">
          <div>
            <h3>Signal mix</h3>
            <span>Activity grouped by health, logs, metrics, performance, and check-ins</span>
          </div>
        </div>
        <%= responsive_chart_region do %>
          <%= render "projects/telemetry_timeline_chart",
                     classes: "project-insights-chart",
                     data: { "project-insights-target": "eventChart" },
                     label: "Signal mix timeline for the selected insight scope" %>
        <% end %>
      </article>
    </div>

    <aside class="project-insights-side" aria-label="Investigation tools">
      <article class="project-insights-panel"
               <%= tag.attributes(data: product_tour_step_data(tour_group, :recent_stream)) %>
               style="view-transition-name: insights-recent-stream; view-transition-class: project-insights-panel;">
        <div class="project-insights-panel-header">
          <div>
            <h3>Recent stream</h3>
            <span>Latest matching events</span>
          </div>
        </div>
        <div class="project-insights-recent" data-project-insights-target="recentEvents"></div>
      </article>
    </aside>
  </div>
</section>
<% end %>
