<turbo-frame id="project_inbox" target="error_detail">
  <% group_trends = local_assigns.fetch(:group_trends, {}) %>
  <% latest_events = local_assigns[:latest_events] ||
    IngestEvent.for_partition_references(groups, id_key: :latest_event_id, occurred_at_key: :latest_event_occurred_at).select(:id, :project_id, :uuid, :occurred_at).index_by(&:id) %>
  <% has_activity_events = local_assigns.fetch(:has_activity_events, false) %>
  <% assignee_param = local_assigns[:assignee].presence || "all" %>
  <div class="inbox-table-wrap">
    <% if groups.any? %>
      <div class="inbox-list-scroll">
        <table class="inbox-table inbox-table-compact" aria-label="Error groups">
          <tbody>
            <% groups.each do |group| %>
              <% latest_event = latest_events[group.latest_event_id] %>
              <% row_clickable = latest_event.present? %>
              <% first_seen_words = time_ago_in_words(group.first_seen_at) %>
              <% last_seen_words = time_ago_in_words(group.last_seen_at) %>
              <% trend_points = group_trends.fetch(group.id) { group.trend } %>
              <% trend_total = trend_points.sum %>
              <% trend_tooltip = "7 day trend: #{trend_points.join(", ")} occurrences. #{trend_total} total in the last 7 days." %>
              <% stage = group.stage.presence || "production" %>
              <% severity = group.severity.presence || "error" %>
              <tr id="<%= dom_id(group) %>"
                  class="inbox-row<%= " is-selected" if selected_uuid.present? && selected_uuid == group.uuid %><%= " is-clickable" if row_clickable %>"
                  data-action="<%= row_clickable ? 'click->inbox#openRow keydown.enter->inbox#openRowKey keydown.space->inbox#openRowKey' : '' %>"
                  tabindex="<%= row_clickable ? 0 : -1 %>"
                  aria-selected="<%= selected_uuid.present? && selected_uuid == group.uuid ? "true" : "false" %>"
                  aria-label="<%= row_clickable ? "Open error details for #{group.title}" : nil %>"
                  style="view-transition-name: <%= dom_id(group) %>; view-transition-class: inbox-row;">
                <td class="inbox-error-cell">
                  <% if latest_event %>
                    <%= link_to partitioned_project_event_path(project, latest_event,
                                  filter: filter, q: query, assignee: assignee_param, group_uuid: group.uuid),
                                class: "error-row-link",
                                data: {
                                  turbo_frame: "error_detail",
                                  action: "click->inbox#openDetail"
                                } do %>
                      <span class="error-row-primary">
                        <span class="error-title"><%= group.title %></span>
                        <% if group.subtitle.present? %>
                          <span class="error-subtitle"><%= group.subtitle %></span>
                        <% end %>
                      </span>
                    <% end %>
                  <% else %>
                    <span class="error-row-link error-row-link--orphan">
                      <span class="error-row-primary">
                        <span class="error-title"><%= group.title %></span>
                        <% if group.subtitle.present? %>
                          <span class="error-subtitle"><%= group.subtitle %></span>
                        <% end %>
                      </span>
                    </span>
                  <% end %>
                  <div class="error-meta-row">
                    <span class="error-meta-chip"
                          title="<%= pluralize(group.occurrence_count, "event") %>"
                          aria-label="<%= pluralize(group.occurrence_count, "event") %>">
                      <%= app_icon(:info, css: "inbox-info-icon") %>
                      <strong><%= group.occurrence_count %></strong>
                    </span>
                    <span class="error-meta-chip error-meta-trend"
                          title="<%= trend_tooltip %>"
                          aria-label="<%= trend_tooltip %>">
                      <%= app_icon(:info, css: "inbox-info-icon") %>
                      <span class="error-meta-sparkline"><%= render "shared/widgets/sparkline", points: trend_points, compact: true %></span>
                    </span>
                    <span class="stage-tag stage-tag-compact"
                          title="Stage: <%= stage %>"
                          aria-label="Stage: <%= stage %>"><%= stage %></span>
                    <span class="severity-compact severity-<%= severity %>"
                          title="Severity: <%= severity %>"
                          aria-label="Severity: <%= severity %>">
                      <span class="severity-compact-dot" aria-hidden="true"></span>
                      <span><%= severity %></span>
                    </span>
                    <span class="error-meta-chip error-meta-assignee"
                          title="<%= group.assignee.present? ? "Assigned to #{inbox_assignee_label(project, current_user, group.assignee)}" : "Unassigned" %>"
                          aria-label="<%= group.assignee.present? ? "Assigned to #{inbox_assignee_label(project, current_user, group.assignee)}" : "Unassigned" %>">
                      <%= app_icon(:account, css: "inbox-info-icon") %>
                      <span><%= group.assignee.present? ? (group.assignee.name.presence || group.assignee.email) : "Unassigned" %></span>
                    </span>
                    <span class="error-meta-chip error-meta-time"
                          title="First seen <%= first_seen_words %> ago. Last seen <%= last_seen_words %> ago."
                          aria-label="First seen <%= first_seen_words %> ago. Last seen <%= last_seen_words %> ago.">
                      <%= app_icon(:info, css: "inbox-info-icon") %>
                      <span>last <%= last_seen_words %> ago</span>
                    </span>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="inbox-empty">
        <p class="muted">No errors matching this filter.</p>
        <% if has_activity_events %>
          <p class="muted mt-2">
            This project has logs, metrics, transactions, or check-ins. Those live in
            <%= link_to "Activity", activity_project_path(project), class: "inline-link", data: { turbo_frame: "_top" } %>.
          </p>
        <% end %>
        <% if query.present? %>
          <%= link_to "Clear search",
                      inbox_project_path(project, filter: filter, assignee: assignee_param),
                      class: "inline-link",
                      data: { turbo_frame: "project_inbox" } %>
        <% end %>
      </div>
    <% end %>
  </div>
</turbo-frame>
