<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-bold text-slate-900 inline-flex items-center gap-2"><%= app_icon(:account, css: "w-6 h-6") %><span>User: <%= @user.email %></span></h1>
    <p class="text-slate-600 text-sm mt-1">Manage confirmation, deletion, and inspect ownership/activity.</p>
  </div>
  <%= link_to admin_users_path, class: "btn-ghost shrink-0 inline-flex items-center gap-2" do %>
    <%= app_icon(:arrow_left) %><span>Back to users</span>
  <% end %>
</div>

<div class="rounded-xl bg-white border border-slate-200 shadow-sm p-6 mb-6">
  <p class="kicker mb-3">Profile</p>
  <dl class="event-meta-list mb-4">
    <dt>User ID</dt>
    <dd><code class="text-xs break-all"><%= @user.uuid %></code></dd>
    <dt>Name</dt>
    <dd><%= @user.name.presence || "—" %></dd>
    <dt>Email</dt>
    <dd><%= @user.email %></dd>
    <dt>Joined</dt>
    <dd><%= local_time_tag(@user.created_at, format: :long) %></dd>
    <dt>Status</dt>
    <dd>
      <% if @user.confirmed? %>
        <span class="pill">Confirmed</span>
      <% else %>
        <span class="pill bg-amber-50 text-amber-800 border-amber-200">Pending confirmation</span>
      <% end %>
    </dd>
  </dl>

  <% unless @user.confirmed? %>
    <div class="flex flex-wrap gap-2 mt-4 pt-4 border-t border-slate-200">
      <%= button_to "Confirm user",
                    confirm_admin_user_path(@user),
                    method: :patch,
                    class: "btn-resolve inline-flex items-center gap-2" do %>
        <%= app_icon(:check) %><span>Confirm user</span>
      <% end %>
      <%= button_to "Resend confirmation",
                    resend_confirmation_admin_user_path(@user),
                    method: :post,
                    class: "btn-ghost inline-flex items-center gap-2" do %>
        <%= app_icon(:upload) %><span>Resend confirmation</span>
      <% end %>
    </div>
  <% end %>

  <% if @user != current_user %>
    <div class="flex flex-wrap gap-2 mt-4 pt-4 border-t border-slate-200">
      <%= button_to admin_user_path(@user),
                    method: :delete,
                    class: "btn-ghost text-red-600 border-red-300 hover:bg-red-50 inline-flex items-center gap-2",
                    form: { data: { turbo_confirm: "Delete this user and all owned data permanently?" } } do %>
        <%= app_icon(:warning) %><span>Delete user</span>
      <% end %>
    </div>
  <% end %>
</div>

<div class="rounded-xl bg-white border border-slate-200 shadow-sm p-6 mb-6">
  <p class="kicker mb-3">Owned projects (<%= @owned_projects.size %>)</p>
  <% if @owned_projects.any? %>
    <ul class="space-y-1.5">
      <% @owned_projects.each do |project| %>
        <li><%= link_to project.name, project_path(project), class: "inline-link" %></li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-slate-600 text-sm">No owned projects.</p>
  <% end %>
</div>

<div class="rounded-xl bg-white border border-slate-200 shadow-sm p-6 mb-6">
  <p class="kicker mb-3">Shared projects (<%= @shared_projects.size %>)</p>
  <% if @shared_projects.any? %>
    <ul class="space-y-1.5">
      <% @shared_projects.each do |project| %>
        <li><%= link_to project.name, project_path(project), class: "inline-link" %></li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-slate-600 text-sm">No shared projects.</p>
  <% end %>
</div>

<div class="rounded-xl bg-white border border-slate-200 shadow-sm p-6">
  <p class="kicker mb-3">API keys created by this user (<%= @api_keys.size %>)</p>
  <% if @api_keys.any? %>
    <div class="overflow-x-auto">
      <table class="inbox-table min-w-full">
        <thead>
          <tr>
            <th>Name</th>
            <th>Project</th>
            <th>Created</th>
            <th>Last used</th>
          </tr>
        </thead>
        <tbody>
          <% @api_keys.each do |api_key| %>
            <tr class="inbox-row">
              <td class="text-slate-900"><%= api_key.name %></td>
              <td><%= link_to api_key.project.name, project_path(api_key.project), class: "inline-link" %></td>
              <td class="text-slate-600"><%= local_time_tag(api_key.created_at, format: :date_only) %></td>
              <td class="text-slate-600"><%= api_key.last_used_at ? local_time_tag(api_key.last_used_at) : "Never" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-slate-600 text-sm">No API keys.</p>
  <% end %>
</div>
