<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-bold text-slate-900 inline-flex items-center gap-2"><%= app_icon(:users, css: "w-6 h-6") %><span>User Management</span></h1>
    <p class="text-slate-600 text-sm mt-1">Admin-only list of users signed up for Logister.</p>
  </div>
</div>

<div class="rounded-xl bg-white border border-slate-200 shadow-sm p-4 mb-6">
  <%= form_with url: admin_users_path, method: :get, local: true do |f| %>
    <div class="flex flex-col sm:flex-row gap-3 sm:items-center">
      <%= f.text_field :q,
                       value: @query,
                       placeholder: "Search by email or name",
                       class: "form-input sm:max-w-md" %>
      <div class="flex gap-2">
        <%= f.button class: "btn-primary inline-flex items-center gap-2" do %>
          <%= app_icon(:search) %><span>Search</span>
        <% end %>
        <% if @query.present? %>
          <%= link_to admin_users_path, class: "btn-ghost inline-flex items-center gap-2" do %>
            <%= app_icon(:x) %><span>Clear</span>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<div class="rounded-xl bg-white border border-slate-200 shadow-sm overflow-hidden">
  <div class="overflow-x-auto">
    <table class="inbox-table min-w-full">
      <thead>
        <tr>
          <th>Email</th>
          <th>Name</th>
          <th>Status</th>
          <th>Created</th>
          <th>Projects</th>
          <th>API keys</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr class="inbox-row">
            <td class="text-slate-900"><%= user.email %></td>
            <td class="text-slate-600"><%= user.name.presence || "—" %></td>
            <td>
              <% if user.confirmed? %>
                <span class="pill">Confirmed</span>
              <% else %>
                <span class="pill bg-amber-50 text-amber-800 border-amber-200">Pending</span>
              <% end %>
            </td>
            <td class="text-slate-600"><%= local_time_tag(user.created_at, format: :date_only) %></td>
            <td class="text-slate-600"><%= user.read_attribute(:projects_count).to_i %></td>
            <td class="text-slate-600"><%= user.read_attribute(:api_keys_count).to_i %></td>
            <td><%= link_to admin_user_path(user), class: "inline-link inline-flex items-center gap-1.5" do %><%= app_icon(:settings, css: "w-4 h-4") %><span>Manage</span><% end %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
