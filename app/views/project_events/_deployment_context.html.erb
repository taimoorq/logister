<% deployment_context = local_assigns[:deployment_context] %>
<% deployment = deployment_context&.deployment %>
<% previous_deployment = deployment_context&.previous_deployment %>

<% if deployment.present? %>
  <section class="rounded-lg border border-slate-200 bg-slate-50 p-4">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <p class="kicker">Deployment context</p>
        <p class="mt-1 text-sm font-semibold text-slate-900">
          <% if deployment_context.started_after %>
            This started after deploy <code class="text-xs"><%= deployment.release %></code>
          <% elsif deployment_context.exact_release? %>
            This event matches deploy <code class="text-xs"><%= deployment.release %></code>
          <% else %>
            Nearest deploy <code class="text-xs"><%= deployment.release %></code>
          <% end %>
        </p>
        <p class="mt-1 text-xs text-slate-500">
          <%= deployment.repository_full_name %>
          &middot; <%= deployment.environment %>
          <% if deployment_context.minutes_after.present? %>
            &middot; first seen <%= distance_of_time_in_words(deployment.deployed_at, deployment.deployed_at + deployment_context.minutes_after.minutes) %> later
          <% end %>
        </p>
      </div>

      <div class="flex flex-wrap gap-2">
        <% if deployment.github_commit_url.present? %>
          <%= link_to deployment.short_commit_sha, deployment.github_commit_url, target: "_blank", rel: "noopener noreferrer", class: "inline-flex items-center rounded-md border border-slate-200 bg-white px-2.5 py-1 text-xs font-semibold font-mono text-blue-600 no-underline hover:bg-slate-50" %>
        <% end %>
        <% if deployment.compare_url(previous_deployment).present? %>
          <%= link_to "Compare", deployment.compare_url(previous_deployment), target: "_blank", rel: "noopener noreferrer", class: "inline-flex items-center rounded-md border border-slate-200 bg-white px-2.5 py-1 text-xs font-semibold text-slate-700 no-underline hover:bg-slate-50" %>
        <% end %>
        <% if deployment.pull_request_url.present? %>
          <%= link_to deployment.pull_request_label || "Pull request", deployment.pull_request_url, target: "_blank", rel: "noopener noreferrer", class: "inline-flex items-center rounded-md border border-slate-200 bg-white px-2.5 py-1 text-xs font-semibold text-slate-700 no-underline hover:bg-slate-50" %>
        <% end %>
        <% if deployment.release_url.present? %>
          <%= link_to "Release", deployment.release_url, target: "_blank", rel: "noopener noreferrer", class: "inline-flex items-center rounded-md border border-slate-200 bg-white px-2.5 py-1 text-xs font-semibold text-slate-700 no-underline hover:bg-slate-50" %>
        <% end %>
      </div>
    </div>

    <dl class="mt-3 grid grid-cols-1 gap-3 text-xs sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <dt class="font-semibold uppercase text-slate-500">Commit</dt>
        <dd class="mt-1 font-mono text-slate-700"><%= deployment.short_commit_sha %></dd>
      </div>
      <% if deployment.branch.present? %>
        <div>
          <dt class="font-semibold uppercase text-slate-500">Branch</dt>
          <dd class="mt-1 text-slate-700"><%= deployment.branch %></dd>
        </div>
      <% end %>
      <div>
        <dt class="font-semibold uppercase text-slate-500">Source</dt>
        <dd class="mt-1 text-slate-700"><%= deployment.source %></dd>
      </div>
      <div>
        <dt class="font-semibold uppercase text-slate-500">Deployed</dt>
        <dd class="mt-1 text-slate-700"><%= deployment.deployed_at ? local_time_tag(deployment.deployed_at, format: :long) : local_time_tag(deployment.created_at, format: :long) %></dd>
      </div>
    </dl>
  </section>
<% end %>
