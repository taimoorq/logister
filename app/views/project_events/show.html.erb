<section class="card">
  <div class="section-head">
    <h1>Event details</h1>
    <%= link_to "Back to project", project_path(@project), class: "action-link" %>
  </div>
  <p class="muted">Project: <%= @project.name %> (<code><%= @project.slug %></code>)</p>
</section>

<section class="card">
  <h2><%= @event.event_type %> event</h2>
  <p><strong>Occurred at:</strong> <%= @event.occurred_at&.strftime("%Y-%m-%d %H:%M:%S %Z") %></p>
  <p><strong>Level:</strong> <%= @event.level.presence || "-" %></p>
  <p><strong>Fingerprint:</strong> <code><%= @event.fingerprint.presence || "-" %></code></p>
  <p><strong>Event ID:</strong> <code><%= @event.uuid %></code></p>
</section>

<section class="card">
  <h2>Message</h2>
  <pre><code><%= @event.message %></code></pre>
</section>

<% exception_data = @event.context.is_a?(Hash) ? (@event.context["exception"] || @event.context[:exception]) : nil %>
<% if exception_data.is_a?(Hash) %>
  <section class="card">
    <h2>Exception</h2>
    <p><strong>Class:</strong> <%= exception_data["class"].presence || exception_data[:class].presence || "-" %></p>
    <p><strong>Message:</strong> <%= exception_data["message"].presence || exception_data[:message].presence || "-" %></p>

    <% backtrace = exception_data["backtrace"] || exception_data[:backtrace] %>
    <% if backtrace.respond_to?(:any?) && backtrace.any? %>
      <h3>Backtrace</h3>
      <pre><code><%= Array(backtrace).join("\n") %></code></pre>
    <% end %>
  </section>
<% end %>

<section class="card">
  <h2>Context (raw)</h2>
  <pre><code><%= JSON.pretty_generate(@event.context || {}) rescue @event.context.to_s %></code></pre>
</section>
