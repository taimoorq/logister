<%# ── Standalone event detail page ──────────────────────────────────────── %>
<% exception_data = event_exception_data(@event) %>
<% backtrace = event_backtrace(exception_data) %>
<% active_tab = @tab.presence_in(%w[context stacktrace occurrences related_logs]) || "stacktrace" %>
<% stacktrace_tab_label = event_stacktrace_tab_label(@project, @event) %>
<% stacktrace_partial = event_stacktrace_partial(@project, @event) %>
<% request_details = request_context_details(@event) %>
<% parsed_frames = parse_backtrace_frames(backtrace) %>
<% app_frames = parsed_frames.select { |frame| frame[:application_frame] } %>
<% frame_scope = params[:frame_scope].presence_in(%w[application all]) || "application" %>
<% visible_frames = (frame_scope == "application" && app_frames.any?) ? app_frames : parsed_frames %>
<% selected_frame_index = params[:frame].to_i %>
<% selected_frame_index = 0 if selected_frame_index.negative? || selected_frame_index >= visible_frames.size %>
<% selected_frame = visible_frames[selected_frame_index] %>
<% source_excerpt = source_excerpt_for_frame(selected_frame) %>
<% local_variables = event_local_variables(exception_data) %>
<% instance_variables = event_instance_variables(exception_data) %>

<div class="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-6 items-start">

  <%# ── Left sidebar ──────────────────────────────────────────────────────── %>
  <aside class="flex flex-col gap-4 lg:sticky lg:top-24">
    <%# Breadcrumb %>
    <nav class="event-breadcrumb">
      <%= link_to projects_path, class: "breadcrumb-link" do %>
        <span class="inline-flex items-center gap-1.5"><%= app_icon(:arrow_left, css: "w-4 h-4") %><span>All projects</span></span>
      <% end %>
      <%= link_to @project.name, project_path(@project), class: "breadcrumb-link" %>
    </nav>

    <%# Group summary card (if grouped) %>
    <% if @group %>
      <div class="card event-group-card">
        <p class="kicker">Error group</p>
        <p class="event-group-title"><%= truncate(@group.title, length: 80) %></p>
        <% if @group.subtitle.present? %>
          <p class="text-slate-600 text-sm mt-1"><%= @group.subtitle %></p>
        <% end %>

        <div class="event-group-stats">
          <div>
            <span class="kicker">Status</span>
            <span class="detail-status-badge status-<%= @group.status %>"><%= @group.status.upcase %></span>
          </div>
          <div>
            <span class="kicker">Occurrences</span>
            <strong><%= @group.occurrence_count %></strong>
          </div>
          <div>
            <span class="kicker">First seen</span>
            <span><%= local_time_tag(@group.first_seen_at, format: :date_only) %></span>
          </div>
          <div>
            <span class="kicker">Last seen</span>
            <span><%= local_time_tag(@group.last_seen_at, format: :date_only) %></span>
          </div>
          <% if @group.introduced_in_release.present? %>
            <div>
              <span class="kicker">Introduced</span>
              <span><code><%= @group.introduced_in_release %></code></span>
            </div>
          <% end %>
          <% if @group.regressed_in_release.present? %>
            <div>
              <span class="kicker">Regressed</span>
              <span><code><%= @group.regressed_in_release %></code></span>
            </div>
          <% end %>
        </div>

        <div class="event-group-actions">
          <% if @group.unresolved? %>
            <%= button_to resolve_project_error_group_path(@project, @group),
                          method: :patch,
                          class: "btn btn-resolve btn-sm inline-flex items-center gap-1.5",
                          form: { data: { turbo: false } } do %>
              <%= app_icon(:check, css: "w-3.5 h-3.5") %><span>Mark as fixed</span>
            <% end %>
            <%= button_to ignore_project_error_group_path(@project, @group),
                          method: :patch,
                          class: "btn btn-ghost btn-sm inline-flex items-center gap-1.5",
                          form: { data: { turbo: false } } do %>
              <%= app_icon(:x, css: "w-3.5 h-3.5") %><span>Ignore</span>
            <% end %>
            <%= button_to archive_project_error_group_path(@project, @group),
                          method: :patch,
                          class: "btn btn-ghost btn-sm inline-flex items-center gap-1.5",
                          form: { data: { turbo: false } } do %>
              <%= app_icon(:archive, css: "w-3.5 h-3.5") %><span>Archive</span>
            <% end %>
          <% else %>
            <%= button_to reopen_project_error_group_path(@project, @group),
                          method: :patch,
                          class: "btn btn-reopen btn-sm inline-flex items-center gap-1.5",
                          form: { data: { turbo: false } } do %>
              <%= app_icon(:upload, css: "w-3.5 h-3.5") %><span>Reopen</span>
            <% end %>
          <% end %>
          <%= link_to project_path(@project, group_uuid: @group.uuid, filter: @group.status == "unresolved" ? "unresolved" : @group.status),
                      class: "btn btn-ghost btn-sm inline-flex items-center gap-1.5" do %>
            <%= app_icon(:folder_open, css: "w-3.5 h-3.5") %><span>View all in inbox</span>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="card">
        <p class="kicker">Error group</p>
        <p class="text-slate-600 text-sm">This event has not been grouped yet.</p>
        <%= link_to project_path(@project), class: "btn-ghost btn-sm mt-2 inline-flex items-center gap-1.5" do %>
          <%= app_icon(:arrow_left, css: "w-3.5 h-3.5") %><span>Back to inbox</span>
        <% end %>
      </div>
    <% end %>

    <%# Event metadata %>
    <div class="card event-meta-card">
      <p class="kicker">Event</p>
      <dl class="event-meta-list">
        <dt>ID</dt>
        <dd><code class="text-xs break-all"><%= @event.uuid %></code></dd>
        <dt>Occurred</dt>
        <dd><%= local_time_tag(@event.occurred_at, format: :long) %></dd>
        <dt>Level</dt>
        <dd><%= render "shared/widgets/severity_badge", level: @event.level.presence || "error" %></dd>
        <dt>Stage</dt>
        <dd><span class="stage-tag"><%= @group&.stage || @event.context&.dig("environment") || "—" %></span></dd>
        <% if @event.fingerprint.present? %>
          <dt>Fingerprint</dt>
          <dd><code class="text-xs break-all"><%= @event.fingerprint %></code></dd>
        <% end %>
      </dl>
    </div>
  </aside>

  <%# ── Main content ───────────────────────────────────────────────────────── %>
  <main class="min-w-0 flex flex-col gap-4">
    <%# Header %>
    <header class="detail-actionbar">
      <div class="detail-actionbar-left">
        <h1 class="detail-title"><%= @group&.title || @event.message.to_s.lines.first %></h1>
        <% if @group&.subtitle.present? %>
          <p class="detail-subtitle muted"><%= @group.subtitle %></p>
        <% end %>
        <p class="text-slate-600 text-sm mt-1">
          <%= @project.name %>
          &middot; <%= local_time_tag(@event.occurred_at, format: :long) %>
        </p>
      </div>
    </header>

    <%= render "project_events/event_detail_tabs",
               project: @project,
               event: @event,
               group: @group,
               occurrences: @occurrences,
               related_logs: @related_logs,
               filter_param: nil,
               query_param: nil,
               active_tab: active_tab,
               stacktrace_tab_label: stacktrace_tab_label,
               stacktrace_partial: stacktrace_partial,
               exception_data: exception_data,
               request_details: request_details,
               frame_scope: frame_scope,
               visible_frames: visible_frames,
               selected_frame_index: selected_frame_index,
               selected_frame: selected_frame,
               source_excerpt: source_excerpt,
               backtrace: backtrace,
               local_variables: local_variables,
               instance_variables: instance_variables,
               wrapper_classes: "detail-tabs-wrap" %>
  </main>

</div>
