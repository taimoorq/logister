<turbo-frame id="error_detail" target="error_detail" style="view-transition-name: error-detail-pane; view-transition-class: error-detail-pane;">
  <% exception_data = event.context.is_a?(Hash) ? (event.context["exception"] || event.context[:exception]) : nil %>
  <% backtrace = exception_data.is_a?(Hash) ? (exception_data["backtrace"] || exception_data[:backtrace]) : nil %>
  <% filter_param = local_assigns[:filter] || "unresolved" %>
  <% query_param  = local_assigns[:query]  || "" %>
  <% related_logs = local_assigns[:related_logs] || [] %>
  <% active_tab   = local_assigns[:tab].presence_in(%w[stacktrace context occurrences related_logs]) || "stacktrace" %>

  <%# ── Action bar ──────────────────────────────────────────────────────── %>
  <header class="detail-actionbar card">
    <div class="detail-actionbar-left">
      <span class="detail-status-badge status-<%= group&.status || "unresolved" %>">
        <%= (group&.status || "unresolved").upcase %>
      </span>
      <h2 class="detail-title"><%= truncate(group&.title || event.message.to_s.lines.first, length: 120) %></h2>
      <% if group&.subtitle.present? %>
        <p class="muted detail-subtitle"><%= group.subtitle %></p>
      <% end %>
      <p class="muted">
        <%= project.name %>
        · <%= local_time_tag(event.occurred_at, format: :long) %>
        <% if group %>
          · <strong><%= group.occurrence_count %></strong> total occurrences
          <% if group.introduced_in_release.present? %>
            · introduced in <code><%= group.introduced_in_release %></code>
          <% end %>
          <% if group.regressed_in_release.present? %>
            · regressed in <code><%= group.regressed_in_release %></code>
          <% end %>
          · first seen <%= local_time_tag(group.first_seen_at, format: :date_only) %>
          · last seen <%= local_time_tag(group.last_seen_at, format: :date_only) %>
        <% end %>
      </p>
    </div>

    <% if group %>
      <div class="detail-actionbar-actions">
        <% if group.unresolved? %>
          <%= button_to "Mark as fixed",
                        resolve_project_error_group_path(project, group, filter: filter_param, q: query_param),
                        method: :patch,
                        class: "btn btn-resolve",
                        data: { turbo_stream: true } %>
          <%= button_to "Ignore",
                        ignore_project_error_group_path(project, group, filter: filter_param, q: query_param),
                        method: :patch,
                        class: "btn btn-ghost",
                        data: { turbo_stream: true } %>
          <%= button_to "Archive",
                        archive_project_error_group_path(project, group, filter: filter_param, q: query_param),
                        method: :patch,
                        class: "btn btn-ghost",
                        data: { turbo_stream: true } %>
        <% else %>
          <%= button_to "Reopen",
                        reopen_project_error_group_path(project, group, filter: filter_param, q: query_param),
                        method: :patch,
                        class: "btn btn-reopen",
                        data: { turbo_stream: true } %>
        <% end %>
      </div>
    <% end %>
  </header>

  <%# ── Tabs ──────────────────────────────────────────────────────────── %>
  <div class="detail-tabs-wrap card">
    <nav class="detail-tabs" role="tablist">
      <%= link_to "Stacktrace",
                  project_event_path(project, event, filter: filter_param, q: query_param, group_uuid: group&.uuid, tab: "stacktrace"),
                  class: "detail-tab #{'is-active' if active_tab == 'stacktrace'}",
                  role: "tab",
                  data: { turbo_frame: "error_detail", turbo_action: "advance" } %>
      <%= link_to "Context",
                  project_event_path(project, event, filter: filter_param, q: query_param, group_uuid: group&.uuid, tab: "context"),
                  class: "detail-tab #{'is-active' if active_tab == 'context'}",
                  role: "tab",
                  data: { turbo_frame: "error_detail", turbo_action: "advance" } %>
      <%= link_to "Occurrences (#{occurrences.size})",
                  project_event_path(project, event, filter: filter_param, q: query_param, group_uuid: group&.uuid, tab: "occurrences"),
                  class: "detail-tab #{'is-active' if active_tab == 'occurrences'}",
                  role: "tab",
                  data: { turbo_frame: "error_detail", turbo_action: "advance" } %>
      <%= link_to "Related logs (#{related_logs.size})",
                  project_event_path(project, event, filter: filter_param, q: query_param, group_uuid: group&.uuid, tab: "related_logs"),
                  class: "detail-tab #{'is-active' if active_tab == 'related_logs'}",
                  role: "tab",
                  data: { turbo_frame: "error_detail", turbo_action: "advance" } %>
    </nav>

    <%# ── Stacktrace panel ─────────────────────────────────────────────── %>
    <section id="tab-stacktrace" class="detail-panel<%= ' is-hidden' unless active_tab == 'stacktrace' %>">
      <div class="detail-meta-strip">
        <div><span class="kicker">Event ID</span><code><%= event.uuid %></code></div>
        <div><span class="kicker">Fingerprint</span><code><%= event.fingerprint.presence || group&.fingerprint || "—" %></code></div>
        <div><span class="kicker">Severity</span><%= render "shared/widgets/severity_badge", level: event.level.presence || "error" %></div>
        <div><span class="kicker">Stage</span><span class="stage-tag"><%= group&.stage || "production" %></span></div>
      </div>

      <% if backtrace.respond_to?(:any?) && backtrace.any? %>
        <pre class="stacktrace"><code><%= Array(backtrace).join("\n") %></code></pre>
      <% else %>
        <pre class="stacktrace"><code><%= event.message %></code></pre>
      <% end %>
    </section>

    <%# ── Context panel ────────────────────────────────────────────────── %>
    <section id="tab-context" class="detail-panel<%= ' is-hidden' unless active_tab == 'context' %>">
      <%= render "project_events/context_panel", event: event %>
    </section>

    <%# ── Occurrences panel ───────────────────────────────────────────── %>
    <section id="tab-occurrences" class="detail-panel<%= ' is-hidden' unless active_tab == 'occurrences' %>">
      <% if occurrences.any? %>
        <table class="occurrences-table">
          <thead>
            <tr>
              <th>When</th>
              <th>Message</th>
              <th>Severity</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% occurrences.each do |occ| %>
              <% ev = occ.ingest_event %>
              <tr>
                <td><%= local_time_tag(ev.occurred_at, format: :long) %></td>
                <td><%= truncate(ev.message.to_s.lines.first, length: 80) %></td>
                <td><%= render "shared/widgets/severity_badge", level: ev.level.presence || "error" %></td>
                <td>
                  <%= link_to "View",
                              project_event_path(project, ev, filter: filter_param, q: query_param, group_uuid: group&.uuid),
                              class: "inline-link",
                              data: { turbo_frame: "error_detail", turbo_action: "advance" } %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="muted">No occurrences recorded yet.</p>
      <% end %>
    </section>

    <section id="tab-related-logs" class="detail-panel<%= ' is-hidden' unless active_tab == 'related_logs' %>">
      <% if related_logs.any? %>
        <table class="occurrences-table">
          <thead>
            <tr>
              <th>When</th>
              <th>Level</th>
              <th>Message</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% related_logs.each do |log_event| %>
              <tr>
                <td><%= local_time_tag(log_event.occurred_at, format: :long) %></td>
                <td><%= render "shared/widgets/severity_badge", level: log_event.level.presence || "info" %></td>
                <td><%= truncate(log_event.message.to_s.lines.first, length: 120) %></td>
                <td>
                  <%= link_to "View",
                              project_event_path(project, log_event, filter: filter_param, q: query_param, group_uuid: group&.uuid),
                              class: "inline-link",
                              data: { turbo_frame: "error_detail", turbo_action: "advance" } %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="muted">No logs found in the correlation window.</p>
      <% end %>
    </section>
  </div>
</turbo-frame>
