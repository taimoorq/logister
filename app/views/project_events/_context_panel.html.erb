<% details = request_context_details(event) %>

<div class="context-details">
  <p class="kicker">Request details</p>

  <dl class="context-detail-list">
    <% if details[:client_ip].present? %>
      <dt>clientIp</dt>
      <dd><code><%= details[:client_ip] %></code></dd>
    <% end %>

    <% if details[:http_method].present? %>
      <dt>httpMethod</dt>
      <dd><code><%= details[:http_method] %></code></dd>
    <% end %>

    <% if details[:http_version].present? %>
      <dt>httpVersion</dt>
      <dd><code><%= details[:http_version] %></code></dd>
    <% end %>

    <% if details[:rails_action].present? %>
      <dt>railsAction</dt>
      <dd><code><%= details[:rails_action] %></code></dd>
    <% end %>

    <% if details[:referer].present? %>
      <dt>referer</dt>
      <dd><%= details[:referer] %></dd>
    <% end %>

    <% if details[:request_id].present? %>
      <dt>requestId</dt>
      <dd><code><%= details[:request_id] %></code></dd>
    <% end %>

    <% if details[:url].present? %>
      <dt>url</dt>
      <dd><%= details[:url] %></dd>
    <% end %>
  </dl>

  <% if details[:headers].present? %>
    <p class="kicker">headers</p>
    <div class="copy-block" data-controller="copy" data-copy-text-value="<%= pretty_context_json(details[:headers]) %>">
      <button type="button" class="copy-block-btn" data-action="copy#copy" onclick="window.logisterCopyButton && window.logisterCopyButton(this)" aria-label="Copy headers JSON">
        <%= app_icon(:clipboard, css: "w-3.5 h-3.5") %>
        <span data-copy-target="buttonLabel">Copy</span>
      </button>
      <pre class="context-json" data-copy-target="source"><code><%= pretty_context_json(details[:headers]) %></code></pre>
    </div>
  <% end %>

  <% if details[:params].present? %>
    <p class="kicker">params</p>
    <div class="copy-block" data-controller="copy" data-copy-text-value="<%= pretty_context_json(details[:params]) %>">
      <button type="button" class="copy-block-btn" data-action="copy#copy" onclick="window.logisterCopyButton && window.logisterCopyButton(this)" aria-label="Copy params JSON">
        <%= app_icon(:clipboard, css: "w-3.5 h-3.5") %>
        <span data-copy-target="buttonLabel">Copy</span>
      </button>
      <pre class="context-json" data-copy-target="source"><code><%= pretty_context_json(details[:params]) %></code></pre>
    </div>
  <% end %>

  <p class="kicker">full context</p>
  <div class="copy-block" data-controller="copy" data-copy-text-value="<%= pretty_context_json(event.context || {}) %>">
    <button type="button" class="copy-block-btn" data-action="copy#copy" onclick="window.logisterCopyButton && window.logisterCopyButton(this)" aria-label="Copy full context JSON">
      <%= app_icon(:clipboard, css: "w-3.5 h-3.5") %>
      <span data-copy-target="buttonLabel">Copy</span>
    </button>
    <pre class="context-json" data-copy-target="source"><code><%= pretty_context_json(event.context || {}) %></code></pre>
  </div>
</div>
