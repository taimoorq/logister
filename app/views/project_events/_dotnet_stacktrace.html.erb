<% dotnet_presenter = ProjectEvents::DotnetEventPresenter.new(event, exception_data) %>
<% dotnet_summary = dotnet_presenter.summary(event.message) %>
<% dotnet_frames = dotnet_presenter.frames %>
<% dotnet_stack_lines = dotnet_presenter.stack_lines %>
<% dotnet_matches = dotnet_presenter.endpoint_matches(event.message) %>
<% runtime_details = dotnet_presenter.runtime_details %>
<% exception_chain = dotnet_presenter.exception_chain %>
<% exception_data_fields = dotnet_presenter.exception_data %>
<% query_parameters = dotnet_presenter.query_parameters %>
<% request_headers = dotnet_presenter.request_headers %>
<% request_cookies = dotnet_presenter.request_cookies %>
<% routing_details = dotnet_presenter.routing_details %>
<% raw_exception_details = exception_data.is_a?(Hash) ? pretty_context_json(exception_data) : event.message %>
<% stack_fallback = dotnet_stack_lines.presence || Array(dotnet_frames).map { |frame| frame[:raw] }.compact_blank.presence || [event.message] %>

<div class="dotnet-dev-page">
  <header class="dotnet-dev-header">
    <h3>An unhandled exception occurred while processing the request.</h3>

    <p class="dotnet-dev-lede">
      <strong><%= dotnet_summary[:class_name] %>:</strong>
      <%= dotnet_summary[:message].to_s.lines.first.to_s.strip.presence || event.message.to_s.lines.first %>
    </p>

    <% if dotnet_matches.any? %>
      <div class="dotnet-dev-matches">
        <% dotnet_matches.each do |match| %>
          <div><%= match %></div>
        <% end %>
      </div>
    <% end %>

    <% if stack_fallback.first.present? %>
      <p class="dotnet-dev-top-frame"><%= stack_fallback.first %></p>
    <% end %>
  </header>

  <nav class="dotnet-dev-tabs" aria-label=".NET exception detail sections">
    <a href="#dotnet-stack" class="dotnet-dev-tab is-active">Stack</a>
    <a href="#dotnet-query" class="dotnet-dev-tab">Query</a>
    <a href="#dotnet-cookies" class="dotnet-dev-tab">Cookies</a>
    <a href="#dotnet-headers" class="dotnet-dev-tab">Headers</a>
    <a href="#dotnet-routing" class="dotnet-dev-tab">Routing</a>
  </nav>

  <section id="dotnet-stack" class="dotnet-dev-stack-panel">
    <h4><%= dotnet_presenter.developer_exception_title(event.message, compact: true) %></h4>

    <% if stack_fallback.any? %>
      <pre class="dotnet-dev-stack"><code><%= stack_fallback.join("\n") %></code></pre>
    <% else %>
      <p class="muted">No .NET stack frames were captured for this event.</p>
    <% end %>
  </section>

  <details class="dotnet-dev-raw">
    <summary>Show raw exception details</summary>
    <div class="copy-block copy-block-tight" data-controller="copy" data-copy-text-value="<%= raw_exception_details %>">
      <button type="button" class="copy-block-btn" data-action="copy#copy" aria-label="Copy raw exception details">
        <%= app_icon(:clipboard, css: "w-3.5 h-3.5") %>
        <span data-copy-target="buttonLabel">Copy</span>
      </button>
      <pre class="context-json" data-copy-target="source"><code><%= raw_exception_details %></code></pre>
    </div>
  </details>

  <div class="dotnet-dev-section-grid">
    <section id="dotnet-query" class="dotnet-dev-section">
      <h4>Query</h4>
      <% if query_parameters.any? %>
        <table class="dotnet-dev-table">
          <tbody>
            <% query_parameters.each do |key, value| %>
              <tr>
                <th><code><%= key %></code></th>
                <td><code><%= value.is_a?(Hash) || value.is_a?(Array) ? pretty_context_json(value) : value %></code></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="muted">No query string values were captured.</p>
      <% end %>
    </section>

    <section id="dotnet-cookies" class="dotnet-dev-section">
      <h4>Cookies</h4>
      <% if request_cookies.any? %>
        <table class="dotnet-dev-table">
          <tbody>
            <% request_cookies.each do |key, value| %>
              <tr>
                <th><code><%= key %></code></th>
                <td><code><%= value.is_a?(Hash) || value.is_a?(Array) ? pretty_context_json(value) : value %></code></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="muted">No cookies were captured.</p>
      <% end %>
    </section>

    <section id="dotnet-headers" class="dotnet-dev-section">
      <h4>Headers</h4>
      <% if request_headers.any? %>
        <table class="dotnet-dev-table">
          <tbody>
            <% request_headers.each do |key, value| %>
              <tr>
                <th><code><%= key %></code></th>
                <td><code><%= value.is_a?(Hash) || value.is_a?(Array) ? pretty_context_json(value) : value %></code></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="muted">No request headers were captured.</p>
      <% end %>
    </section>

    <section id="dotnet-routing" class="dotnet-dev-section">
      <h4>Routing</h4>
      <% if routing_details.any? %>
        <table class="dotnet-dev-table">
          <tbody>
            <% routing_details.each do |key, value| %>
              <tr>
                <th><code><%= key.to_s.humanize %></code></th>
                <td><code><%= value.is_a?(Hash) || value.is_a?(Array) ? pretty_context_json(value) : value %></code></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="muted">No routing details were captured.</p>
      <% end %>
    </section>
  </div>

  <div class="dotnet-dev-section-grid dotnet-dev-secondary-grid">
    <section class="dotnet-dev-section">
      <h4>Runtime details</h4>
      <% if runtime_details.compact_blank.any? %>
        <table class="dotnet-dev-table">
          <tbody>
            <% runtime_details.compact_blank.each do |key, value| %>
              <tr>
                <th><code><%= key.to_s.humanize %></code></th>
                <td><code><%= value %></code></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="muted">No .NET runtime details were captured.</p>
      <% end %>
    </section>

    <section class="dotnet-dev-section">
      <h4>Exception chain</h4>
      <% if exception_chain.any? %>
        <table class="dotnet-dev-table">
          <tbody>
            <% exception_chain.each do |entry| %>
              <tr>
                <th><code><%= entry[:label] %></code></th>
                <td>
                  <strong><%= entry[:class_name] %></strong>
                  <% if entry[:message].present? %>
                    <span><%= entry[:message] %></span>
                  <% end %>
                  <% if entry[:frames].any? %>
                    <code><%= entry[:frames].first[:file] %>:<%= entry[:frames].first[:line_number] %></code>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="muted">No inner .NET exceptions were captured.</p>
      <% end %>
    </section>

    <section class="dotnet-dev-section">
      <h4>Exception data</h4>
      <% if exception_data_fields.any? %>
        <table class="dotnet-dev-table">
          <tbody>
            <% exception_data_fields.each do |key, value| %>
              <tr>
                <th><code><%= key %></code></th>
                <td><code><%= value.is_a?(Hash) || value.is_a?(Array) ? pretty_context_json(value) : value %></code></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="muted">No <code>Exception.Data</code> entries were captured.</p>
      <% end %>
    </section>
  </div>
</div>
